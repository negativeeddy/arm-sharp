{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Web UI (F5 - devcontainer)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/src/ArmRipper.WebUi/bin/Debug/net10.0/ArmRipper.WebUi.dll",
            "args": [],
            "cwd": "${workspaceFolder}/src/ArmRipper.WebUi",
            "stopAtEntry": false,
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development",
                "ASPNETCORE_URLS": "http://+:8080"
            },
            "console": "internalConsole"
        },
        {
            "name": "Web UI (Attach to Docker)",
            "type": "coreclr",
            "request": "attach",
            "processId": "${command:pickRemoteProcess}",
            "pipeTransport": {
                "pipeProgram": "docker",
                "pipeArgs": [
                    "exec",
                    "-i",
                    "arm-sharp-debug"
                ],
                "debuggerPath": "/vsdbg/vsdbg",
                "pipeCwd": "${workspaceFolder}",
                "quoteArgs": false
            },
            "sourceFileMap": {
                "/src": "${workspaceFolder}"
            }
        }
    ]
}
