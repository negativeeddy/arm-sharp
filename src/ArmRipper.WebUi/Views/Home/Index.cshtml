@model IEnumerable<ArmRipper.Core.Models.Job>
@{
    ViewData["Title"] = "Home - ARM";
    var hwEncoders = ViewBag.HardwareEncoders as System.Collections.IList;
    var hasEncoders = hwEncoders is { Count: > 0 }
        && hwEncoders[0] is Dictionary<string, object> first
        && (!first.TryGetValue("available", out var a) || a is not false);

    string FormatBytes(long? bytes) =>
        bytes is long b
            ? b >= 1099511627776L ? $"{b / 1099511627776.0:F1} TB"
            : b >= 1073741824 ? $"{b / 1073741824.0:F1} GB"
            : b >= 1048576 ? $"{b / 1048576.0:F1} MB"
            : $"{b / 1024.0:F1} KB"
            : "—";
}

<div id="activeJobsTable">
    <table class="table table-striped table-hover table-sm">
        <thead>
            <tr>
                <th>ID</th>
                <th>Title</th>
                <th>Disc Type</th>
                <th>Status</th>
                <th>Started</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr><td colspan="6" class="text-center text-muted">No active rips.</td></tr>
            }
            else
            {
                @foreach (var job in Model)
                {
                    <tr>
                        <td>@job.Id</td>
                        <td>@job.Title</td>
                        <td>@job.DiscType</td>
                        <td>
                            @if (!string.IsNullOrEmpty(job.Warnings))
                            {
                                <span class="badge bg-warning text-dark" title="@job.Warnings">Warning</span>
                            }
                            else
                            {
                                @job.Status
                            }
                        </td>
                        <td>@job.StartTime.ToString("g")</td>
                        <td><a href="/jobs/jobdetail?jobId=@job.Id" class="btn btn-sm btn-outline-primary">View</a></td>
                    </tr>
                    <tr class="pipeline-row">
                        <td colspan="6" class="p-2 bg-light">
                            <partial name="_Pipeline" model="job" />
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

<div class="row mb-3">
    <div class="col-md-3 mb-2">
        <div class="card h-100">
            <div class="card-body py-3">
                <h6 class="card-title text-muted border-bottom pb-2">System</h6>
                <dl class="row mb-0 small">
                    <dt class="col-5">Name</dt>
                    <dd class="col-7 mb-1">@(ViewBag.Hostname ?? "—")</dd>
                    <dt class="col-5">CPU</dt>
                    <dd class="col-7 mb-1 text-truncate" title="@ViewBag.CpuModel">@(ViewBag.CpuModel ?? "—")</dd>
                    <dt class="col-5">Cores</dt>
                    <dd class="col-7 mb-1">@ViewBag.CpuCount</dd>
                    <dt class="col-5">CPU Temp</dt>
                    <dd class="col-7 mb-1">@(ViewBag.CpuTemp is double t ? $"{t:F1}°C" : "—")</dd>
                    <dt class="col-5">Usage</dt>
                    <dd class="col-7 mb-1">@(ViewBag.CpuUsage is double u ? $"{u:F1}%" : "—")</dd>
                </dl>
            </div>
        </div>
    </div>
    <div class="col-md-3 mb-2">
        <div class="card h-100">
            <div class="card-body py-3">
                <h6 class="card-title text-muted border-bottom pb-2">System Memory</h6>
                <dl class="row mb-0 small">
                    <dt class="col-5">Total</dt>
                    <dd class="col-7 mb-1">@FormatBytes(ViewBag.MemTotal)</dd>
                    <dt class="col-5">Free</dt>
                    <dd class="col-7 mb-1">@FormatBytes(ViewBag.MemFree)</dd>
                    <dt class="col-5">Used</dt>
                    <dd class="col-7 mb-1">@FormatBytes(ViewBag.MemUsed)</dd>
                    <dt class="col-5">Usage</dt>
                    <dd class="col-7 mb-1">
                        @if (ViewBag.MemTotal is long mt && ViewBag.MemUsed is long mu && mt > 0)
                        {
                            <span>@($"{mu / (double)mt * 100:F1}%")</span>
                        }
                        else
                        {
                            <span>—</span>
                        }
                    </dd>
                </dl>
            </div>
        </div>
    </div>
    <div class="col-md-3 mb-2">
        <div class="card h-100">
            <div class="card-body py-3">
                <h6 class="card-title text-muted border-bottom pb-2">Storage</h6>
                @{
                    var tc = ViewBag.StorageTranscode as Dictionary<string, object>;
                    var co = ViewBag.StorageCompleted as Dictionary<string, object>;
                }
                @if (tc is not null)
                {
                    <div class="small mb-2">
                        <div class="fw-bold text-muted mb-1">Transcode</div>
                        <dl class="row mb-0 small">
                            <dt class="col-5">Free</dt>
                            <dd class="col-7 mb-1">@FormatBytes(tc["free"] as long?)</dd>
                            <dt class="col-5">Used</dt>
                            <dd class="col-7 mb-1">@(tc["used_pct"])%</dd>
                        </dl>
                        <div class="text-muted small text-truncate" title="@tc["path"]">@tc["path"]</div>
                    </div>
                }
                @if (co is not null)
                {
                    <div class="small">
                        <div class="fw-bold text-muted mb-1">Completed</div>
                        <dl class="row mb-0 small">
                            <dt class="col-5">Free</dt>
                            <dd class="col-7 mb-1">@FormatBytes(co["free"] as long?)</dd>
                            <dt class="col-5">Used</dt>
                            <dd class="col-7 mb-1">@(co["used_pct"])%</dd>
                        </dl>
                        <div class="text-muted small text-truncate" title="@co["path"]">@co["path"]</div>
                    </div>
                }
                @if (tc is null && co is null)
                {
                    <div class="text-muted small">Unavailable</div>
                }
            </div>
        </div>
    </div>
    <div class="col-md-3 mb-2">
        <div class="card h-100">
            <div class="card-body py-3">
                <h6 class="card-title text-muted border-bottom pb-2">Hardware Encoders</h6>
                @if (hasEncoders)
                {
                    <ul class="list-unstyled small mb-0">
                        @foreach (Dictionary<string, object> enc in hwEncoders!)
                        {
                            <li class="mb-1">
                                <span class="fw-bold">@enc["vendor"]</span>
                                @if (enc.TryGetValue("type", out var ty)) { <span class="text-muted">@ty</span> }
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <div class="text-muted small">None detected</div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            arm.startJobRefresh();
        });
    </script>
}
