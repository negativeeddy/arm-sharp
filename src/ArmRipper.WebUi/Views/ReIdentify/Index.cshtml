@{
    ViewData["Title"] = "Re-Identify Episodes — ARM";
    var jobs = ViewBag.CompletedJobs as List<dynamic> ?? [];
}

<h1>Re-Identify Episodes</h1>
<p class="text-muted">Select a completed TV-series job and re-run the episode identification pipeline to see if results have improved.</p>

<div class="card mb-4">
    <div class="card-body">
        <form id="reidentifyForm" method="post" action="/reidentify/run">
            <div class="form-group row">
                <label for="jobSelect" class="col-sm-2 col-form-label">Job</label>
                <div class="col-sm-10">
                    <select id="jobSelect" name="jobId" class="form-control" required>
                        <option value="">— Select a completed job —</option>
                        @foreach (var job in jobs)
                        {
                            var label = $"Job {job.Id}: {job.Title}";
                            if (!string.IsNullOrEmpty(job.VideoType))
                            {
                                label += $" ({job.VideoType})";
                            }
                            if (job.SeasonNumber is not null)
                            {
                                label += $" S{job.SeasonNumber}";
                            }
                            if (!string.IsNullOrEmpty(job.Label))
                            {
                                label += $" [{job.Label}]";
                            }
                            <option value="@job.Id">@label</option>
                        }
                    </select>
                </div>
            </div>

            <div class="form-group row">
                <div class="col-sm-10 offset-sm-2">
                    <div class="form-check">
                        <input type="checkbox" id="saveCheck" name="save" value="true" class="form-check-input" />
                        <label class="form-check-label" for="saveCheck">
                            <strong>Save to database</strong>
                            <small class="text-muted"> — write the new episode numbers/titles back to the database (irreversible)</small>
                        </label>
                    </div>
                </div>
            </div>

            <div class="form-group row">
                <div class="col-sm-10 offset-sm-2">
                    <button type="submit" id="runBtn" class="btn btn-primary">
                        🎯 Re-Identify
                    </button>
                    <span id="spinner" style="display:none;" class="ml-2">
                        <span class="spinner-border spinner-border-sm text-secondary" role="status"></span>
                        Running identification...
                    </span>
                </div>
            </div>
        </form>
    </div>
</div>

<div id="resultsArea" style="display:none;">
    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span id="resultTitle"></span>
            <span id="saveBadge" class="badge badge-success" style="display:none;">✓ Saved to database</span>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-sm table-bordered mb-0" id="comparisonTable">
                    <thead class="thead-light">
                        <tr>
                            <th style="width:4%;">#</th>
                            <th style="width:18%;">File</th>
                            <th style="width:8%;">Duration</th>
                            <th style="width:15%;" class="text-center">Before</th>
                            <th style="width:15%;" class="text-center">After</th>
                            <th style="width:20%;">Title</th>
                            <th style="width:12%;">Provider</th>
                            <th style="width:8%;">Confidence</th>
                        </tr>
                    </thead>
                    <tbody id="comparisonBody">
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div id="errorArea" style="display:none;" class="alert alert-danger"></div>

@section Scripts {
<script>
    $(function () {
        $('#reidentifyForm').on('submit', function (e) {
            e.preventDefault();

            var jobId = $('#jobSelect').val();
            if (!jobId) return;

            var save = $('#saveCheck').is(':checked');
            $('#runBtn').prop('disabled', true);
            $('#spinner').show();
            $('#resultsArea').hide();
            $('#errorArea').hide();

            $.ajax({
                url: '/reidentify/run',
                method: 'POST',
                data: { jobId: parseInt(jobId), save: save },
                dataType: 'json',
                success: function (data) {
                    if (data.error) {
                        $('#errorArea').text(data.error).show();
                        return;
                    }
                    renderResults(data);
                },
                error: function (xhr) {
                    var msg = 'Request failed: ' + (xhr.responseJSON?.error || xhr.statusText || 'Unknown error');
                    $('#errorArea').text(msg).show();
                },
                complete: function () {
                    $('#runBtn').prop('disabled', false);
                    $('#spinner').hide();
                }
            });
        });

        function renderResults(data) {
            $('#resultTitle').text(
                'Job ' + data.jobId + ': ' + data.title
                + (data.season ? ' S' + data.season : '')
                + (data.discLabel ? ' [' + data.discLabel + ']' : '')
                + ' — ' + data.trackCount + ' tracks'
            );

            if (data.saved) {
                $('#saveBadge').show();
            } else {
                $('#saveBadge').hide();
            }

            var tbody = $('#comparisonBody');
            tbody.empty();

            if (!data.comparison || data.comparison.length === 0) {
                tbody.append('<tr><td colspan="8" class="text-muted">No tracks to display.</td></tr>');
            } else {
                $.each(data.comparison, function (i, t) {
                    var rowClass = t.changed ? 'table-warning' : '';
                    var arrow = t.changed ? ' → ' : '';

                    var oldVal = t.oldDisplay || '—';
                    var newVal = t.changed ? '<strong>' + (t.newDisplay || '—') + '</strong>' : (t.newDisplay || '—');

                    // Build episode cell with before/after
                    var beforeCell = t.changed
                        ? '<span class="text-muted"><s>' + oldVal + '</s></span>'
                        : oldVal;

                    var afterCell = newVal;

                    // Title cell: show old title struck through if changed
                    var titleHtml = '';
                    if (t.changed && t.oldTitle) {
                        titleHtml += '<div class="text-muted small"><s>' + escapeHtml(t.oldTitle) + '</s></div>';
                    }
                    if (t.newTitle) {
                        titleHtml += '<div>' + (t.changed ? '<strong>' : '') + escapeHtml(t.newTitle) + (t.changed ? '</strong>' : '') + '</div>';
                    } else if (!t.oldTitle && !t.newTitle) {
                        titleHtml = '<span class="text-muted">—</span>';
                    }

                    var row = '<tr class="' + rowClass + '">'
                        + '<td>' + t.trackIndex + '</td>'
                        + '<td class="small">' + escapeHtml(t.fileName) + '</td>'
                        + '<td class="small">' + escapeHtml(t.duration) + '</td>'
                        + '<td class="text-center">' + beforeCell + '</td>'
                        + '<td class="text-center">' + afterCell + '</td>'
                        + '<td class="small">' + titleHtml + '</td>'
                        + '<td class="small">' + (t.provider || '—') + '</td>'
                        + '<td class="small text-center">' + (t.confidence || '—') + '</td>'
                        + '</tr>';

                    tbody.append(row);
                });
            }

            $('#resultsArea').show();

            // Scroll to results
            $('html, body').animate({ scrollTop: $('#resultsArea').offset().top - 80 }, 300);
        }

        function escapeHtml(str) {
            if (!str) return '';
            return $('<span>').text(str).html();
        }
    });
</script>
}
