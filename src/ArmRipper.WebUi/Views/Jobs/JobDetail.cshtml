@model ArmRipper.Core.Models.Job
@{
    ViewData["Title"] = $"Job {Model.Id} - ARM";
    var meta = ViewBag.Metadata as ArmRipper.Core.Metadata.OmdbTitleResult;
}

<h1>Job @Model.Id: @Model.Title</h1>

<div class="row mb-4" data-job-id="@Model.Id">
    @if (Model.PosterUrl is not null)
    {
        <div class="col-md-3 mb-3">
            <img src="@Model.PosterUrl" alt="Poster" class="img-fluid rounded shadow-sm" />
        </div>
        <div class="col-md-9">
            <dl class="row mb-0">
                <dt class="col-sm-3">Disc Type</dt>
                <dd class="col-sm-9">@Model.DiscType</dd>
                <dt class="col-sm-3">Status</dt>
                <dd class="col-sm-9">
                    @if (!string.IsNullOrEmpty(Model.Warnings))
                    {
                        <span class="badge bg-warning text-dark" title="@Model.Warnings">Warning</span>
                    }
                    else
                    {
                        @Model.Status
                    }
                </dd>
                <dt class="col-sm-3">Rip Progress</dt>
                <dd class="col-sm-9">
                    <div class="d-flex align-items-center gap-2">
                        <div class="progress flex-grow-1" style="height:20px;">
                            <div class="progress-bar progress-bar-striped progress-bar-animated" role="progressbar"
                                 style="width:@(Model.MakeMkvProgress ?? 0)%" aria-valuenow="@(Model.MakeMkvProgress ?? 0)" aria-valuemin="0" aria-valuemax="100">
                                @(Model.MakeMkvProgress.HasValue ? $"{Model.MakeMkvProgress}%" : "0%")
                            </div>
                        </div>
                        @if (Model.Status is JobState.VideoRipping or JobState.TranscodeActive)
                        {
                            <span class="spinner-border spinner-border-sm text-secondary" role="status"></span>
                        }
                    </div>
                </dd>
                <dt class="col-sm-3">Transcode Progress</dt>
                <dd class="col-sm-9">
                    <div class="d-flex align-items-center gap-2">
                        <div class="progress flex-grow-1" style="height:20px;">
                            <div class="progress-bar progress-bar-striped progress-bar-animated bg-success" role="progressbar"
                                 style="width:@(Model.TranscodeProgress ?? 0)%" aria-valuenow="@(Model.TranscodeProgress ?? 0)" aria-valuemin="0" aria-valuemax="100">
                                @(Model.TranscodeProgress.HasValue ? $"{Model.TranscodeProgress}%" : "0%")
                            </div>
                        </div>
                    </div>
                </dd>
                <dt class="col-sm-3">Stage</dt>
                <dd class="col-sm-9">@(Model.Stage ?? "—")</dd>
                <dt class="col-sm-3">Started</dt>
                <dd class="col-sm-9">@Model.StartTime.ToLocalTime().ToString("g")</dd>
                <dt class="col-sm-3">Stopped</dt>
                <dd class="col-sm-9">@Model.StopTime?.ToLocalTime().ToString("g")</dd>
                <dt class="col-sm-3">Duration</dt>
                <dd class="col-sm-9">@Model.JobLength</dd>
                <dt class="col-sm-3">Titles</dt>
                <dd class="col-sm-9">@Model.NoOfTitles</dd>
                @if (!string.IsNullOrEmpty(Model.ProgressMessage))
                {
                    <dt class="col-sm-3">Progress</dt>
                    <dd class="col-sm-9">@Model.ProgressMessage</dd>
                }
                @if (!Model.Status.IsTerminal())
                {
                    <dt class="col-sm-3"></dt>
                    <dd class="col-sm-9">
                        @if (Model.Status is JobState.ManualWaitStarted)
                        {
                            <form method="post" action="/jobs/continue-wait" style="display:inline">
                                <input type="hidden" name="jobId" value="@Model.Id" />
                                <button type="submit" class="btn btn-success btn-sm">Start Now</button>
                            </form>
                        }
                        <form method="post" action="/jobs/cancel" onsubmit="return confirm('Cancel this job?')" style="display:inline">
                            <input type="hidden" name="jobId" value="@Model.Id" />
                            <button type="submit" class="btn btn-danger btn-sm">Cancel Job</button>
                        </form>
                    </dd>
                }
            </dl>
        </div>
    }
    else
    {
        <div class="col-12">
            <dl class="row mb-0">
                <dt class="col-sm-2">Disc Type</dt>
                <dd class="col-sm-10">@Model.DiscType</dd>
                <dt class="col-sm-2">Status</dt>
                <dd class="col-sm-10">
                    @if (!string.IsNullOrEmpty(Model.Warnings))
                    {
                        <span class="badge bg-warning text-dark" title="@Model.Warnings">Warning</span>
                    }
                    else
                    {
                        @Model.Status
                    }
                </dd>
                <dt class="col-sm-2">Rip Progress</dt>
                <dd class="col-sm-10">
                    <div class="d-flex align-items-center gap-2">
                        <div class="progress flex-grow-1" style="height:20px;">
                            <div class="progress-bar progress-bar-striped progress-bar-animated" role="progressbar"
                                 style="width:@(Model.MakeMkvProgress ?? 0)%" aria-valuenow="@(Model.MakeMkvProgress ?? 0)" aria-valuemin="0" aria-valuemax="100">
                                @(Model.MakeMkvProgress.HasValue ? $"{Model.MakeMkvProgress}%" : "0%")
                            </div>
                        </div>
                        @if (Model.Status is JobState.VideoRipping or JobState.TranscodeActive)
                        {
                            <span class="spinner-border spinner-border-sm text-secondary" role="status"></span>
                        }
                    </div>
                </dd>
                <dt class="col-sm-2">Transcode Progress</dt>
                <dd class="col-sm-10">
                    <div class="d-flex align-items-center gap-2">
                        <div class="progress flex-grow-1" style="height:20px;">
                            <div class="progress-bar progress-bar-striped progress-bar-animated bg-success" role="progressbar"
                                 style="width:@(Model.TranscodeProgress ?? 0)%" aria-valuenow="@(Model.TranscodeProgress ?? 0)" aria-valuemin="0" aria-valuemax="100">
                                @(Model.TranscodeProgress.HasValue ? $"{Model.TranscodeProgress}%" : "0%")
                            </div>
                        </div>
                    </div>
                </dd>
                <dt class="col-sm-2">Stage</dt>
                <dd class="col-sm-10">@(Model.Stage ?? "—")</dd>
                <dt class="col-sm-2">Started</dt>
                <dd class="col-sm-10">@Model.StartTime.ToLocalTime().ToString("g")</dd>
                <dt class="col-sm-2">Stopped</dt>
                <dd class="col-sm-10">@Model.StopTime?.ToLocalTime().ToString("g")</dd>
                <dt class="col-sm-2">Duration</dt>
                <dd class="col-sm-10">@Model.JobLength</dd>
                <dt class="col-sm-2">Titles</dt>
                <dd class="col-sm-10">@Model.NoOfTitles</dd>
                @if (!string.IsNullOrEmpty(Model.ProgressMessage))
                {
                    <dt class="col-sm-2">Progress</dt>
                    <dd class="col-sm-10">@Model.ProgressMessage</dd>
                }
                @if (!Model.Status.IsTerminal())
                {
                    <dt class="col-sm-2"></dt>
                    <dd class="col-sm-10">
                        @if (Model.Status is JobState.ManualWaitStarted)
                        {
                            <form method="post" action="/jobs/continue-wait" style="display:inline">
                                <input type="hidden" name="jobId" value="@Model.Id" />
                                <button type="submit" class="btn btn-success btn-sm">Start Now</button>
                            </form>
                        }
                        <form method="post" action="/jobs/cancel" onsubmit="return confirm('Cancel this job?')">
                            <input type="hidden" name="jobId" value="@Model.Id" />
                            <button type="submit" class="btn btn-danger btn-sm">Cancel Job</button>
                        </form>
                    </dd>
                }
            </dl>
        </div>
    }
</div>

@if (meta is not null)
{
    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span>@meta.Title (@meta.Year)</span>
            <span>
                @if (meta.Ratings is not null)
                {
                    foreach (var r in meta.Ratings)
                    {
                        <span class="badge bg-secondary me-1" title="@r.Source">@r.Source: @r.Value</span>
                    }
                }
                <span class="badge bg-warning text-dark">IMDb: @meta.ImdbRating</span>
            </span>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-8">
                    <p class="mb-2">@meta.Plot</p>
                    <dl class="row small mb-0">
                        <dt class="col-sm-3">Rated</dt>
                        <dd class="col-sm-9">@meta.Rated</dd>
                        <dt class="col-sm-3">Runtime</dt>
                        <dd class="col-sm-9">@meta.Runtime</dd>
                        <dt class="col-sm-3">Genre</dt>
                        <dd class="col-sm-9">@meta.Genre</dd>
                        <dt class="col-sm-3">Director</dt>
                        <dd class="col-sm-9">@meta.Director</dd>
                        <dt class="col-sm-3">Actors</dt>
                        <dd class="col-sm-9">@meta.Actors</dd>
                        <dt class="col-sm-3">Language</dt>
                        <dd class="col-sm-9">@meta.Language</dd>
                        <dt class="col-sm-3">Country</dt>
                        <dd class="col-sm-9">@meta.Country</dd>
                        <dt class="col-sm-3">Released</dt>
                        <dd class="col-sm-9">@meta.Released</dd>
                        @if (!string.IsNullOrEmpty(meta.Awards))
                        {
                            <dt class="col-sm-3">Awards</dt>
                            <dd class="col-sm-9">@meta.Awards</dd>
                        }
                    </dl>
                </div>
                @if (!string.IsNullOrEmpty(meta.Poster) && Model.PosterUrl is null)
                {
                    <div class="col-md-4">
                        <img src="@meta.Poster" alt="Poster" class="img-fluid rounded shadow-sm" />
                    </div>
                }
            </div>
        </div>
    </div>
}

<div class="row mb-4">
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span>Identification</span>
                @if (!Model.HasNiceTitle)
                {
                    <a href="/jobs/titlesearch?jobId=@Model.Id" class="btn btn-outline-primary btn-sm">Search for Title</a>
                }
            </div>
            <div class="card-body">
                <form method="post" action="/jobs/update-identification" class="mb-2">
                    <input type="hidden" name="jobId" value="@Model.Id" />
                    <table class="table table-sm table-borderless mb-0">
                        <thead>
                            <tr>
                                <th>Field</th>
                                <th>Auto</th>
                                <th>Manual</th>
                                <th>Final</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>Title</td>
                                <td>@(Model.TitleAuto ?? "—")</td>
                                <td><input type="text" name="title" class="form-control form-control-sm" value="@(Model.TitleManual ?? "")" /></td>
                                <td><strong>@Model.Title</strong></td>
                            </tr>
                            <tr>
                                <td>Year</td>
                                <td>@(Model.YearAuto ?? "—")</td>
                                <td><input type="text" name="year" class="form-control form-control-sm" value="@(Model.YearManual ?? "")" /></td>
                                <td><strong>@Model.Year</strong></td>
                            </tr>
                            <tr>
                                <td>Video Type</td>
                                <td>@(Model.VideoTypeAuto ?? "—")</td>
                                <td>
                                    <select name="videoType" class="form-select form-select-sm">
                                        <option value="">—</option>
                                        <option value="movie" selected="@(Model.VideoTypeManual == "movie")">movie</option>
                                        <option value="series" selected="@(Model.VideoTypeManual == "series")">series</option>
                                        <option value="episode" selected="@(Model.VideoTypeManual == "episode")">episode</option>
                                    </select>
                                </td>
                                <td><strong>@Model.VideoType</strong></td>
                            </tr>
                            <tr>
                                <td>IMDb ID</td>
                                <td>@(Model.ImdbIdAuto ?? "—")</td>
                                <td><input type="text" name="imdbId" class="form-control form-control-sm" value="@(Model.ImdbIdManual ?? "")" /></td>
                                <td><strong>@Model.ImdbId</strong></td>
                            </tr>
                            <tr>
                                <td>Poster URL</td>
                                <td class="text-truncate" style="max-width:200px" title="@Model.PosterUrlAuto">@(Model.PosterUrlAuto ?? "—")</td>
                                <td><input type="text" name="posterUrl" class="form-control form-control-sm" value="@(Model.PosterUrlManual ?? "")" /></td>
                                <td class="text-truncate" style="max-width:200px" title="@Model.PosterUrl">@(Model.PosterUrl ?? "—")</td>
                            </tr>
                        </tbody>
                    </table>
                    <button type="submit" class="btn btn-primary btn-sm">Save</button>
                </form>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header">Device</div>
            <div class="card-body">
                <dl class="row mb-0 small">
                    <dt class="col-sm-4">Device Path</dt>
                    <dd class="col-sm-8">@(Model.DevPath ?? "—")</dd>
                    <dt class="col-sm-4">Mount Point</dt>
                    <dd class="col-sm-8">@(Model.MountPoint ?? "—")</dd>
                    <dt class="col-sm-4">Label</dt>
                    <dd class="col-sm-8">@(Model.Label ?? "—")</dd>
                    <dt class="col-sm-4">Output Path</dt>
                    <dd class="col-sm-8"><code>@(Model.Path ?? "—")</code></dd>
                    <dt class="col-sm-4">CRC64</dt>
                    <dd class="col-sm-8"><code>@(Model.CrcId ?? "—")</code></dd>
                    <dt class="col-sm-4">Log File</dt>
                    <dd class="col-sm-8">@(Model.LogFile ?? "—")</dd>
                    <dt class="col-sm-4">Has Nice Title</dt>
                    <dd class="col-sm-8">@Model.HasNiceTitle</dd>
                    <dt class="col-sm-4">Is ISO</dt>
                    <dd class="col-sm-8">@Model.IsIso</dd>
                    <dt class="col-sm-4">Ejected</dt>
                    <dd class="col-sm-8">@Model.Ejected</dd>
                </dl>
            </div>
        </div>
    </div>
</div>

<div class="card mb-4">
    <div class="card-header">Pipeline</div>
    <div class="card-body" id="pipeline-container">
        <partial name="_Pipeline" model="Model" />
    </div>
</div>

<div class="card mb-4">
    <div class="card-header d-flex justify-content-between align-items-center">
        <a class="text-decoration-none" data-bs-toggle="collapse" href="#logCollapse" role="button" id="logToggle">
            Live Log ▾
        </a>
        <a href="/logs?jobId=@Model.Id" class="btn btn-outline-secondary btn-sm">View Full Log</a>
    </div>
    <div class="collapse show" id="logCollapse">
        <div class="card-body p-0">
            <pre id="logContent" class="mb-0 small p-2" style="max-height:300px; overflow-y:auto; background:#1e1e1e; color:#d4d4d4; font-family:monospace; font-size:12px; line-height:1.4;">Loading...</pre>
        </div>
    </div>
</div>

@if (!string.IsNullOrEmpty(Model.Warnings))
{
    <div class="card border-warning mb-4" id="warnings-card">
        <div class="card-header text-warning fw-bold">Warnings</div>
        <div class="card-body">
            <pre id="warnings-text" class="mb-0 small">@Model.Warnings</pre>
        </div>
    </div>
}

@if (!string.IsNullOrEmpty(Model.Errors))
{
    <div class="card border-danger mb-4" id="errors-card">
        <div class="card-header text-danger fw-bold">Errors</div>
        <div class="card-body">
            <pre id="errors-text" class="mb-0 small">@Model.Errors</pre>
        </div>
    </div>
}

<div class="card mb-4">
    <div class="card-header">
        <a class="text-decoration-none" data-bs-toggle="collapse" href="#configCollapse" role="button">
            Config Snapshot
        </a>
    </div>
    <div class="collapse" id="configCollapse">
        <div class="card-body">
            @if (Model.Config is null)
            {
                <div class="text-muted">No config snapshot.</div>
            }
            else
            {
                var cfg = Model.Config;
                <div class="row">
                    <div class="col-md-6">
                        <h6 class="text-muted">Rip Settings</h6>
                        <dl class="row small mb-3">
                            <dt class="col-6">Rip Method</dt>
                            <dd class="col-6">@(cfg.RipMethod ?? "—")</dd>
                            <dt class="col-6">Skip Transcode</dt>
                            <dd class="col-6">@cfg.SkipTranscode</dd>
                            <dt class="col-6">Main Feature Only</dt>
                            <dd class="col-6">@cfg.MainFeature</dd>
                            <dt class="col-6">Use FFmpeg</dt>
                            <dd class="col-6">@cfg.UseFfmpeg</dd>
                            <dt class="col-6">Manual Wait</dt>
                            <dd class="col-6">@cfg.ManualWait</dd>
                            <dt class="col-6">Allow Duplicates</dt>
                            <dd class="col-6">@cfg.AllowDuplicates</dd>
                            <dt class="col-6">Min Length</dt>
                            <dd class="col-6">@(cfg.MinLength?.ToString() ?? "—")s</dd>
                            <dt class="col-6">Max Length</dt>
                            <dd class="col-6">@(cfg.MaxLength?.ToString() ?? "—")s</dd>
                            <dt class="col-6">Prevent 99</dt>
                            <dd class="col-6">@cfg.Prevent99</dd>
                        </dl>
                        <h6 class="text-muted">Paths</h6>
                        <dl class="row small mb-0">
                            <dt class="col-6">Raw</dt>
                            <dd class="col-6"><code>@(cfg.RawPath ?? "—")</code></dd>
                            <dt class="col-6">Transcode</dt>
                            <dd class="col-6"><code>@(cfg.TranscodePath ?? "—")</code></dd>
                            <dt class="col-6">Completed</dt>
                            <dd class="col-6"><code>@(cfg.CompletedPath ?? "—")</code></dd>
                        </dl>
                    </div>
                    <div class="col-md-6">
                        <h6 class="text-muted">HandBrake</h6>
                        <dl class="row small mb-3">
                            <dt class="col-5">DVD Preset</dt>
                            <dd class="col-7">@(cfg.HbPresetDvd ?? "—")</dd>
                            <dt class="col-5">BD Preset</dt>
                            <dd class="col-7">@(cfg.HbPresetBd ?? "—")</dd>
                            <dt class="col-5">DVD Args</dt>
                            <dd class="col-7"><code>@(cfg.HbArgsDvd ?? "—")</code></dd>
                            <dt class="col-5">BD Args</dt>
                            <dd class="col-7"><code>@(cfg.HbArgsBd ?? "—")</code></dd>
                            <dt class="col-5">Dest Ext</dt>
                            <dd class="col-7">@(cfg.DestExt ?? "—")</dd>
                        </dl>
                        <h6 class="text-muted">FFmpeg</h6>
                        <dl class="row small mb-3">
                            <dt class="col-5">CLI</dt>
                            <dd class="col-7"><code>@(cfg.FfmpegCli ?? "—")</code></dd>
                            <dt class="col-5">Pre Args</dt>
                            <dd class="col-7"><code>@(cfg.FfmpegPreFileArgs ?? "—")</code></dd>
                            <dt class="col-5">Post Args</dt>
                            <dd class="col-7"><code>@(cfg.FfmpegPostFileArgs ?? "—")</code></dd>
                        </dl>
                        <h6 class="text-muted">Notifications</h6>
                        <dl class="row small mb-0">
                            <dt class="col-5">Notify Rip</dt>
                            <dd class="col-7">@cfg.NotifyRip</dd>
                            <dt class="col-5">Notify Transcode</dt>
                            <dd class="col-7">@cfg.NotifyTranscode</dd>
                            <dt class="col-5">Auto Eject</dt>
                            <dd class="col-7">@cfg.AutoEject</dd>
                            <dt class="col-5">Del Raw Files</dt>
                            <dd class="col-7">@cfg.DelRawFiles</dd>
                        </dl>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<h2>Tracks (@Model.Tracks.Count)</h2>
@if (!Model.Tracks.Any())
{
    <div class="alert alert-info">No tracks.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover table-sm">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Title</th>
                    <th>Length</th>
                    <th>Chapters</th>
                    <th>Size</th>
                    <th>FPS</th>
                    <th>Aspect</th>
                    <th>Source</th>
                    <th>Ripped</th>
                    <th>Main</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var track in Model.Tracks.OrderBy(t => t.TrackNumber))
                {
                    <tr class="@(track.MainFeature ? "table-primary" : "")">
                        <td>@track.TrackNumber</td>
                        <td>@(track.FileName ?? track.BaseName ?? "—")</td>
                        <td>
                            @if (track.Length is int secs)
                            {
                                @(secs >= 3600 ? $"{secs / 3600}h {(secs % 3600) / 60}m" : $"{secs / 60}m {secs % 60}s")
                            }
                            else
                            {
                                <span>—</span>
                            }
                        </td>
                        <td>@track.Chapters</td>
                        <td>
                            @(track.FileSize is long fs
                                ? fs >= 1073741824 ? $"{fs / 1073741824.0:F1} GB"
                                : fs >= 1048576 ? $"{fs / 1048576.0:F1} MB"
                                : $"{fs / 1024.0:F1} KB"
                                : "—")
                        </td>
                        <td>@(track.Fps is double fps ? $"{fps:F2}" : "—")</td>
                        <td>@(track.AspectRatio ?? "—")</td>
                        <td>@(track.Source ?? "—")</td>
                        <td>@(track.Ripped ? "Yes" : "No")</td>
                        <td>@(track.MainFeature ? "Yes" : "")</td>
                        <td>@(track.Status ?? "—")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@if (Model.Status is not JobState.Success and not JobState.Failure)
{
    @section Scripts {
    <script>
    (function () {
        var jobId = @Model.Id;
        var wasTerminal = false;
        var lastStage = '@Model.Stage';

        // Helper: find a <dd> element by its preceding <dt> text label
        function findDd(label) {
            var container = document.querySelector('[data-job-id="' + jobId + '"]');
            if (!container) return null;
            var dts = container.querySelectorAll('dt');
            for (var i = 0; i < dts.length; i++) {
                if (dts[i].innerText.trim().indexOf(label) === 0) {
                    return dts[i].nextElementSibling;
                }
            }
            return null;
        }

        // Update progress bar and its text
        function setProgress(dd, pct) {
            if (!dd) return;
            var bar = dd.querySelector('.progress-bar');
            if (!bar) return;
            var val = pct != null ? pct : 0;
            bar.style.width = val + '%';
            bar.setAttribute('aria-valuenow', val);
            bar.textContent = val + '%';
        }

        // Show/hide the spinner next to progress bars
        function setSpinner(show) {
            var container = document.querySelector('[data-job-id="' + jobId + '"]');
            if (!container) return;
            var spinners = container.querySelectorAll('.spinner-border');
            spinners.forEach(function (s) { s.style.display = show ? '' : 'none'; });
        }

        // Replace text content of a <dd>
        function setText(dd, text) {
            if (!dd || text == null) return;
            dd.textContent = text;
        }

        // Terminal status strings (lowercase from server)
        var terminalStatuses = ['success', 'fail', 'cancelled'];

        function isTerminal(status) {
            return terminalStatuses.indexOf(status) !== -1;
        }

        // Re-fetch pipeline partial from server
        function refreshPipeline() {
            fetch('/api/jobs/' + jobId + '/pipeline')
                .then(function (r) { return r.text(); })
                .then(function (html) {
                    var el = document.getElementById('pipeline-container');
                    if (el) el.innerHTML = html;
                })
                .catch(function () {});
        }

        // Main update handler
        function onJobUpdate(update) {
            if (update.JobId !== jobId) return;

            // Progress bars
            setProgress(findDd('Rip Progress'), update.MakeMkvProgress);
            setProgress(findDd('Transcode Progress'), update.TranscodeProgress);

            // Progress message
            if (update.ProgressMessage != null) {
                var dd = findDd('Progress');
                if (dd) {
                    dd.textContent = update.ProgressMessage;
                } else if (update.ProgressMessage) {
                    // Progress row doesn't exist yet, could add it but skip for now
                }
            }

            // Status
            if (update.Status != null) {
                var dd = findDd('Status');
                if (dd) {
                    if (update.Warnings) {
                        dd.innerHTML = '<span class=\"badge bg-warning text-dark\" title=\"' +
                            update.Warnings.replace(/"/g, '&quot;') + '\">Warning</span>';
                    } else {
                        dd.textContent = update.Status;
                    }
                }

                // On transition to terminal: clean up UI and schedule full reload
                if (isTerminal(update.Status) && !wasTerminal) {
                    wasTerminal = true;
                    setSpinner(false);
                    var container = document.querySelector('[data-job-id="' + jobId + '"]');
                    if (container) {
                        var forms = container.querySelectorAll('form');
                        forms.forEach(function (f) {
                            if (f.action && (f.action.indexOf('/cancel') > -1 || f.action.indexOf('/continue-wait') > -1)) {
                                f.style.display = 'none';
                            }
                        });
                    }
                    // Full reload after short delay to pick up final tracks, paths
                    setTimeout(function () { location.reload(); }, 2000);
                }
            }

            // Stage
            if (update.Stage != null && update.Stage !== lastStage) {
                lastStage = update.Stage;
                setText(findDd('Stage'), update.Stage);
                // Refresh pipeline when stage changes
                refreshPipeline();
            }

            // Stop time
            if (update.StopTime != null) {
                var dd = findDd('Stopped');
                if (dd) {
                    try {
                        var d = new Date(update.StopTime);
                        dd.textContent = d.toLocaleString();
                    } catch (e) { dd.textContent = update.StopTime; }
                }
            }

            // Duration
            if (update.JobLength != null) {
                setText(findDd('Duration'), update.JobLength);
            }

            // Warnings card
            if (update.Warnings != null) {
                var warningEl = document.getElementById('warnings-card');
                if (update.Warnings) {
                    if (!warningEl) {
                        // Create warnings card if it doesn't exist
                        var pipelineCard = document.querySelector('.card:has(#pipeline-container)');
                        if (pipelineCard) {
                            var div = document.createElement('div');
                            div.id = 'warnings-card';
                            div.className = 'card border-warning mb-4';
                            div.innerHTML = '<div class=\"card-header text-warning fw-bold\">Warnings</div>' +
                                '<div class=\"card-body\"><pre id=\"warnings-text\" class=\"mb-0 small\"></pre></div>';
                            pipelineCard.parentNode.insertBefore(div, pipelineCard);
                        }
                    }
                    var pre = document.getElementById('warnings-text');
                    if (pre) pre.textContent = update.Warnings;
                } else if (warningEl) {
                    warningEl.style.display = 'none';
                }
            }

            // Errors card
            if (update.Errors != null) {
                var errorEl = document.getElementById('errors-card');
                if (update.Errors) {
                    if (!errorEl) {
                        var pipelineCard = document.querySelector('.card:has(#pipeline-container)');
                        if (pipelineCard) {
                            var div = document.createElement('div');
                            div.id = 'errors-card';
                            div.className = 'card border-danger mb-4';
                            div.innerHTML = '<div class=\"card-header text-danger fw-bold\">Errors</div>' +
                                '<div class=\"card-body\"><pre id=\"errors-text\" class=\"mb-0 small\"></pre></div>';
                            pipelineCard.parentNode.insertBefore(div, pipelineCard);
                        }
                    }
                    var pre = document.getElementById('errors-text');
                    if (pre) pre.textContent = update.Errors;
                } else if (errorEl) {
                    errorEl.style.display = 'none';
                }
            }
        }

        // Log tail refresh
        var logInterval = null;
        function refreshLog() {
            var pre = document.getElementById('logContent');
            if (!pre) return;
            // Only fetch if the log section is visible (not collapsed)
            var collapse = document.getElementById('logCollapse');
            if (collapse && !collapse.classList.contains('show')) return;
            fetch('/jobs/log-tail?jobId=' + jobId + '&lines=40')
                .then(function (r) { return r.text(); })
                .then(function (text) {
                    if (text) pre.textContent = text;
                    pre.scrollTop = pre.scrollHeight;
                })
                .catch(function () {});
        }
        refreshLog();
        logInterval = setInterval(refreshLog, 3000);

        arm.onJobUpdate(onJobUpdate);
    })();
    </script>
    }
}
