@model ArmRipper.Core.Models.Job
@using ArmRipper.Core.Models
@{
    ViewData["Title"] = $"Job {Model.Id} - ARM";
    var meta = ViewBag.Metadata as ArmRipper.Core.Metadata.OmdbTitleResult;
    var imdbUrl = !string.IsNullOrEmpty(Model.ImdbId) ? $"https://www.imdb.com/title/{Model.ImdbId}/" : null;
}

<h1>Job @Model.Id: @Model.Title</h1>

@* === PIPELINE (moved to top) === *@
<div class="card mb-4">
    <div class="card-header">Pipeline</div>
    <div class="card-body" id="pipeline-container">
        <partial name="_Pipeline" model="Model" />
    </div>
</div>

@* === LIVE LOG === *@
<div class="card mb-4">
    <div class="card-header d-flex justify-content-between align-items-center">
        <a class="text-decoration-none" data-bs-toggle="collapse" href="#logCollapse" role="button" id="logToggle">Live Log ▾</a>
        <a href="/logs/view?file=@(Model.Id).log" class="btn btn-outline-secondary btn-sm">View Full Log</a>
    </div>
    <div class="collapse show" id="logCollapse">
        <div class="card-body p-0">
            <pre id="logContent" class="mb-0 small p-2" style="max-height:300px; overflow-y:auto; background:#1e1e1e; color:#d4d4d4; font-family:monospace; font-size:12px; line-height:1.4;">Loading...</pre>
        </div>
    </div>
</div>

@* === JOB INFO + ACTIONS === *@
<div class="row mb-4" data-job-id="@Model.Id">
    <div class="col-12">
        <div class="card">
            <div class="card-body py-3">
                <div class="row">
                    @if (Model.PosterUrl is not null)
                    {
                        <div class="col-md-2 mb-3" id="poster-container">
                            <img id="poster-image" src="@Model.PosterUrl" alt="Poster" class="img-fluid rounded shadow-sm" />
                        </div>
                    }
                    <div class="@(Model.PosterUrl is not null ? "col-md-10" : "col-12")" id="job-info-dl">
                        <dl class="row mb-0">
                            <dt class="col-sm-2">Disc Type</dt>
                            <dd class="col-sm-4">@Model.DiscType</dd>
                            <dt class="col-sm-2">Status</dt>
                            <dd class="col-sm-4">
                                @if (!string.IsNullOrEmpty(Model.Warnings))
                                {
                                    <span class="badge bg-warning text-dark" title="@Model.Warnings">⚠ @Model.Status</span>
                                }
                                else
                                {
                                    @Model.Status
                                }
                                @if (Model.Status is JobState.ManualWaitStarted)
                                {
                                    <span class="text-muted small"> (auto-continues in ~60s)</span>
                                }
                            </dd>
                            <dt class="col-sm-2">Rip Progress</dt>
                            <dd class="col-sm-4">
                                <div class="d-flex align-items-center gap-2">
                                    <div class="progress flex-grow-1" style="height:20px;">
                                        <div class="progress-bar progress-bar-striped @(Model.MakeMkvProgress is null or < 100 ? "progress-bar-animated" : "")" role="progressbar"
                                             style="width:@(Model.MakeMkvProgress ?? 0)%" aria-valuenow="@(Model.MakeMkvProgress ?? 0)" aria-valuemin="0" aria-valuemax="100">
                                            @(Model.MakeMkvProgress.HasValue ? $"{Model.MakeMkvProgress}%" : "—")
                                        </div>
                                    </div>
                                    @if (Model.Status is JobState.VideoRipping or JobState.TranscodeActive)
                                    {
                                        <span class="spinner-border spinner-border-sm text-secondary" role="status"></span>
                                    }
                                </div>
                            </dd>
                            <dt class="col-sm-2">Transcode Progress</dt>
                            <dd class="col-sm-4">
                                <div class="d-flex align-items-center gap-2">
                                    <div class="progress flex-grow-1" style="height:20px;">
                                        <div class="progress-bar progress-bar-striped @(Model.TranscodeProgress is null or < 100 ? "progress-bar-animated" : "") bg-success" role="progressbar"
                                             style="width:@(Model.TranscodeProgress ?? 0)%" aria-valuenow="@(Model.TranscodeProgress ?? 0)" aria-valuemin="0" aria-valuemax="100">
                                            @(Model.TranscodeProgress.HasValue ? $"{Model.TranscodeProgress}%" : "—")
                                        </div>
                                    </div>
                                </div>
                            </dd>
                            <dt class="col-sm-2">Stage</dt>
                            <dd class="col-sm-4">@(Model.Stage?.ToString() ?? "—")</dd>
                            <dt class="col-sm-2">Stage Started</dt>
                            <dd class="col-sm-4" id="stageStartTime">@(Model.StageStartTime?.ToLocalTime().ToString("g") ?? "—")</dd>
                            <dt class="col-sm-2">Started</dt>
                            <dd class="col-sm-4">@Model.StartTime.ToLocalTime().ToString("g")</dd>
                            <dt class="col-sm-2">Stopped</dt>
                            <dd class="col-sm-4">@Model.StopTime?.ToLocalTime().ToString("g")</dd>
                            <dt class="col-sm-2">Duration</dt>
                            <dd class="col-sm-4">@(Model.JobLength ?? "—")</dd>
                            <dt class="col-sm-2">Titles</dt>
                            <dd class="col-sm-4">@(Model.NoOfTitles?.ToString() ?? "—")</dd>
                            @if (!string.IsNullOrEmpty(Model.ProgressMessage))
                            {
                                <dt class="col-sm-2">Progress</dt>
                                <dd class="col-sm-4 text-muted small">@Model.ProgressMessage</dd>
                            }
                            @if (!Model.Status.IsTerminal())
                            {
                                <dt class="col-sm-2"></dt>
                                <dd class="col-sm-10 mt-2">
                                    @if (Model.Status is JobState.ManualWaitStarted)
                                    {
                                        <form method="post" action="/jobs/continue-wait" style="display:inline">
                                            <input type="hidden" name="jobId" value="@Model.Id" />
                                            <button type="submit" class="btn btn-success me-2">▶ Skip Wait — Start Now</button>
                                        </form>
                                    }
                                    <form method="post" action="/jobs/cancel" onsubmit="return confirm('Cancel this job?')" style="display:inline">
                                        <input type="hidden" name="jobId" value="@Model.Id" />
                                        <button type="submit" class="btn btn-outline-danger btn-sm">Cancel Job</button>
                                    </form>
                                </dd>
                            }
                            else if (Model.Status.IsResumable() && !string.IsNullOrEmpty(Model.CompletedStages))
                            {
                                <dt class="col-sm-2"></dt>
                                <dd class="col-sm-10 mt-2">
                                    <form method="post" action="/jobs/resume" style="display:inline">
                                        <input type="hidden" name="jobId" value="@Model.Id" />
                                        <button type="submit" class="btn btn-success btn-sm me-2">↻ Resume Job</button>
                                    </form>
                                    <span class="badge bg-secondary">Stopped — pick up from @Model.CompletedStages</span>
                                </dd>
                            }
                        </dl>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@* === METADATA CARD === *@
@if (meta is not null)
{
    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span>@meta.Title (@meta.Year)</span>
            <span>
                @if (meta.Ratings is not null)
                {
                    foreach (var r in meta.Ratings)
                    {
                        if (r.Source == "Internet Movie Database") continue; // we show IMDb badge below
                        var ratingUrl = r.Source switch
                        {
                            "Rotten Tomatoes" => $"https://www.rottentomatoes.com/search?search={Uri.EscapeDataString(meta.Title ?? "")}",
                            "Metacritic" => $"https://www.metacritic.com/search/{Uri.EscapeDataString(meta.Title ?? "")}",
                            _ => null
                        };
                        if (ratingUrl is not null)
                        {
                            <a href="@ratingUrl" target="_blank" class="badge bg-secondary me-1 text-decoration-none" title="@r.Source">
                                @r.Source: @r.Value
                            </a>
                        }
                        else
                        {
                            <span class="badge bg-secondary me-1" title="@r.Source">@r.Source: @r.Value</span>
                        }
                    }
                }
                @if (imdbUrl is not null)
                {
                    <a href="@imdbUrl" target="_blank" class="badge bg-warning text-dark text-decoration-none">IMDb @meta.ImdbRating</a>
                }
            </span>
        </div>
        <div class="card-body">
            <p class="mb-3">@meta.Plot</p>
            <div class="row">
                <div class="col-md-8">
                    <dl class="row small mb-0">
                        <dt class="col-sm-3">Rated</dt><dd class="col-sm-9">@meta.Rated</dd>
                        <dt class="col-sm-3">Runtime</dt><dd class="col-sm-9">@meta.Runtime</dd>
                        <dt class="col-sm-3">Genre</dt><dd class="col-sm-9">@meta.Genre</dd>
                        <dt class="col-sm-3">Director</dt><dd class="col-sm-9">@meta.Director</dd>
                        <dt class="col-sm-3">Actors</dt><dd class="col-sm-9">@meta.Actors</dd>
                    </dl>
                </div>
                <div class="col-md-4">
                    <dl class="row small mb-0">
                        <dt class="col-sm-5">Language</dt><dd class="col-sm-7">@meta.Language</dd>
                        <dt class="col-sm-5">Country</dt><dd class="col-sm-7">@meta.Country</dd>
                        <dt class="col-sm-5">Released</dt><dd class="col-sm-7">@meta.Released</dd>
                        @if (!string.IsNullOrEmpty(meta.Awards))
                        {
                            <dt class="col-sm-5">Awards</dt><dd class="col-sm-7">@meta.Awards</dd>
                        }
                    </dl>
                </div>
            </div>
        </div>
    </div>
}

@* === IDENTIFICATION + DEVICE === *@
<div class="row mb-4">
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span>Identification</span>
                <span class="d-flex gap-2">
                    @if (!Model.HasNiceTitle)
                    {
                        @if (!string.IsNullOrEmpty(Model.Title))
                        {
                            <form method="post" action="/jobs/approve-title" style="display:inline">
                                <input type="hidden" name="jobId" value="@Model.Id" />
                                <button type="submit" class="btn btn-success btn-sm">✓ Approve Title</button>
                            </form>
                        }
                        <a href="/jobs/titlesearch?jobId=@Model.Id" class="btn btn-outline-primary btn-sm">Search for Title</a>
                    }
                </span>
            </div>
            <div class="card-body">
                <form method="post" action="/jobs/update-identification" class="mb-2">
                    <input type="hidden" name="jobId" value="@Model.Id" />
                    <table class="table table-sm table-borderless mb-0">
                        <thead><tr><th>Field</th><th>Auto</th><th>Manual</th><th>Final</th></tr></thead>
                        <tbody>
                            <tr>
                                <td>Title</td><td>@(Model.TitleAuto ?? "—")</td>
                                <td><input type="text" name="title" class="form-control form-control-sm" value="@(Model.TitleManual ?? "")" /></td>
                                <td><strong>@Model.Title</strong></td>
                            </tr>
                            <tr>
                                <td>Year</td><td>@(Model.YearAuto ?? "—")</td>
                                <td><input type="text" name="year" class="form-control form-control-sm" value="@(Model.YearManual ?? "")" /></td>
                                <td><strong>@Model.Year</strong></td>
                            </tr>
                            <tr>
                                <td>Video Type</td><td>@(Model.VideoTypeAuto ?? "—")</td>
                                <td>
                                    <select name="videoType" class="form-select form-select-sm">
                                        <option value="">—</option>
                                        <option value="movie" selected="@(Model.VideoTypeManual == "movie")">movie</option>
                                        <option value="series" selected="@(Model.VideoTypeManual == "series")">series</option>
                                        <option value="episode" selected="@(Model.VideoTypeManual == "episode")">episode</option>
                                    </select>
                                </td>
                                <td><strong>@Model.VideoType</strong></td>
                            </tr>
                            <tr>
                                <td>IMDb ID</td><td>@(Model.ImdbIdAuto ?? "—")</td>
                                <td><input type="text" name="imdbId" class="form-control form-control-sm" value="@(Model.ImdbIdManual ?? "")" /></td>
                                <td><strong>@Model.ImdbId</strong></td>
                            </tr>
                            <tr>
                                <td>Poster URL</td>
                                <td class="text-truncate" style="max-width:200px" title="@Model.PosterUrlAuto">@(Model.PosterUrlAuto ?? "—")</td>
                                <td><input type="text" name="posterUrl" class="form-control form-control-sm" value="@(Model.PosterUrlManual ?? "")" /></td>
                                <td class="text-truncate" style="max-width:200px" title="@Model.PosterUrl">@(Model.PosterUrl ?? "—")</td>
                            </tr>
                        </tbody>
                    </table>
                    <button type="submit" class="btn btn-primary btn-sm">Save</button>
                </form>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header">Device</div>
            <div class="card-body">
                <dl class="row mb-0 small">
                    <dt class="col-sm-4">Device Path</dt><dd class="col-sm-8">@(Model.DevPath ?? "—")</dd>
                    <dt class="col-sm-4">Mount Point</dt><dd class="col-sm-8">@(Model.MountPoint ?? "—")</dd>
                    <dt class="col-sm-4">Label</dt><dd class="col-sm-8">@(Model.Label ?? "—")</dd>
                    <dt class="col-sm-4">Output Path</dt><dd class="col-sm-8"><code>@(Model.Path ?? "—")</code></dd>
                    <dt class="col-sm-4">CRC64</dt><dd class="col-sm-8"><code>@(Model.CrcId ?? "—")</code></dd>
                    <dt class="col-sm-4">Log File</dt>
                        <dd class="col-sm-8">
                            @if (!string.IsNullOrEmpty(Model.LogFile))
                            {
                                <a href="/logs/view?file=@Model.LogFile&mode=full" target="_blank">@Model.LogFile</a>
                            }
                            else
                            {
                                <span>—</span>
                            }
                        </dd>
                    <dt class="col-sm-4">Has Nice Title</dt><dd class="col-sm-8">@Model.HasNiceTitle</dd>
                    <dt class="col-sm-4">Is ISO</dt><dd class="col-sm-8">@Model.IsIso</dd>
                    <dt class="col-sm-4">Ejected</dt><dd class="col-sm-8">@Model.Ejected</dd>
                </dl>
            </div>
        </div>
    </div>
</div>

@* === WARNINGS / ERRORS === *@
@if (!string.IsNullOrEmpty(Model.Warnings))
{
    <div class="card border-warning mb-4" id="warnings-card">
        <div class="card-header text-warning fw-bold">Warnings</div>
        <div class="card-body"><pre id="warnings-text" class="mb-0 small">@Model.Warnings</pre></div>
    </div>
}
@if (!string.IsNullOrEmpty(Model.Errors))
{
    <div class="card border-danger mb-4" id="errors-card">
        <div class="card-header text-danger fw-bold">Errors</div>
        <div class="card-body"><pre id="errors-text" class="mb-0 small">@Model.Errors</pre></div>
    </div>
}

@* === CONFIG SNAPSHOT === *@
<div class="card mb-4">
    <div class="card-header">
        <a class="text-decoration-none" data-bs-toggle="collapse" href="#configCollapse" role="button">Config Snapshot</a>
    </div>
    <div class="collapse" id="configCollapse">
        <div class="card-body">
            @if (Model.Config is null)
            {
                <div class="text-muted">No config snapshot.</div>
            }
            else
            {
                var cfg = Model.Config;
                <div class="row">
                    <div class="col-md-6">
                        <h6 class="text-muted">Rip Settings</h6>
                        <dl class="row small mb-3">
                            <dt class="col-6">Rip Method</dt><dd class="col-6">@(cfg.RipMethod ?? "—")</dd>
                            <dt class="col-6">Skip Transcode</dt><dd class="col-6">@cfg.SkipTranscode</dd>
                            <dt class="col-6">Main Feature Only</dt><dd class="col-6">@cfg.MainFeature</dd>
                            <dt class="col-6">Use FFmpeg</dt><dd class="col-6">@cfg.UseFfmpeg</dd>
                            <dt class="col-6">Manual Wait</dt><dd class="col-6">@cfg.ManualWait</dd>
                            <dt class="col-6">Allow Duplicates</dt><dd class="col-6">@cfg.AllowDuplicates</dd>
                            <dt class="col-6">Min Length</dt><dd class="col-6">@(cfg.MinLength?.ToString() ?? "—")s</dd>
                            <dt class="col-6">Max Length</dt><dd class="col-6">@(cfg.MaxLength?.ToString() ?? "—")s</dd>
                            <dt class="col-6">Prevent 99</dt><dd class="col-6">@cfg.Prevent99</dd>
                        </dl>
                        <h6 class="text-muted">Paths</h6>
                        <dl class="row small mb-0">
                            <dt class="col-6">Raw</dt><dd class="col-6"><code>@(cfg.RawPath ?? "—")</code></dd>
                            <dt class="col-6">Transcode</dt><dd class="col-6"><code>@(cfg.TranscodePath ?? "—")</code></dd>
                            <dt class="col-6">Completed</dt><dd class="col-6"><code>@(cfg.CompletedPath ?? "—")</code></dd>
                        </dl>
                    </div>
                    <div class="col-md-6">
                        <h6 class="text-muted">HandBrake</h6>
                        <dl class="row small mb-3">
                            <dt class="col-5">DVD Preset</dt><dd class="col-7">@(cfg.HbPresetDvd ?? "—")</dd>
                            <dt class="col-5">BD Preset</dt><dd class="col-7">@(cfg.HbPresetBd ?? "—")</dd>
                            <dt class="col-5">DVD Args</dt><dd class="col-7"><code>@(cfg.HbArgsDvd ?? "—")</code></dd>
                            <dt class="col-5">BD Args</dt><dd class="col-7"><code>@(cfg.HbArgsBd ?? "—")</code></dd>
                            <dt class="col-5">Dest Ext</dt><dd class="col-7">@(cfg.DestExt ?? "—")</dd>
                        </dl>
                        <h6 class="text-muted">FFmpeg</h6>
                        <dl class="row small mb-3">
                            <dt class="col-5">CLI</dt><dd class="col-7"><code>@(cfg.FfmpegCli ?? "—")</code></dd>
                            <dt class="col-5">Pre Args</dt><dd class="col-7"><code>@(cfg.FfmpegPreFileArgs ?? "—")</code></dd>
                            <dt class="col-5">Post Args</dt><dd class="col-7"><code>@(cfg.FfmpegPostFileArgs ?? "—")</code></dd>
                        </dl>
                        <h6 class="text-muted">Notifications</h6>
                        <dl class="row small mb-0">
                            <dt class="col-5">Notify Rip</dt><dd class="col-7">@cfg.NotifyRip</dd>
                            <dt class="col-5">Notify Transcode</dt><dd class="col-7">@cfg.NotifyTranscode</dd>
                            <dt class="col-5">Auto Eject</dt><dd class="col-7">@cfg.AutoEject</dd>
                            <dt class="col-5">Del Raw Files</dt><dd class="col-7">@cfg.DelRawFiles</dd>
                        </dl>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@* === TRACKS === *@
<h2>Tracks (@Model.Tracks.Count)</h2>
@if (!Model.Tracks.Any())
{
    <div class="alert alert-info">No tracks yet — they will appear after MakeMKV scan.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover table-sm">
            <thead><tr><th>#</th><th>Title</th><th>Length</th><th>Chapters</th><th>Size</th><th>FPS</th><th>Aspect</th><th>Source</th><th>Type</th><th>Ripped</th><th>Main</th><th>Status</th></tr></thead>
            <tbody>
                @foreach (var track in Model.Tracks.OrderBy(t => t.TrackNumber))
                {
                    <tr class="@(track.MainFeature ? "table-primary" : "")">
                        <td>@track.TrackNumber</td>
                        <td>
                            @if (!string.IsNullOrEmpty(track.EpisodeTitle))
                            {
                                <strong>@track.EpisodeTitle</strong>
                                <br /><small class="text-muted">@track.FileName</small>
                            }
                            else
                            {
                                @(track.FileName ?? track.BaseName ?? "—")
                            }
                        </td>
                        <td>@(track.Length is int secs ? (secs >= 3600 ? $"{secs / 3600}h {(secs % 3600) / 60}m" : $"{secs / 60}m {secs % 60}s") : "—")</td>
                        <td>@track.Chapters</td>
                        <td>@(track.FileSize is long fs ? (fs >= 1073741824 ? $"{fs / 1073741824.0:F1} GB" : fs >= 1048576 ? $"{fs / 1048576.0:F1} MB" : $"{fs / 1024.0:F1} KB") : "—")</td>
                        <td>@(track.Fps is double fps ? $"{fps:F2}" : "—")</td>
                        <td>@(track.AspectRatio ?? "—")</td>
                        <td>@(track.Source ?? "—")</td>
                        <td>
                            @if (!string.IsNullOrEmpty(track.ContentType))
                            {
                                var badgeClass = track.ContentType switch
                                {
                                    "main" => "bg-success",
                                    "extra" or "deleted_scene" or "trailer" or "featurette" or "behind_the_scenes" => track.Process ? "bg-primary" : "bg-info text-white",
                                    _ => "bg-secondary"
                                };
                                <span class="badge @badgeClass">@track.ContentType</span>
                            }
                            else if (track.Process && !track.MainFeature)
                            {
                                <span class="badge bg-primary">rip</span>
                            }
                            else if (track.Process && track.MainFeature)
                            {
                                <span class="badge bg-success">main</span>
                            }
                            else
                            {
                                <span class="badge bg-danger bg-opacity-25 text-danger">—</span>
                            }
                        </td>
                        <td>@(track.Ripped ? "Yes" : "No")</td>
                        <td>@(track.MainFeature ? "Yes" : "")</td>
                        <td>@(track.Status ?? "—")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@if (!Model.Status.IsTerminal())
{
    @section Scripts {
    <script>
    (function () {
        var jobId = @Model.Id;
        var wasTerminal = false;
        var lastStage = '@(Model.Stage?.ToString())';

        function findDd(label) {
            var container = document.querySelector('[data-job-id="' + jobId + '"]');
            if (!container) return null;
            var dts = container.querySelectorAll('dt');
            for (var i = 0; i < dts.length; i++) {
                if (dts[i].innerText.trim().indexOf(label) === 0) return dts[i].nextElementSibling;
            }
            return null;
        }

        function setProgress(dd, pct) {
            if (!dd) return;
            var bar = dd.querySelector('.progress-bar');
            if (!bar) return;
            var val = pct != null ? pct : 0;
            bar.style.width = val + '%';
            bar.setAttribute('aria-valuenow', val);
            bar.textContent = (pct != null ? pct + '%' : '\u2014');
            if (pct != null && pct >= 100) {
                bar.classList.remove('progress-bar-animated');
            } else if (pct != null && pct < 100) {
                bar.classList.add('progress-bar-animated');
            }
        }

        function setSpinner(show) {
            var container = document.querySelector('[data-job-id="' + jobId + '"]');
            if (!container) return;
            var spinners = container.querySelectorAll('.spinner-border');
            spinners.forEach(function (s) { s.style.display = show ? '' : 'none'; });
        }

        function updatePoster(posterUrl) {
            var container = document.getElementById('poster-container');
            var img = document.getElementById('poster-image');
            var infoDl = document.getElementById('job-info-dl');
            if (!infoDl) return;

            if (posterUrl) {
                if (!container) {
                    // Create poster container and image from scratch
                    container = document.createElement('div');
                    container.id = 'poster-container';
                    container.className = 'col-md-2 mb-3';
                    img = document.createElement('img');
                    img.id = 'poster-image';
                    img.className = 'img-fluid rounded shadow-sm';
                    img.alt = 'Poster';
                    container.appendChild(img);
                    // Insert before the info dl
                    infoDl.parentNode.insertBefore(container, infoDl);
                }
                if (img && img.src !== posterUrl) {
                    img.src = posterUrl;
                }
                infoDl.className = 'col-md-10';
            } else {
                if (container) {
                    container.parentNode.removeChild(container);
                }
                infoDl.className = 'col-12';
            }
        }

        function setText(dd, text) {
            if (!dd || text == null) return;
            dd.textContent = text;
        }

        var terminalStatuses = ['success', 'fail', 'cancelled'];
        function isTerminal(status) { return terminalStatuses.indexOf(status) !== -1; }

        var _pipelineDebounce = null;
        function refreshPipeline() {
            if (_pipelineDebounce) clearTimeout(_pipelineDebounce);
            _pipelineDebounce = setTimeout(function () {
                fetch('/api/jobs/' + jobId + '/pipeline')
                    .then(function (r) { return r.text(); })
                    .then(function (html) {
                        var el = document.getElementById('pipeline-container');
                        if (el) el.innerHTML = html;
                    })
                    .catch(function () {});
            }, 1000);
        }

        function updateActionButtons(status) {
            var dd = findDd('');  // last dd in the dl is the actions row
            // Find the actions dd by looking for the form elements
            var container = document.querySelector('[data-job-id="' + jobId + '"]');
            if (!container) return;
            var forms = container.querySelectorAll('form');
            var actionsDd = null;
            forms.forEach(function (f) {
                if (f.action && (f.action.indexOf('/cancel') > -1 || f.action.indexOf('/continue-wait') > -1)) {
                    actionsDd = f.parentElement;
                }
            });
            if (!actionsDd) return;

            var isManualWait = status === 'waiting'; // ManualWaitStarted
            var isTerminal_ = terminalStatuses.indexOf(status) !== -1;

            if (isTerminal_) {
                actionsDd.innerHTML = '';
                return;
            }

            if (isManualWait) {
                actionsDd.innerHTML =
                    '<form method="post" action="/jobs/continue-wait" style="display:inline">' +
                    '<input type="hidden" name="jobId" value="' + jobId + '" />' +
                    '<button type="submit" class="btn btn-success me-2">\u25B6 Skip Wait \u2014 Start Now</button>' +
                    '</form>' +
                    '<form method="post" action="/jobs/cancel" onsubmit="return confirm(\'Cancel this job?\')" style="display:inline">' +
                    '<input type="hidden" name="jobId" value="' + jobId + '" />' +
                    '<button type="submit" class="btn btn-outline-danger btn-sm">Cancel Job</button>' +
                    '</form>';
            } else {
                actionsDd.innerHTML =
                    '<form method="post" action="/jobs/cancel" onsubmit="return confirm(\'Cancel this job?\')" style="display:inline">' +
                    '<input type="hidden" name="jobId" value="' + jobId + '" />' +
                    '<button type="submit" class="btn btn-outline-danger btn-sm">Cancel Job</button>' +
                    '</form>';
            }
        }

        function onJobUpdate(update) {
            if (update.jobId !== jobId) return;

            setProgress(findDd('Rip Progress'), update.makeMkvProgress);
            setProgress(findDd('Transcode Progress'), update.transcodeProgress);

            // Update poster image when identification completes
            if (update.posterUrl !== undefined) {
                updatePoster(update.posterUrl);
            }

            // Update title when identification completes
            if (update.title != null) {
                var h1 = document.querySelector('h1');
                if (h1) h1.textContent = 'Job ' + jobId + ': ' + update.title;
            }

            // Update year when identification completes
            if (update.year !== undefined && update.year != null) {
                setText(findDd('Year'), update.year);
            }

            // Update disc type when identification completes
            if (update.discType != null) {
                setText(findDd('Disc Type'), update.discType);
            }

            // Update title count when ripping starts
            if (update.titleCount != null) {
                setText(findDd('Titles'), String(update.titleCount));
            }

            // Refresh pipeline when progress or stage changes
            if (update.makeMkvProgress != null || update.transcodeProgress != null || (update.stage != null && update.stage !== lastStage)) {
                if (update.stage != null && update.stage !== lastStage) lastStage = update.stage;
                refreshPipeline();
            }

            if (update.progressMessage != null) {
                var dd = findDd('Progress');
                if (dd) dd.textContent = update.progressMessage;
            }

            if (update.status != null) {
                var dd = findDd('Status');
                if (dd) {
                    if (update.warnings) {
                        dd.innerHTML = '<span class="badge bg-warning text-dark" title="' + update.warnings.replace(/"/g, '&quot;') + '">\u26A0 ' + update.status + '</span>';
                    } else {
                        dd.textContent = update.status;
                    }
                }

                // Update action buttons when status changes
                updateActionButtons(update.status);

                if (isTerminal(update.status) && !wasTerminal) {
                    wasTerminal = true;
                    setSpinner(false);
                    setTimeout(function () { location.reload(); }, 2000);
                }
            }

            if (update.stage != null && update.stage !== lastStage) {
                setText(findDd('Stage'), update.stage);
            }

            if (update.stageStartTime != null) {
                var stdd = document.getElementById('stageStartTime');
                if (stdd) {
                    try { var d = new Date(update.stageStartTime); stdd.textContent = d.toLocaleString(); } catch (e) { stdd.textContent = update.stageStartTime; }
                }
            }

            if (update.stopTime != null) {
                var dd = findDd('Stopped');
                if (dd) {
                    try { var d = new Date(update.stopTime); dd.textContent = d.toLocaleString(); } catch (e) { dd.textContent = update.stopTime; }
                }
            }

            if (update.jobLength != null) setText(findDd('Duration'), update.jobLength);

            if (update.warnings != null) {
                var wEl = document.getElementById('warnings-card');
                if (update.warnings) {
                    if (!wEl) {
                        var pipelineCard = document.querySelector('.card:has(#pipeline-container)');
                        if (pipelineCard) {
                            var div = document.createElement('div');
                            div.id = 'warnings-card';
                            div.className = 'card border-warning mb-4';
                            div.innerHTML = '<div class="card-header text-warning fw-bold">Warnings</div><div class="card-body"><pre id="warnings-text" class="mb-0 small"></pre></div>';
                            pipelineCard.parentNode.insertBefore(div, pipelineCard);
                        }
                    }
                    var pre = document.getElementById('warnings-text');
                    if (pre) pre.textContent = update.warnings;
                } else if (wEl) wEl.style.display = 'none';
            }

            if (update.errors != null) {
                var eEl = document.getElementById('errors-card');
                if (update.errors) {
                    if (!eEl) {
                        var pipelineCard = document.querySelector('.card:has(#pipeline-container)');
                        if (pipelineCard) {
                            var div = document.createElement('div');
                            div.id = 'errors-card';
                            div.className = 'card border-danger mb-4';
                            div.innerHTML = '<div class="card-header text-danger fw-bold">Errors</div><div class="card-body"><pre id="errors-text" class="mb-0 small"></pre></div>';
                            pipelineCard.parentNode.insertBefore(div, pipelineCard);
                        }
                    }
                    var pre = document.getElementById('errors-text');
                    if (pre) pre.textContent = update.errors;
                } else if (eEl) eEl.style.display = 'none';
            }
        }

        // Log tail refresh
        var logInterval = null;
        function refreshLog() {
            var pre = document.getElementById('logContent');
            if (!pre) return;
            var collapse = document.getElementById('logCollapse');
            if (collapse && !collapse.classList.contains('show')) return;
            fetch('/jobs/log-tail?jobId=' + jobId + '&lines=40')
                .then(function (r) { return r.text(); })
                .then(function (text) {
                    if (text) pre.textContent = text;
                    pre.scrollTop = pre.scrollHeight;
                })
                .catch(function () {});
        }
        refreshLog();
        logInterval = setInterval(refreshLog, 3000);

        arm.onJobUpdate(onJobUpdate);
    })();
    </script>
    }
}
