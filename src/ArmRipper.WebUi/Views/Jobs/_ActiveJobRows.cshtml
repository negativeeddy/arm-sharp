@model IEnumerable<ArmRipper.Core.Models.Job>
@if (!Model.Any())
{
    <tr><td colspan="7" class="text-center text-muted">No active rips.</td></tr>
}
else
{
    @foreach (var job in Model)
    {
        <tr>
            <td rowspan="2" class="align-middle text-center" style="width:110px;">
                @if (!string.IsNullOrEmpty(job.PosterUrl))
                {
                    <a href="/jobs/jobdetail?jobId=@job.Id" class="d-inline-block">
                        <img src="@job.PosterUrl" alt="Poster" class="img-fluid rounded shadow-sm" style="max-height:140px;object-fit:contain;" />
                    </a>
                }
            </td>
            <td>@job.Id</td>
            <td>@job.Title</td>
            <td>@job.DiscType</td>
            <td>
                @if (!string.IsNullOrEmpty(job.Warnings))
                {
                    <span class="badge bg-warning text-dark" title="@job.Warnings">Warning</span>
                }
                else
                {
                    @job.Status
                }
            </td>
            <td>@job.StartTime.ToLocalTime().ToString("g")</td>
            <td><a href="/jobs/jobdetail?jobId=@job.Id" class="btn btn-sm btn-outline-primary">View</a></td>
        </tr>
        <tr class="pipeline-row">
            <td colspan="6" class="p-2 bg-light">
                <partial name="_Pipeline" model="job" />
            </td>
        </tr>
    }
}
