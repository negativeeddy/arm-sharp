@model IEnumerable<ArmRipper.Core.Models.Job>
@{
    ViewData["Title"] = "Title Search - ARM";
}

<h1>Title Search</h1>

<form method="get" action="/jobs/titlesearch" class="mb-3">
    <div class="input-group">
        <input type="text" name="query" class="form-control" placeholder="Search by title..." value="@Context.Request.Query["query"]" />
        <button type="submit" class="btn btn-primary">Search</button>
    </div>
</form>

@if (!Model.Any())
{
    <div class="alert alert-info">No results.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover table-sm">
            <thead>
                <tr>
                    <th style="width:60px"></th>
                    <th>ID</th>
                    <th>Title</th>
                    <th>Year</th>
                    <th>Type</th>
                    <th>Disc</th>
                    <th>Status</th>
                    <th>Started</th>
                    <th style="width:180px">Custom Title</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var job in Model)
                {
                    <tr>
                        <td>
                            @if (!string.IsNullOrEmpty(job.PosterUrl))
                            {
                                <img src="@job.PosterUrl" alt="" class="img-thumbnail" style="width:50px;height:75px;object-fit:cover" />
                            }
                        </td>
                        <td>@job.Id</td>
                        <td>@job.Title</td>
                        <td>@(job.Year ?? "—")</td>
                        <td>@(job.VideoType ?? "—")</td>
                        <td>@job.DiscType</td>
                        <td>@job.Status</td>
                        <td>@job.StartTime.ToString("g")</td>
                        <td>
                            <form method="post" action="/jobs/set-title" class="input-group input-group-sm">
                                <input type="hidden" name="jobId" value="@job.Id" />
                                <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                                <input type="text" name="title" class="form-control form-control-sm" value="@(job.TitleManual ?? job.Title)" placeholder="Custom title" />
                                <button type="submit" class="btn btn-outline-secondary btn-sm" title="Save custom title">Save</button>
                            </form>
                        </td>
                        <td>
                            <div class="btn-group btn-group-sm">
                                <a href="/jobs/jobdetail?jobId=@job.Id" class="btn btn-outline-primary">View</a>
                                <button type="button" class="btn btn-outline-secondary" data-bs-toggle="modal" data-bs-target="#paramsModal"
                                        data-job-id="@job.Id"
                                        data-disc-type="@job.DiscType"
                                        data-min-length="@(job.Config?.MinLength)"
                                        data-max-length="@(job.Config?.MaxLength)"
                                        data-rip-method="@(job.Config?.RipMethod)"
                                        data-main-feature="@(job.Config?.MainFeature)">
                                    Params
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<div class="modal fade" id="paramsModal" tabindex="-1">
    <div class="modal-dialog">
        <form class="modal-content" method="post" action="/api/change-params" id="paramsForm">
            <div class="modal-header">
                <h5 class="modal-title">Change Parameters</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" name="jobId" id="paramJobId" />
                <div class="mb-3">
                    <label class="form-label" for="paramDiscType">Disc Type</label>
                    <select name="disctype" id="paramDiscType" class="form-select">
                        <option value="">—</option>
                        <option value="Dvd">DVD</option>
                        <option value="Bluray">Blu-ray</option>
                        <option value="Music">Music</option>
                        <option value="Data">Data</option>
                    </select>
                </div>
                <div class="row mb-3">
                    <div class="col">
                        <label class="form-label" for="paramMinLength">Min Length (s)</label>
                        <input type="number" name="minLength" id="paramMinLength" class="form-control" />
                    </div>
                    <div class="col">
                        <label class="form-label" for="paramMaxLength">Max Length (s)</label>
                        <input type="number" name="maxLength" id="paramMaxLength" class="form-control" />
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label" for="paramRipMethod">Rip Method</label>
                    <select name="ripMethod" id="paramRipMethod" class="form-select">
                        <option value="">—</option>
                        <option value="makemkv">MakeMKV</option>
                        <option value="handbrake">HandBrake</option>
                        <option value="ffmpeg">FFmpeg</option>
                    </select>
                </div>
                <div class="form-check">
                    <input type="checkbox" name="mainFeature" id="paramMainFeature" class="form-check-input" value="true" />
                    <label class="form-check-label" for="paramMainFeature">Main Feature Only</label>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="submit" class="btn btn-primary">Save Changes</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        var paramsModal = document.getElementById('paramsModal');
        if (paramsModal) {
            paramsModal.addEventListener('show.bs.modal', function (event) {
                var btn = event.relatedTarget;
                document.getElementById('paramJobId').value = btn.getAttribute('data-job-id');
                document.getElementById('paramMinLength').value = btn.getAttribute('data-min-length') || '';
                document.getElementById('paramMaxLength').value = btn.getAttribute('data-max-length') || '';
                document.getElementById('paramRipMethod').value = btn.getAttribute('data-rip-method') || '';
                document.getElementById('paramMainFeature').checked = btn.getAttribute('data-main-feature') === 'True';

                var discType = btn.getAttribute('data-disc-type');
                var sel = document.getElementById('paramDiscType');
                for (var i = 0; i < sel.options.length; i++) {
                    if (sel.options[i].value.toLowerCase() === (discType || '').toLowerCase()) {
                        sel.selectedIndex = i;
                        break;
                    }
                }
            });
        }

        document.getElementById('paramsForm')?.addEventListener('submit', function (e) {
            e.preventDefault();
            var form = e.target;
            var data = new FormData(form);
            fetch(form.action, { method: 'POST', body: data })
                .then(function (r) { return r.json(); })
                .then(function (result) {
                    if (result.success) {
                        location.reload();
                    } else {
                        alert('Error: ' + (result.error || 'Unknown'));
                    }
                })
                .catch(function () { alert('Request failed'); });
        });
    </script>
}
