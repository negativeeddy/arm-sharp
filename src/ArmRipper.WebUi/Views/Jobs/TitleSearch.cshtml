@model IEnumerable<ArmRipper.Core.Metadata.OmdbSearchItem>
@{
    ViewData["Title"] = "Search Movies - ARM";
    var jobs = ViewBag.Jobs as IEnumerable<ArmRipper.Core.Models.Job>;
    var selectedJobId = ViewBag.SelectedJobId as int?;
    var query = Context.Request.Query["query"];
    bool Selected(int jobId) => selectedJobId.HasValue && selectedJobId.Value == jobId;
    var jobIdValue = selectedJobId.GetValueOrDefault();
    var importFilePath = ViewBag.ImportFilePath as string;
    var isImportMode = !string.IsNullOrEmpty(importFilePath);
}

<h1>Search Movies</h1>

<div class="card mb-4">
    <div class="card-body">
        <form method="get" action="/jobs/titlesearch" class="form-inline">
            <div class="form-group mr-2">
                <label class="mr-2 font-weight-bold" for="titleInput">Title</label>
                <input type="text" id="titleInput" name="query" class="form-control" value="@query" placeholder="Movie title..." required style="min-width:250px" />
            </div>
            <div class="form-group mr-2">
                <label class="mr-2 font-weight-bold" for="jobSelect">Job</label>
                <select name="jobId" id="jobSelect" class="form-control">
                    <option value="">— Select job —</option>
                    @if (jobs is not null)
                    {
                        foreach (var job in jobs)
                        {
                            <option value="@job.Id" selected="@(Selected(job.Id) ? "selected" : null)">
                                #@job.Id — @(job.Title ?? job.Label ?? "Untitled")
                            </option>
                        }
                    }
                </select>
            </div>
            <button type="submit" class="btn btn-primary">Search</button>
            @if (!string.IsNullOrEmpty(query))
            {
                <a href="/jobs/titlesearch@(selectedJobId.HasValue ? "?jobId=" + selectedJobId.Value : "")" class="btn btn-outline-secondary ml-2">Clear</a>
            }
        </form>
    </div>
</div>

@if (isImportMode)
{
    <div class="alert alert-info">
        <strong>Import Mode:</strong> Select a movie below to create a new transcode job for
        <code>@System.IO.Path.GetFileName(importFilePath)</code>.
        The rip stage will be skipped — only transcoding will be performed.
    </div>
}

@if (string.IsNullOrEmpty(query))
{
    <div class="alert alert-info">Enter a movie title above to search online databases (OMDB/TMDB).</div>
}
else if (!Model.Any())
{
    <div class="alert alert-warning">No results found for &quot;@query&quot;. Try a different title or check your API keys in Settings.</div>
}
else
{
    <h5 class="mb-3">Results for &quot;@query&quot;</h5>
    <div class="row">
        @foreach (var item in Model)
        {
            var poster = !string.IsNullOrEmpty(item.Poster) && item.Poster != "N/A" ? item.Poster : "/img/none.png";
            var hasJob = jobIdValue > 0;

            <div class="col-md-3 col-sm-4 col-6 mb-4">
                <div class="card text-center h-100">
                    <a href="@(hasJob ? "/jobs/select-title?imdbId=" + item.ImdbID + "&jobId=" + jobIdValue : "#")" title="View details">
                        <img src="@poster" class="card-img-top img-thumbnail" alt="@item.Title poster"
                             style="height:260px;object-fit:cover" onerror="this.src='/img/none.png'" />
                    </a>
                    <div class="card-body d-flex flex-column">
                        <h6 class="card-title mb-1">@item.Title</h6>
                        <p class="card-text small text-muted mb-2">
                            @(item.Type ?? "movie") (@item.Year)
                        </p>
                        @if (isImportMode)
                        {
                            <form method="post" action="/jobs/import-from-search" class="mt-auto">
                                <input type="hidden" name="filePath" value="@importFilePath" />
                                <input type="hidden" name="title" value="@item.Title" />
                                <input type="hidden" name="year" value="@item.Year" />
                                <input type="hidden" name="videoType" value="@item.Type" />
                                <button type="submit" class="btn btn-primary btn-sm btn-block">Import &amp; Transcode</button>
                            </form>
                        }
                        else if (hasJob)
                        {
                            <form method="post" action="/jobs/assign-movie" class="mt-auto">
                                <input type="hidden" name="jobId" value="@jobIdValue" />
                                <input type="hidden" name="title" value="@item.Title" />
                                <input type="hidden" name="year" value="@item.Year" />
                                <input type="hidden" name="imdbId" value="@item.ImdbID" />
                                <input type="hidden" name="posterUrl" value="@item.Poster" />
                                <input type="hidden" name="videoType" value="@item.Type" />
                                <button type="submit" class="btn btn-success btn-sm btn-block">Update Title</button>
                            </form>
                        }
                        else
                        {
                            <span class="text-muted small mt-auto">Select a job above</span>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}
