@model ArmRipper.Core.Models.Job
@using ArmRipper.Core.Models

@{
    var hasWarning = !string.IsNullOrEmpty(Model.Warnings);

    var stageErrors = new Dictionary<string, string>();
    if (!string.IsNullOrEmpty(Model.StageErrors))
    {
        foreach (var entry in Model.StageErrors.Split(';', StringSplitOptions.RemoveEmptyEntries))
        {
            var colon = entry.IndexOf(':');
            if (colon > 0)
                stageErrors[entry[..colon]] = entry[(colon + 1)..];
        }
    }

    string? StageError(string name) => stageErrors.TryGetValue(name, out var msg) ? msg : null;

    // Determine pipeline stages based on disc type
    // Default to video pipeline for Unknown (most common; identify will determine actual type)
    var isVideo = Model.DiscType is DiscType.Dvd or DiscType.Bluray or DiscType.Unknown;
    var isMusic = Model.DiscType is DiscType.Music;
    var isData = Model.DiscType is DiscType.Data;

    var pipelineStages = new List<(string name, string label, bool isActive, bool isDone, bool isWarning)>();

    // Setup — active initially, done when any work has started
    pipelineStages.Add(("setup", "Setup",
        Model.Status == JobState.Active && Model.Stage == null,
        Model.Stage is not null && Model.Stage != RipStage.Setup && !Model.Status.IsTerminal()
            || Model.Status is JobState.Success,
        StageError("setup") is not null));

    // Identify — active during identify, done when moved past it
    pipelineStages.Add(("identify", "Identify",
        Model.Stage == RipStage.Identify && !Model.Status.IsTerminal(),
        Model.Stage is not null && Model.Stage != RipStage.Identify && Model.Stage != RipStage.Setup
            || Model.Status.IsTerminal(),
        StageError("identify") is not null || hasWarning));

    // Rip — varies by disc type
    if (isVideo)
    {
        pipelineStages.Add(("rip", "Rip",
            Model.Status is JobState.VideoRipping,
            Model.Status is JobState.TranscodeActive or JobState.Success or JobState.Failure,
            StageError("rip") is not null));
    }
    else if (isMusic)
    {
        pipelineStages.Add(("rip", "Rip",
            Model.Status is JobState.AudioRipping,
            Model.Status is JobState.Success or JobState.Failure,
            StageError("rip") is not null));
    }
    else // Data or Unknown
    {
        pipelineStages.Add(("rip", "Rip",
            Model.Stage == RipStage.Rip && !Model.Status.IsTerminal(),
            Model.Status.IsTerminal(),
            StageError("rip") is not null));
    }

    // Transcode — only for video discs
    if (isVideo)
    {
        pipelineStages.Add(("transcode", "Transcode",
            Model.Status is JobState.TranscodeActive,
            Model.Status is JobState.Success or JobState.Failure,
            StageError("transcode") is not null));
    }

    // Done
    pipelineStages.Add(("done", "Done",
        false,
        Model.Status.IsTerminal(),
        false));

    var stageOrder = pipelineStages.Select(s => s.name).ToArray();

    string? FailedStage()
    {
        if (Model.Status != JobState.Failure || Model.Stage is null) return null;
        var s = Model.Stage.Value;
        if (s == RipStage.Rip) return "rip";
        if (s == RipStage.Transcode) return "transcode";
        return s.ToString().ToLowerInvariant();
    }
    var failed = FailedStage();
    var failedIdx = failed is null ? -1 : Array.IndexOf(stageOrder, failed);

    string StageClass(bool isFailed, bool isDone, bool isActive, bool isWarning) =>
        isFailed ? "bg-danger text-white"
        : isWarning && isDone ? "bg-warning text-dark"
        : isDone ? "bg-success text-white"
        : isActive ? "bg-primary text-white"
        : "bg-light text-muted";
}

<div class="d-flex justify-content-between align-items-center">
    @for (var i = 0; i < pipelineStages.Count; i++)
    {
        var (name, label, active, done, warning) = pipelineStages[i];
        var thisIdx = i;
        var inFailure = failed is not null;
        var isDone = inFailure ? thisIdx < failedIdx : done;
        var isFailed = name == failed;
        var isActive = inFailure ? false : active;
        var isWarning = warning && isDone && !inFailure;
        var cls = StageClass(isFailed, isDone, isActive, isWarning);
        var stageErr = StageError(name);
        var tip = isFailed ? $"Failed at {label}" : stageErr is not null ? $"{label}: {stageErr}" : isWarning ? Model.Warnings : label;
        <div class="text-center flex-fill mx-1" style="min-width:0;">
            <div class="rounded py-1 px-1 small @cls text-nowrap" title="@tip">@label</div>
        </div>
        @if (i < pipelineStages.Count - 1)
        {
            <div class="text-muted flex-shrink-0" style="width:12px;text-align:center;">&rarr;</div>
        }
    }
</div>
@{
    // Show progress bar whenever there's useful info: rip %, transcode %, or a progress message
    var activeProgress = Model.Status switch
    {
        JobState.VideoRipping => Model.MakeMkvProgress,
        JobState.TranscodeActive => Model.TranscodeProgress,
        _ => (int?)null
    };
    var hasMessage = !string.IsNullOrEmpty(Model.ProgressMessage);
    var showProgress = activeProgress.HasValue
        || Model.Status is JobState.VideoRipping or JobState.TranscodeActive
        || hasMessage;
}
@if (showProgress)
{
    var pct = activeProgress ?? 0;
    var isIndeterminate = activeProgress is null && hasMessage;
    var label = hasMessage
        ? (activeProgress.HasValue ? Model.ProgressMessage + " — " + pct + "%" : Model.ProgressMessage)
        : pct + "%";
    <div class="progress mt-2" style="height:22px;">
        <div class="progress-bar @(isIndeterminate
            ? "progress-bar-striped progress-bar-animated bg-info"
            : pct >= 100
                ? "bg-success"
                : "progress-bar-striped progress-bar-animated")" role="progressbar"
             style="width:@(isIndeterminate ? "100" : pct)%" aria-valuenow="@pct" aria-valuemin="0" aria-valuemax="100">
            @label
        </div>
    </div>
}
