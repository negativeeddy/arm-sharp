@model ArmRipper.Core.Models.Job

@{
    var hasRipProgress = Model.MakeMkvProgress.HasValue;
    var hasTranscodeProgress = Model.TranscodeProgress.HasValue;
    var hasWarning = !string.IsNullOrEmpty(Model.Warnings);

    var stageErrors = new Dictionary<string, string>();
    if (!string.IsNullOrEmpty(Model.StageErrors))
    {
        foreach (var entry in Model.StageErrors.Split(';', StringSplitOptions.RemoveEmptyEntries))
        {
            var colon = entry.IndexOf(':');
            if (colon > 0)
                stageErrors[entry[..colon]] = entry[(colon + 1)..];
        }
    }

    string? StageError(string name) => stageErrors.TryGetValue(name, out var msg) ? msg : null;

    var pipelineStages = new[]
    {
        ("setup", "Setup", true, Model.Status != JobState.Active, StageError("setup") is not null),
        ("identify", "Identify", Model.Status is JobState.Active or JobState.VideoInfo, Model.Status is not JobState.Active and not JobState.VideoInfo, StageError("identify") is not null || hasWarning),
        ("rip", "Rip", Model.Status is JobState.VideoRipping, Model.Status is JobState.TranscodeActive or JobState.Success or JobState.Failure, StageError("rip") is not null),
        ("transcode", "Transcode", Model.Status is JobState.TranscodeActive, Model.Status is JobState.Success or JobState.Failure, StageError("transcode") is not null),
        ("done", "Done", false, Model.Status is JobState.Success or JobState.Failure, false),
    };

    string? FailedStage()
    {
        if (Model.Status != JobState.Failure || Model.Stage is null) return null;
        var s = Model.Stage;
        if (s.Contains("Rip", StringComparison.OrdinalIgnoreCase)) return "rip";
        if (s.Contains("Transcode", StringComparison.OrdinalIgnoreCase)) return "transcode";
        return "identify";
    }
    var failed = FailedStage();
    var stageOrder = new[] { "setup", "identify", "rip", "transcode", "done" };

    int? StageProgress(string name) => name switch
    {
        "rip" => Model.MakeMkvProgress,
        "transcode" => Model.TranscodeProgress,
        _ => null
    };

    string StageClass(bool isFailed, bool isDone, bool isActive, bool isWarning) =>
        isFailed ? "bg-danger text-white"
        : isWarning && isDone ? "bg-warning text-dark"
        : isDone ? "bg-success text-white"
        : isActive ? "bg-primary text-white"
        : "bg-light text-muted";
}

<div class="d-flex justify-content-between align-items-center">
    @foreach (var (name, label, active, done, warning) in pipelineStages)
    {
        var pct = StageProgress(name);
        var failedIdx = failed is null ? -1 : Array.IndexOf(stageOrder, failed);
        var thisIdx = Array.IndexOf(stageOrder, name);
        var inFailure = failed is not null;
        var isDone = inFailure ? thisIdx < failedIdx : done;
        var isFailed = name == failed;
        var isActive = inFailure ? false : active;
        var isWarning = warning && isDone && !inFailure;
        var cls = StageClass(isFailed, isDone, isActive, isWarning);
        var stageErr = StageError(name);
        var tip = isFailed ? $"Failed at {label}" : stageErr is not null ? $"{label}: {stageErr}" : isWarning ? Model.Warnings : pct.HasValue ? $"{label}: {pct}%" : label;
        <div class="text-center flex-fill mx-1" style="min-width:0;">
            <div class="rounded py-1 px-1 small @cls text-nowrap" title="@tip">@label</div>
            @if (isActive && pct.HasValue)
            {
                <div class="progress mt-1" style="height:4px;">
                    <div class="progress-bar" role="progressbar"
                         style="width:@(pct)%" aria-valuenow="@pct" aria-valuemin="0" aria-valuemax="100"></div>
                </div>
            }
        </div>
        @if (name != "done")
        {
            <div class="text-muted flex-shrink-0" style="width:12px;text-align:center;">&rarr;</div>
        }
    }
</div>
@{
    var overall = pipelineStages.Sum(s => StageProgress(s.Item1) ?? 0);
    var overallCount = pipelineStages.Count(s => StageProgress(s.Item1).HasValue);
    var overallPct = overallCount > 0 ? overall / overallCount : (int?)null;
}
@if (overallPct.HasValue)
{
    <div class="progress mt-2" style="height:6px;">
        <div class="progress-bar progress-bar-striped progress-bar-animated" role="progressbar"
             style="width:@(overallPct)%" aria-valuenow="@overallPct" aria-valuemin="0" aria-valuemax="100">
            @overallPct%
        </div>
    </div>
}
