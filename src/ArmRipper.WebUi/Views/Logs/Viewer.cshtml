@{
    ViewData["Title"] = $"Log: {ViewBag.FileName} - ARM";
    var file = ViewBag.FileName as string;
    var mode = ViewBag.Mode as string ?? "full";
}

<h4>Log: <code>@file</code></h4>

<div class="card">
    <div class="card-body p-0">
        <pre id="log-content" class="mb-0 p-3" style="max-height:80vh;overflow-y:auto;font-size:0.85rem;"></pre>
    </div>
</div>

@section Scripts {
<script>
    const output = document.getElementById('log-content');
    const connection = new signalR.HubConnectionBuilder()
        .withUrl('/hubs/notifications')
        .withAutomaticReconnect()
        .build();

    connection.start()
        .then(() => {
            connection.stream('StreamLog', '@file', '@mode')
                .subscribe({
                    next: (data) => {
                        output.textContent += data;
                        @if (mode == "tail")
                        {
                            <text>window.scrollTo(0, document.body.scrollHeight);</text>
                        }
                    },
                    complete: () => {},
                    error: (err) => {
                        output.textContent = 'Error loading log: ' + err.message;
                    }
                });
        })
        .catch(err => {
            output.textContent = 'Connection error: ' + err.message;
        });
</script>
}
