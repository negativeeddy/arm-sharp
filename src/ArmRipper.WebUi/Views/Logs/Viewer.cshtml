@{
    ViewData["Title"] = $"Log: {ViewBag.FileName} - ARM";
    var file = ViewBag.FileName as string;
    var mode = ViewBag.Mode as string ?? "full";
}

<h4>Log: <code>@file</code></h4>

<div class="card">
    <div class="card-body p-0">
        <pre id="log-content" class="mb-0 p-3" style="max-height:80vh;overflow-y:auto;font-size:0.85rem;"></pre>
    </div>
</div>

@section Scripts {
<script>
    const output = document.getElementById('log-content');
    const logFile = '@file';
    const logMode = '@mode';

    // Auto-scroll tracking: stay pinned to bottom unless user scrolls up
    var autoScroll = true;
    output.addEventListener('scroll', function () {
        autoScroll = (output.scrollTop + output.clientHeight >= output.scrollHeight - 20);
    });

    // ── "full" mode: load entire file via HTTP first, then stream updates ──
    if (logMode === 'full') {
        output.textContent = 'Loading log\u2026';
        fetch('/logs/reader?file=' + encodeURIComponent(logFile))
            .then(function (r) {
                if (!r.ok) throw new Error('HTTP ' + r.status);
                return r.text();
            })
            .then(function (text) {
                output.textContent = text;
                startSignalRStream();
            })
            .catch(function (err) {
                output.textContent = 'Error loading log: ' + err.message;
            });
    } else {
        // ── "tail" mode: SignalR stream (starts from last ~4 KB) ──
        startSignalRStream();
    }

    function startSignalRStream() {
        const connection = new signalR.HubConnectionBuilder()
            .withUrl('/hubs/notifications')
            .withAutomaticReconnect()
            .build();

        connection.start()
            .then(function () {
                connection.stream('StreamLog', logFile, logMode)
                    .subscribe({
                        next: function (data) {
                            output.textContent += data;
                            if (logMode === 'tail' && autoScroll) {
                                output.scrollTop = output.scrollHeight;
                            }
                        },
                        complete: function () {},
                        error: function (err) {
                            output.textContent = 'Error streaming log: ' + err.message;
                        }
                    });
            })
            .catch(function (err) {
                output.textContent = 'Connection error: ' + err.message;
            });
    }
</script>
}
