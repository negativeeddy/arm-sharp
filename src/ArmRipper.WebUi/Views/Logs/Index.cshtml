@model IEnumerable<ArmRipper.WebUi.Controllers.LogFileEntry>
@{
    ViewData["Title"] = "Logs - ARM";
}

<h1>Log Files</h1>

<div class="card mb-4 border-info">
    <div class="card-body py-2">
        <strong>System Log:</strong>
        <a href="/logs/view?file=arm.log&mode=tail" class="btn btn-sm btn-outline-info ml-2">tail</a>
        <a href="/logs/view?file=arm.log&mode=full" class="btn btn-sm btn-outline-secondary">full</a>
        <a href="/logs/download?file=arm.log" class="btn btn-sm btn-outline-success">download</a>
        <span class="text-muted small ml-2">(general ARM system logs — BackgroundRipService, DiscPollingService, etc.)</span>
    </div>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">No log files found in the log directory.</div>
}
else
{
    <table class="table table-striped table-hover table-sm tablesorter">
        <thead>
            <tr>
                <th>File</th>
                <th>Last Modified</th>
                <th>Size</th>
                <th colspan="3" class="text-center">View</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var file in Model)
            {
                <tr>
                    <td>@file.Name</td>
                    <td>@file.LastWriteTime</td>
                    <td>@file.SizeKb KB</td>
                    <td><a href="/logs/view?file=@file.Name&mode=tail" class="btn btn-sm btn-outline-primary">tail</a></td>
                    <td><a href="/logs/view?file=@file.Name&mode=full" class="btn btn-sm btn-outline-secondary">full</a></td>
                    <td><a href="/logs/download?file=@file.Name" class="btn btn-sm btn-outline-success">download</a></td>
                </tr>
            }
        </tbody>
    </table>
}

<div class="card">
    <div class="card-header"><strong>View Modes</strong></div>
    <div class="card-body">
        <p><strong>tail:</strong> Output to browser in real time. Similar to 'tail -f'</p>
        <p><strong>full:</strong> Static output of the entire log including MakeMKV and HandBrake</p>
        <p><strong>download:</strong> Download the full log file</p>
    </div>
</div>

@section Scripts {
<script>
    $(function () {
        $('.tablesorter').tablesorter();
    });
</script>
}
