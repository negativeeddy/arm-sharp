@{
    ViewData["Title"] = "Database Update - ARM";
}

<h1>Database Management</h1>

<div class="row mt-4">
    <div class="col-md-6">
        <div class="card mb-3">
            <div class="card-header"><h5 class="mb-0">Migrate Database</h5></div>
            <div class="card-body">
                <p>Apply pending EF Core migrations to update the database schema.</p>
                <form method="post" action="/database/update">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="action" value="migrate" />
                    <button type="submit" class="btn btn-warning">Run Migrations</button>
                </form>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card mb-3">
            <div class="card-header"><h5 class="mb-0">Create Database</h5></div>
            <div class="card-body">
                <p>Create all tables if they don't exist. Safe to run on an existing database.</p>
                <form method="post" action="/database/update">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="action" value="create" />
                    <button type="submit" class="btn btn-success">Create Tables</button>
                </form>
            </div>
        </div>
    </div>
</div>

<hr />

<h2>Import Completed Movies</h2>
<p>Scan the completed path for folders matching <code>Title (YYYY)</code> format and add them to the database.</p>
<a href="/database/import" class="btn btn-primary">Scan Completed Path</a>

<div class="mt-3">
    <a href="/database" class="btn btn-outline-secondary">&laquo; Back to Database</a>
</div>
