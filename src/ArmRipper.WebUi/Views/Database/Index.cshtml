@model IEnumerable<ArmRipper.Core.Models.Job>
@{
    ViewData["Title"] = "Database - ARM";
    var curPage = ViewBag.CurrentPage as int? ?? 1;
    var totalPages = ViewBag.TotalPages as int? ?? 1;
    var totalJobs = ViewBag.TotalJobs as int? ?? 0;
    var filter = ViewBag.Filter as string;
    var search = ViewBag.Search as string;
}

<h1>Database</h1>

@if (TempData["Message"] is string msg)
{
    <div class="alert alert-info alert-dismissible fade show" role="alert">
        @msg
        <button type="button" class="close" data-dismiss="alert">&times;</button>
    </div>
}

<div class="row mb-3">
    <div class="col-md-6">
        <form method="get" action="/database" class="form-inline">
            <div class="input-group">
                <input type="text" name="search" class="form-control" placeholder="Search title..." value="@search" />
                <div class="input-group-append">
                    <button type="submit" class="btn btn-primary">Search</button>
                    @if (!string.IsNullOrEmpty(search))
                    {
                        <a href="/database" class="btn btn-outline-secondary">Clear</a>
                    }
                </div>
            </div>
        </form>
    </div>
    <div class="col-md-6 text-md-right">
        <div class="btn-group btn-group-sm" role="group">
            <a href="/database?filter=success" class="btn btn-outline-success @(filter == "success" ? "active" : "")">Success</a>
            <a href="/database?filter=failed" class="btn btn-outline-danger @(filter == "failed" ? "active" : "")">Failed</a>
            <a href="/database?filter=active" class="btn btn-outline-warning @(filter == "active" ? "active" : "")">Active</a>
            <a href="/database" class="btn btn-outline-secondary @(filter is null ? "active" : "")">All</a>
        </div>
    </div>
</div>

<p>Showing page <strong>@curPage</strong> of <strong>@totalPages</strong> (@totalJobs total jobs)</p>

@if (!Model.Any())
{
    <div class="alert alert-info">No jobs found.</div>
}
else
{
    <table class="table table-striped table-hover table-sm tablesorter">
        <thead>
            <tr>
                <th>ID</th>
                <th>Title</th>
                <th>Year</th>
                <th>Type</th>
                <th>Status</th>
                <th>Started</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var job in Model)
            {
                <tr>
                    <td class="text-nowrap">@job.Id</td>
                    <td>
                        @(job.TitleManual ?? job.Title ?? "Untitled")
                        @if (job.TitleManual != null)
                        {
                            <span class="badge badge-info">manual</span>
                        }
                    </td>
                    <td>@job.Year</td>
                    <td>@(job.VideoType ?? job.DiscType.ToString())</td>
                    <td>@job.Status</td>
                    <td class="text-nowrap">@job.StartTime.ToString("g")</td>
                    <td class="text-nowrap">
                        <a href="/jobs/jobdetail?jobId=@job.Id" class="btn btn-sm btn-outline-primary">View</a>
                        <a href="/logs/view?file=@job.LogFile&mode=full" class="btn btn-sm btn-outline-info">Log</a>
                        <form method="post" action="/database/delete/@job.Id" style="display:inline;"
                              onsubmit="return confirm('Delete job @job.Id? This cannot be undone.')">
                            <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}


<nav aria-label="Page navigation">
    <ul class="pagination pagination-sm justify-content-center">
        <li class="page-item @(curPage <= 1 ? "disabled" : "")">
            <a class="page-link" href="/database?page=@(curPage - 1)&filter=@filter&search=@search">&laquo; Prev</a>
        </li>
        @for (var p = 1; p <= totalPages; p++)
        {
            <li class="page-item @(p == curPage ? "active" : "")">
                <a class="page-link" href="/database?page=@p&filter=@filter&search=@search">@p</a>
            </li>
        }
        <li class="page-item @(curPage >= totalPages ? "disabled" : "")">
            <a class="page-link" href="/database?page=@(curPage + 1)&filter=@filter&search=@search">Next &raquo;</a>
        </li>
    </ul>
</nav>

<hr />

<h2>Database Actions</h2>
<div class="btn-group" role="group">
    <a href="/database/update" class="btn btn-outline-secondary">Manage Database</a>
</div>

@section Scripts {
<script>
    $(function () {
        $('.tablesorter').tablesorter({
            sortList: [[0,1]],
            headers: { 0: { sorter: 'digit' } }
        });
    });
</script>
}
