@model IEnumerable<ArmRipper.Core.Models.Notification>
@{
    ViewData["Title"] = "Notifications - ARM";
    var current = ViewBag.CurrentFilter as string ?? "unread";
}

<h1>Notifications</h1>

@if (TempData["Message"] is string msg)
{
    <div class="alert alert-info alert-dismissible fade show" role="alert">
        @msg
        <button type="button" class="close" data-dismiss="alert">&times;</button>
    </div>
}

<ul class="nav nav-pills mb-3">
    <li class="nav-item">
        <a class="nav-link @(current == "unread" ? "active" : "")" href="/notifications?filter=unread">Unread</a>
    </li>
    <li class="nav-item">
        <a class="nav-link @(current == "read" ? "active" : "")" href="/notifications?filter=read">Read</a>
    </li>
    <li class="nav-item">
        <a class="nav-link @(current == "all" ? "active" : "")" href="/notifications?filter=all">All</a>
    </li>
</ul>

<div class="mb-3 d-flex">
    <button type="button" class="btn btn-outline-info btn-sm mr-2" onclick="sendTestNotification()">🧪 Test Notification</button>
    <span id="testMsg" class="text-success small align-self-center" style="display:none">✓ Sent!</span>
    @if (current != "read" && Model.Any(n => !n.Read))
    {
        <form method="post" action="/notifications/markallread" style="display:inline;">
            <button type="submit" class="btn btn-outline-danger btn-sm">Mark All Read</button>
        </form>
    }
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">No notifications.</div>
}
else
{
    <table class="table table-striped table-hover table-sm">
        <thead>
            <tr>
                <th>Time</th>
                <th>Type</th>
                <th>Message</th>
                <th>Read</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var notification in Model)
            {
                <tr class="@(notification.Read ? "" : "table-active")">
                    <td>@notification.Timestamp.ToLocalTime().ToString("g")</td>
                    <td><span class="badge badge-secondary">@notification.EventType</span></td>
                    <td>@notification.Message</td>
                    <td>@(notification.Read ? "Yes" : "No")</td>
                    <td>
                        @if (!notification.Read)
                        {
                            <form method="post" action="/notifications/markread/@notification.Id">
                                <button type="submit" class="btn btn-sm btn-outline-success">Mark Read</button>
                            </form>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@section Scripts {
<script>
async function sendTestNotification() {
    const btn = event.target;
    btn.disabled = true;
    btn.textContent = '⏳ Sending...';
    try {
        const resp = await fetch('/notifications/test', { method: 'POST' });
        if (resp.ok) {
            const msg = document.getElementById('testMsg');
            msg.style.display = '';
            setTimeout(() => { msg.style.display = 'none'; }, 3000);
        }
    } finally {
        btn.disabled = false;
        btn.textContent = '🧪 Test Notification';
    }
}
</script>
}
