@model IEnumerable<ArmRipper.Core.Models.Notification>
@{
    ViewData["Title"] = "Notifications - ARM";
    var current = ViewBag.CurrentFilter as string ?? "unread";
}

<h1>Notifications</h1>

<ul class="nav nav-pills mb-3">
    <li class="nav-item">
        <a class="nav-link @(current == "unread" ? "active" : "")" href="/notifications?filter=unread">Unread</a>
    </li>
    <li class="nav-item">
        <a class="nav-link @(current == "read" ? "active" : "")" href="/notifications?filter=read">Read</a>
    </li>
    <li class="nav-item">
        <a class="nav-link @(current == "all" ? "active" : "")" href="/notifications?filter=all">All</a>
    </li>
</ul>

@if (current != "read" && Model.Any(n => !n.Read))
{
    <form method="post" action="/notifications/markallread" class="mb-3">
        <button type="submit" class="btn btn-outline-danger btn-sm">Mark All Read</button>
    </form>
}

@if (!Model.Any())
{
    <div class="alert alert-info">No notifications.</div>
}
else
{
    <table class="table table-striped table-hover table-sm">
        <thead>
            <tr>
                <th>Time</th>
                <th>Type</th>
                <th>Message</th>
                <th>Read</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var notification in Model)
            {
                <tr class="@(notification.Read ? "" : "table-active")">
                    <td>@notification.Timestamp.ToString("g")</td>
                    <td><span class="badge badge-secondary">@notification.EventType</span></td>
                    <td>@notification.Message</td>
                    <td>@(notification.Read ? "Yes" : "No")</td>
                    <td>
                        @if (!notification.Read)
                        {
                            <form method="post" action="/notifications/markread/@notification.Id">
                                <button type="submit" class="btn btn-sm btn-outline-success">Mark Read</button>
                            </form>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
