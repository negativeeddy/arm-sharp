@{
    ViewData["Title"] = "Settings - ARM";
    var drives = ViewBag.Drives as IEnumerable<ArmRipper.Core.Models.SystemDrive> ?? [];
    var sysInfo = ViewBag.SystemInfo as ArmRipper.Core.Models.SystemInfo;
    var stats = ViewBag.Stats as Dictionary<string, object>;
    var armSettings = ViewBag.ArmSettings as ArmRipper.Core.Configuration.ArmSettings;
    var uiSettings = ViewBag.UiSettings as ArmRipper.Core.Models.UiSettings;
    var abcdeConfig = ViewBag.AbcdeConfig as Dictionary<string, string> ?? [];
}

<div id="settingsPage">

<h1>Settings</h1>

<div class="alert alert-info alert-dismissible fade show" role="alert">
    <strong>ℹ️ Settings flow:</strong> File config (YAML + appsettings.json) seeds the database on first run.
    Changes made here override the file config. Set <code>ARM_RESET_SETTINGS=true</code> on restart to reset from file,
    or click <strong>Reset to file defaults</strong> below.
    <button type="button" class="close" data-dismiss="alert">&times;</button>
</div>

<form id="resetForm" method="post" action="/settings/reset-settings"></form>

@if (TempData["Message"] is string msg)
{
    <div class="alert alert-info alert-dismissible fade show" role="alert">
        @msg
        <button type="button" class="close" data-dismiss="alert">&times;</button>
    </div>
}

<ul class="nav nav-tabs mb-3" id="settingsTabs" role="tablist">
    <li class="nav-item"><a class="nav-link @(ViewBag.ActiveTab == "tab1" ? "active" : "")" id="tab1-tab" data-toggle="tab" href="#tab1" role="tab">General Info</a></li>
    <li class="nav-item"><a class="nav-link @(ViewBag.ActiveTab == "tab2" ? "active" : "")" id="tab2-tab" data-toggle="tab" href="#tab2" role="tab">System Info</a></li>
    <li class="nav-item"><a class="nav-link @(ViewBag.ActiveTab == "tab3" ? "active" : "")" id="tab3-tab" data-toggle="tab" href="#tab3" role="tab">Ripper</a></li>
    <li class="nav-item"><a class="nav-link @(ViewBag.ActiveTab == "tab4" ? "active" : "")" id="tab4-tab" data-toggle="tab" href="#tab4" role="tab">UI</a></li>
    <li class="nav-item"><a class="nav-link @(ViewBag.ActiveTab == "tab5" ? "active" : "")" id="tab5-tab" data-toggle="tab" href="#tab5" role="tab">abcde</a></li>
    <li class="nav-item"><a class="nav-link @(ViewBag.ActiveTab == "tab8" ? "active" : "")" id="tab8-tab" data-toggle="tab" href="#tab8" role="tab">Transcoding</a></li>
    <li class="nav-item"><a class="nav-link @(ViewBag.ActiveTab == "tab9" ? "active" : "")" id="tab9-tab" data-toggle="tab" href="#tab9" role="tab">Online DB</a></li>
    <li class="nav-item"><a class="nav-link @(ViewBag.ActiveTab == "tab6" ? "active" : "")" id="tab6-tab" data-toggle="tab" href="#tab6" role="tab">Apprise</a></li>
    <li class="nav-item"><a class="nav-link @(ViewBag.ActiveTab == "tab7" ? "active" : "")" id="tab7-tab" data-toggle="tab" href="#tab7" role="tab">Help</a></li>
</ul>

<div class="tab-content" id="settingsTabsContent">

    <!-- General Info -->
    <div class="tab-pane fade @(ViewBag.ActiveTab == "tab1" ? "show active" : "")" id="tab1" role="tabpanel">
        <h2>General Info</h2>
        <table class="table table-sm">
            <tr><td><strong>ARM Version:</strong></td><td>1.0.0</td></tr>
            <tr><td><strong>Hostname:</strong></td><td>@ViewBag.Hostname</td></tr>
            <tr><td><strong>OS:</strong></td><td>@ViewBag.OsDesc</td></tr>
            <tr><td><strong>CPU Cores:</strong></td><td>@ViewBag.ProcCount</td></tr>
            <tr><td><strong>Log Path:</strong></td><td>@armSettings?.LogPath</td></tr>
            <tr><td><strong>Raw Path:</strong></td><td>@armSettings?.RawPath</td></tr>
            <tr><td><strong>Transcode Path:</strong></td><td>@armSettings?.TranscodePath</td></tr>
            <tr><td><strong>Completed Path:</strong></td><td>@armSettings?.CompletedPath</td></tr>
            <tr><td><strong>Database File:</strong></td><td>@armSettings?.DbFile</td></tr>
            <tr><td><strong>Install Path:</strong></td><td>@armSettings?.InstallPath</td></tr>
        </table>
    </div>

    <!-- System Info -->
    <div class="tab-pane fade @(ViewBag.ActiveTab == "tab2" ? "show active" : "")" id="tab2" role="tabpanel">
        <h2>System Info &amp; Health</h2>
        <a href="/settings/sysinfo" class="btn btn-sm btn-outline-secondary mb-2">Update system information</a>
        @if (sysInfo is not null)
        {
            <table class="table table-sm">
                <tr><td><strong>Hostname:</strong></td><td>@sysInfo.Hostname</td></tr>
                <tr><td><strong>CPU:</strong></td><td>@sysInfo.CpuInfo</td></tr>
                <tr><td><strong>RAM:</strong></td><td>@sysInfo.RamInfo</td></tr>
                <tr><td><strong>OS:</strong></td><td>@sysInfo.OsInfo</td></tr>
            </table>
        }
        else
        {
            <p>No system info yet. <a href="/settings/sysinfo">Run system info update</a></p>
        }
        <h3 class="mt-3">Drives</h3>
        <a href="/settings/scan" class="btn btn-sm btn-outline-primary mb-2">Scan for drives</a>
        @if (drives.Any())
        {
            <table class="table table-sm table-striped">
                <thead>
                    <tr>
                        <th>Device</th>
                        <th>Model</th>
                        <th>Serial</th>
                        <th>Firmware</th>
                        <th>Capabilities</th>
                        <th>Mode</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        var activeDevPaths = ViewBag.ActiveJobDevPaths as HashSet<string> ?? new HashSet<string>();
                    }
                    @foreach (var d in drives)
                    {
                        var isRipping = activeDevPaths.Contains(d.Mount ?? "");
                        <tr class="@(d.DriveMode == "disabled" ? "table-secondary text-muted" : "")">
                            <td><code>@d.Mount</code></td>
                            <td>@d.Model</td>
                            <td>@(d.Serial ?? "—")</td>
                            <td>@(d.Firmware ?? "—")</td>
                            <td>
                                @if (d.ReadCd) { <span class="badge badge-secondary">CD</span> }
                                @if (d.ReadDvd) { <span class="badge badge-info">DVD</span> }
                                @if (d.ReadBd) { <span class="badge badge-primary">BD</span> }
                                @if (!d.ReadCd && !d.ReadDvd && !d.ReadBd) { <span class="badge badge-light">?</span> }
                            </td>
                            <td>
                                <form method="post" action="/settings/drive-toggle-mode/@d.Id" style="display:inline;">
                                    <button type="submit" class="btn btn-sm @(d.DriveMode switch
                                    {
                                        "autodetect" => "btn-success",
                                        "manual" => "btn-warning",
                                        _ => "btn-secondary"
                                    })">@d.DriveMode</button>
                                </form>
                            </td>
                            <td class="text-nowrap">
                                @if (isRipping)
                                {
                                    <span class="badge bg-warning text-dark">Ripping</span>
                                }
                                else
                                {
                                    <form method="post" action="/settings/start-rip" style="display:inline;">
                                        <input type="hidden" name="devPath" value="@d.Mount" />
                                        <button type="submit" class="btn btn-sm btn-success" title="Start rip">Rip</button>
                                    </form>
                                }
                                <form method="post" action="/settings/eject" style="display:inline;">
                                    <input type="hidden" name="devPath" value="@d.Mount" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Eject disc">Eject</button>
                                </form>
                                <form method="post" action="/settings/drive-remove/@d.Id" style="display:inline;"
                                      data-confirm="Remove drive @d.Mount from the database?">
                                    <button type="submit" class="btn btn-sm btn-outline-dark" title="Remove drive">Remove</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <p>No drives found. <a href="/settings/scan">Scan for drives</a></p>
        }
        <h3 class="mt-3">Hardware Encoders</h3>
        @{
            var encoderList = ViewBag.HardwareEncoders as System.Collections.IList;
            var hasEncoders = encoderList is { Count: > 0 }
                && encoderList[0] is Dictionary<string, object> first
                && (!first.TryGetValue("available", out var a) || a is not false);
        }
        @if (!hasEncoders)
        {
            <p class="text-muted">No hardware encoders detected.</p>
        }
        else
        {
            foreach (Dictionary<string, object> enc in encoderList!)
            {
                <div class="card mb-2">
                    <div class="card-body py-2">
                        <strong>@enc["vendor"] @enc["type"]</strong>
                        @if (enc.TryGetValue("index", out var idx) && enc.TryGetValue("gpu", out var gpu))
                        {
                            <span class="text-muted">#@idx — @gpu</span>
                        }
                        else if (enc.TryGetValue("gpu", out var gpu2))
                        {
                            <span class="text-muted"> — @gpu2</span>
                        }
                        <table class="table table-sm mb-0 mt-1">
                            @if (enc.TryGetValue("driver", out var drv))
                            {
                                <tr><td class="w-25">Driver</td><td>@drv</td></tr>
                            }
                            @if (enc.TryGetValue("compute_cap", out var cc))
                            {
                                <tr><td>Compute Capability</td><td>@cc</td></tr>
                            }
                            @if (enc.TryGetValue("encoder_util", out var util))
                            {
                                <tr><td>Encoder Utilization</td><td>@util</td></tr>
                            }
                            @if (enc.TryGetValue("sessions", out var sess))
                            {
                                <tr><td>Active Sessions</td><td>@sess</td></tr>
                            }
                            @if (enc.TryGetValue("avg_fps", out var fps))
                            {
                                <tr><td>Average FPS</td><td>@fps</td></tr>
                            }
                            @if (enc.TryGetValue("avg_latency", out var lat))
                            {
                                <tr><td>Average Latency</td><td>@lat</td></tr>
                            }
                            @if (enc.TryGetValue("codecs", out var codecsObj) && codecsObj is List<string> codecs)
                            {
                                <tr><td>Codecs</td><td>@string.Join(", ", codecs)</td></tr>
                            }
                            @if (enc.TryGetValue("note", out var note))
                            {
                                <tr><td class="text-warning">Note</td><td class="text-warning">@note</td></tr>
                            }
                        </table>
                    </div>
                </div>
            }
        }

        <h3 class="mt-3">Statistics</h3>
        <table class="table table-sm">
            <tr><td>Total Rips:</td><td>@(stats?["total_rips"] ?? 0)</td></tr>
            <tr><td>Failed:</td><td>@(stats?["failed_rips"] ?? 0)</td></tr>
            <tr><td>Movies:</td><td>@(stats?["movies"] ?? 0)</td></tr>
            <tr><td>Series:</td><td>@(stats?["series"] ?? 0)</td></tr>
        </table>
    </div>

    <!-- Ripper Settings -->
    <div class="tab-pane fade @(ViewBag.ActiveTab == "tab3" ? "show active" : "")" id="tab3" role="tabpanel">
        @{
            var tips = new Dictionary<string, string>
            {
                ["RipMethod"] = "Which program to use: mkv (MakeMKV), backup, or abcde",
                ["MkvArgs"] = "Extra arguments passed to makemkvcon (e.g. --decrypt)",
                ["MinLength"] = "Shortest track length in seconds to include",
                ["MaxLength"] = "Longest track length in seconds (99999 = no limit)",
                ["MaxConcurrentRips"] = "How many jobs can run in parallel (e.g. rip one disc while another is transcoding)",
                ["MainFeature"] = "Rip only the main feature (longest track)",
                ["AutoEject"] = "Automatically eject disc after processing",
                ["DiscPollingEnabled"] = "Automatically detect and rip newly inserted discs (requires app restart to take effect)",
            };
            static string tip(string key, Dictionary<string, string> tips) =>
                $"<span class=\"text-info ml-1\" data-toggle=\"tooltip\" title=\"{tips[key]}\" style=\"cursor:help\">&#9432;</span>";
        }
        <h2>Ripper Settings</h2>
        <form method="post" action="/settings/save-ripper">
            <table class="table table-sm">
                <tr><td class="w-25"><label>Rip Method:</label>@Html.Raw(tip("RipMethod", tips))</td><td><input type="text" name="RipMethod" value="@armSettings?.RipMethod" class="form-control" /></td></tr>
                <tr><td><label>MKV Args:</label>@Html.Raw(tip("MkvArgs", tips))</td><td><input type="text" name="MkvArgs" value="@armSettings?.MkvArgs" class="form-control" /></td></tr>
                <tr><td><label>Min Length:</label>@Html.Raw(tip("MinLength", tips))</td><td><input type="number" name="MinLength" value="@armSettings?.MinLength" class="form-control" /></td></tr>
                <tr><td><label>Max Length:</label>@Html.Raw(tip("MaxLength", tips))</td><td><input type="number" name="MaxLength" value="@armSettings?.MaxLength" class="form-control" /></td></tr>
                <tr><td><label>Concurrent Jobs:</label>@Html.Raw(tip("MaxConcurrentRips", tips))</td><td><input type="number" name="MaxConcurrentRips" value="@(armSettings?.MaxConcurrentRips ?? 1)" class="form-control" min="1" step="1" /></td></tr>
                <tr><td><label>Eject Cooldown (s):</label><span class="text-info ml-1" data-toggle="tooltip" title="Seconds to wait after a rip completes before the same drive is eligible for a new auto-rip. Prevents false re-triggering while the disc is still ejecting." style="cursor:help">&#9432;</span></td><td><input type="number" name="EjectCooldownSeconds" value="@(armSettings?.EjectCooldownSeconds ?? 15)" class="form-control" min="0" max="120" step="1" /></td></tr>
                <tr><td><label for="MainFeature">Main Feature:</label>@Html.Raw(tip("MainFeature", tips))</td><td><input type="hidden" name="MainFeature" value="false" /><div class="custom-control custom-switch d-inline-block"><input type="checkbox" class="custom-control-input" id="MainFeature" name="MainFeature" value="true" checked="@armSettings?.MainFeature" /><label class="custom-control-label" for="MainFeature"></label></div></td></tr>
                <tr><td><label for="AutoEject">Auto Eject:</label>@Html.Raw(tip("AutoEject", tips))</td><td><input type="hidden" name="AutoEject" value="false" /><div class="custom-control custom-switch d-inline-block"><input type="checkbox" class="custom-control-input" id="AutoEject" name="AutoEject" value="true" checked="@armSettings?.AutoEject" /><label class="custom-control-label" for="AutoEject"></label></div></td></tr>
                <tr><td><label for="DiscPollingEnabled">Disc Auto-Detect:</label>@Html.Raw(tip("DiscPollingEnabled", tips))</td><td><input type="hidden" name="DiscPollingEnabled" value="false" /><div class="custom-control custom-switch d-inline-block"><input type="checkbox" class="custom-control-input" id="DiscPollingEnabled" name="DiscPollingEnabled" value="true" checked="@armSettings?.DiscPollingEnabled" /><label class="custom-control-label" for="DiscPollingEnabled"></label></div></td></tr>
                <tr><td><label for="FileBotNonStrict">FileBot Non-Strict:</label></td><td><input type="hidden" name="FileBotNonStrict" value="false" /><div class="custom-control custom-switch d-inline-block"><input type="checkbox" class="custom-control-input" id="FileBotNonStrict" name="FileBotNonStrict" value="true" checked="@armSettings?.FileBotNonStrict" /><label class="custom-control-label" for="FileBotNonStrict">Enable fuzzy matching (-non-strict)</label></div><br /><small class="text-muted">When enabled, FileBot uses fuzzy matching — useful for raw MakeMKV output filenames. Disable for stricter matching when filenames match known titles.</small></td></tr>
            </table>
            <button type="submit" class="btn btn-primary">Save Ripper Settings</button>
            <button type="submit" class="btn btn-outline-warning ml-2" form="resetForm">↻ Reset to file defaults</button>
        </form>

        <hr class="my-4" />
        <h3>TheDiscDb Cache</h3>
        <p class="text-muted small">
            DiscDb lookups are cached locally to avoid redundant API calls when re-ripping the same disc.
            Clearing the cache forces fresh lookups on the next rip of each disc.
        </p>
        <form method="post" action="/settings/cleardiscdb-cache" onsubmit="return confirm('Clear all @ViewBag.DiscDbCacheCount cached DiscDb entr' + (@ViewBag.DiscDbCacheCount == 1 ? 'y' : 'ies') + '?');">
            <p>
                <strong>@ViewBag.DiscDbCacheCount</strong> cached disc entr@(ViewBag.DiscDbCacheCount == 1 ? "y" : "ies").
                <button type="submit" class="btn btn-outline-danger btn-sm">🗑 Clear DiscDb Cache</button>
            </p>
        </form>
    </div>

    <!-- UI Settings -->
    <div class="tab-pane fade @(ViewBag.ActiveTab == "tab4" ? "show active" : "")" id="tab4" role="tabpanel">
        @{
            var uiTips = new Dictionary<string, string>
            {
                ["Theme"] = "UI color theme: Light or Dark mode",
                ["RefreshRate"] = "How often (in seconds) the UI refreshes job status via SignalR. Lower values = more responsive but higher network usage.",
                ["IconStyle"] = "Visual style for drive type icons: Default, Simple, or Detailed",
            };
            static string uiTip(string key, Dictionary<string, string> tips) =>
                tips.TryGetValue(key, out var t) ? $"<span class=\"text-info ml-1\" data-toggle=\"tooltip\" title=\"{t}\" style=\"cursor:help\">&#9432;</span>" : "";
        }
        <h2>UI Settings</h2>
        <form method="post" action="/settings/save-ui">
            @Html.AntiForgeryToken()
            <table class="table table-sm">
                <tr>
                    <td><label>Theme:</label>@Html.Raw(uiTip("Theme", uiTips))</td>
                    <td>
                        <select name="theme" class="form-control">
                            <option value="light" selected="@(uiSettings?.Theme == "light" || uiSettings?.Theme is null)">Light</option>
                            <option value="dark" selected="@(uiSettings?.Theme == "dark")">Dark</option>
                        </select>
                    </td>
                </tr>
                <tr>
                    <td><label>Refresh Rate (seconds):</label>@Html.Raw(uiTip("RefreshRate", uiTips))</td>
                    <td><input type="number" name="refreshRate" value="@(uiSettings?.RefreshRate ?? 10)" class="form-control" min="2" max="300" /></td>
                </tr>
                <tr>
                    <td><label>Icon Style:</label>@Html.Raw(uiTip("IconStyle", uiTips))</td>
                    <td>
                        <select name="iconStyle" class="form-control">
                            <option value="default" selected="@(uiSettings?.IconStyle == "default" || uiSettings?.IconStyle is null)">Default</option>
                            <option value="simple" selected="@(uiSettings?.IconStyle == "simple")">Simple</option>
                            <option value="detailed" selected="@(uiSettings?.IconStyle == "detailed")">Detailed</option>
                        </select>
                    </td>
                </tr>
            </table>
            <button type="submit" class="btn btn-primary">Save UI Settings</button>
        </form>
    </div>

    <!-- abcde Config -->
    <div class="tab-pane fade @(ViewBag.ActiveTab == "tab5" ? "show active" : "")" id="tab5" role="tabpanel">
        @{
            var abcdeTips = new Dictionary<string, string>
            {
                ["OutputFormat"] = "Audio codec for ripped CD tracks (ogg, mp3, flac, aac, wav)",
                ["OutputDir"] = "Directory where ripped audio files are saved",
            };
            static string abcdeTip(string key, Dictionary<string, string> tips) =>
                tips.TryGetValue(key, out var t) ? $"<span class=\"text-info ml-1\" data-toggle=\"tooltip\" title=\"{t}\" style=\"cursor:help\">&#9432;</span>" : "";
        }
        <h2>abcde Config</h2>
        <p>Configuration for audio CD ripping via abcde. Saved to <code>/etc/arm/config/abcde.conf</code>.</p>
        <form method="post" action="/settings/save-abcde">
            @Html.AntiForgeryToken()
            <table class="table table-sm">
                <tr>
                    <td><label>Output Format:</label>@Html.Raw(abcdeTip("OutputFormat", abcdeTips))</td>
                    <td>
                        <select name="outputFormat" class="form-control">
                            <option value="ogg" selected="@(abcdeConfig.GetValueOrDefault("OUTPUTTYPE") == "ogg")">OGG</option>
                            <option value="mp3" selected="@(abcdeConfig.GetValueOrDefault("OUTPUTTYPE") == "mp3")">MP3</option>
                            <option value="flac" selected="@(abcdeConfig.GetValueOrDefault("OUTPUTTYPE") == "flac")">FLAC</option>
                            <option value="aac" selected="@(abcdeConfig.GetValueOrDefault("OUTPUTTYPE") == "aac")">AAC</option>
                            <option value="wav" selected="@(abcdeConfig.GetValueOrDefault("OUTPUTTYPE") == "wav")">WAV</option>
                        </select>
                    </td>
                </tr>
                <tr>
                    <td><label>Output Directory:</label>@Html.Raw(abcdeTip("OutputDir", abcdeTips))</td>
                    <td><input type="text" name="outputDir" value="@(abcdeConfig.GetValueOrDefault("OUTPUTDIR", "/home/arm/media/raw"))" class="form-control" /></td>
                </tr>
            </table>
            <button type="submit" class="btn btn-primary">Save abcde Config</button>
        </form>
        <div class="mt-3">
            <h4>Current Config</h4>
            <pre class="bg-light p-2"><code>@foreach (var kv in abcdeConfig)
{
    <text>@kv.Key=@kv.Value
</text>
}</code></pre>
        </div>
    </div>

    <!-- Transcoding Settings -->
    <div class="tab-pane fade @(ViewBag.ActiveTab == "tab8" ? "show active" : "")" id="tab8" role="tabpanel">
        @{
            var transTips = new Dictionary<string, string>
            {
                ["SkipTranscode"] = "Skip video transcoding entirely; keep raw MakeMKV output",
                ["UseFfmpeg"] = "Use FFmpeg instead of HandBrake for transcoding",
                ["DelRawFiles"] = "Delete raw MakeMKV files after transcoding completes",
                ["HbPresetDvd"] = "HandBrake preset name for DVD encodes",
                ["HbPresetBd"] = "HandBrake preset name for Blu-ray encodes",
                ["HbArgsDvd"] = "Extra HandBrake CLI arguments for DVD (overrides preset)",
                ["HbArgsBd"] = "Extra HandBrake CLI arguments for Blu-ray (overrides preset)",
                ["DestExt"] = "Output file extension (mkv, mp4, m4v, etc.)",
                ["FfmpegCli"] = "Path to the FFmpeg executable",
                ["FfmpegPreFileArgs"] = "FFmpeg arguments before the input file",
                ["FfmpegPostFileArgs"] = "FFmpeg arguments after the input file",
                ["MaxConcurrentTranscodes"] = "Maximum simultaneous transcodes (0 = unlimited)",
            };
            static string transTip(string key, Dictionary<string, string> tips) =>
                $"<span class=\"text-info ml-1\" data-toggle=\"tooltip\" title=\"{tips[key]}\" style=\"cursor:help\">&#9432;</span>";
        }
        <h2>Transcoding Settings</h2>
        <form method="post" action="/settings/save-transcode">
            <div class="card mb-3">
                <div class="card-header"><h5 class="mb-0">General</h5></div>
                <div class="card-body">
                    <table class="table table-sm mb-0">
                        <tr>
                            <td class="w-25"><label for="SkipTranscode">Skip Transcode:</label>@Html.Raw(transTip("SkipTranscode", transTips))</td>
                            <td><input type="hidden" name="SkipTranscode" value="false" /><div class="custom-control custom-switch d-inline-block"><input type="checkbox" class="custom-control-input" id="SkipTranscode" name="SkipTranscode" value="true" checked="@armSettings?.SkipTranscode" /><label class="custom-control-label" for="SkipTranscode"></label></div></td>
                        </tr>
                        <tr>
                            <td><label for="UseFfmpeg">Use FFmpeg:</label>@Html.Raw(transTip("UseFfmpeg", transTips))</td>
                            <td><input type="hidden" name="UseFfmpeg" value="false" /><div class="custom-control custom-switch d-inline-block"><input type="checkbox" class="custom-control-input" id="UseFfmpeg" name="UseFfmpeg" value="true" checked="@armSettings?.UseFfmpeg" /><label class="custom-control-label" for="UseFfmpeg"></label></div></td>
                        </tr>
                        <tr>
                            <td><label for="DelRawFiles">Delete Raw Files:</label>@Html.Raw(transTip("DelRawFiles", transTips))</td>
                            <td><input type="hidden" name="DelRawFiles" value="false" /><div class="custom-control custom-switch d-inline-block"><input type="checkbox" class="custom-control-input" id="DelRawFiles" name="DelRawFiles" value="true" checked="@armSettings?.DelRawFiles" /><label class="custom-control-label" for="DelRawFiles"></label></div></td>
                        </tr>
                        <tr>
                            <td><label>Output Extension:</label>@Html.Raw(transTip("DestExt", transTips))</td>
                            <td><input type="text" name="DestExt" value="@armSettings?.DestExt" class="form-control" /></td>
                        </tr>
                        <tr>
                            <td><label>Max Concurrent Transcodes:</label>@Html.Raw(transTip("MaxConcurrentTranscodes", transTips))</td>
