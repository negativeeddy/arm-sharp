@{
    ViewData["Title"] = "Settings - ARM";
    var drives = ViewBag.Drives as IEnumerable<ArmRipper.Core.Models.SystemDrive> ?? [];
    var sysInfo = ViewBag.SystemInfo as ArmRipper.Core.Models.SystemInfo;
    var stats = ViewBag.Stats as Dictionary<string, object>;
    var armSettings = ViewBag.ArmSettings as ArmRipper.Core.Configuration.ArmSettings;
    var uiSettings = ViewBag.UiSettings as ArmRipper.Core.Models.UiSettings;
    var abcdeConfig = ViewBag.AbcdeConfig as Dictionary<string, string> ?? [];
}

<div id="settingsPage">

<h1>Settings</h1>

@if (TempData["Message"] is string msg)
{
    <div class="alert alert-info alert-dismissible fade show" role="alert">
        @msg
        <button type="button" class="close" data-dismiss="alert">&times;</button>
    </div>
}

<ul class="nav nav-tabs mb-3" id="settingsTabs" role="tablist">
    <li class="nav-item"><a class="nav-link active" id="tab1-tab" data-toggle="tab" href="#tab1" role="tab">General Info</a></li>
    <li class="nav-item"><a class="nav-link" id="tab2-tab" data-toggle="tab" href="#tab2" role="tab">System Info</a></li>
    <li class="nav-item"><a class="nav-link" id="tab3-tab" data-toggle="tab" href="#tab3" role="tab">Ripper</a></li>
    <li class="nav-item"><a class="nav-link" id="tab4-tab" data-toggle="tab" href="#tab4" role="tab">UI</a></li>
    <li class="nav-item"><a class="nav-link" id="tab5-tab" data-toggle="tab" href="#tab5" role="tab">abcde</a></li>
    <li class="nav-item"><a class="nav-link" id="tab6-tab" data-toggle="tab" href="#tab6" role="tab">Apprise</a></li>
    <li class="nav-item"><a class="nav-link" id="tab7-tab" data-toggle="tab" href="#tab7" role="tab">Help</a></li>
</ul>

<div class="tab-content" id="settingsTabsContent">

    <!-- General Info -->
    <div class="tab-pane fade show active" id="tab1" role="tabpanel">
        <h2>General Info</h2>
        <table class="table table-sm">
            <tr><td><strong>ARM Version:</strong></td><td>1.0.0</td></tr>
            <tr><td><strong>Hostname:</strong></td><td>@ViewBag.Hostname</td></tr>
            <tr><td><strong>OS:</strong></td><td>@ViewBag.OsDesc</td></tr>
            <tr><td><strong>CPU Cores:</strong></td><td>@ViewBag.ProcCount</td></tr>
            <tr><td><strong>Log Path:</strong></td><td>@armSettings?.LogPath</td></tr>
            <tr><td><strong>Raw Path:</strong></td><td>@armSettings?.RawPath</td></tr>
            <tr><td><strong>Transcode Path:</strong></td><td>@armSettings?.TranscodePath</td></tr>
            <tr><td><strong>Completed Path:</strong></td><td>@armSettings?.CompletedPath</td></tr>
            <tr><td><strong>Database File:</strong></td><td>@armSettings?.DbFile</td></tr>
            <tr><td><strong>Install Path:</strong></td><td>@armSettings?.InstallPath</td></tr>
        </table>
    </div>

    <!-- System Info -->
    <div class="tab-pane fade" id="tab2" role="tabpanel">
        <h2>System Info &amp; Health</h2>
        <a href="/settings/sysinfo" class="btn btn-sm btn-outline-secondary mb-2">Update system information</a>
        @if (sysInfo is not null)
        {
            <table class="table table-sm">
                <tr><td><strong>Hostname:</strong></td><td>@sysInfo.Hostname</td></tr>
                <tr><td><strong>CPU:</strong></td><td>@sysInfo.CpuInfo</td></tr>
                <tr><td><strong>RAM:</strong></td><td>@sysInfo.RamInfo</td></tr>
                <tr><td><strong>OS:</strong></td><td>@sysInfo.OsInfo</td></tr>
            </table>
        }
        else
        {
            <p>No system info yet. <a href="/settings/sysinfo">Run system info update</a></p>
        }
        <h3 class="mt-3">Drives</h3>
        <a href="/settings/scan" class="btn btn-sm btn-outline-primary mb-2">Scan for drives</a>
        @if (drives.Any())
        {
            <table class="table table-sm table-striped">
                <thead>
                    <tr>
                        <th>Device</th>
                        <th>Model</th>
                        <th>Serial</th>
                        <th>Firmware</th>
                        <th>Capabilities</th>
                        <th>Mode</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var d in drives)
                    {
                        <tr class="@(d.DriveMode == "disabled" ? "table-secondary text-muted" : "")">
                            <td><code>@d.Mount</code></td>
                            <td>@d.Model</td>
                            <td>@(d.Serial ?? "—")</td>
                            <td>@(d.Firmware ?? "—")</td>
                            <td>
                                @if (d.ReadCd) { <span class="badge badge-secondary">CD</span> }
                                @if (d.ReadDvd) { <span class="badge badge-info">DVD</span> }
                                @if (d.ReadBd) { <span class="badge badge-primary">BD</span> }
                                @if (!d.ReadCd && !d.ReadDvd && !d.ReadBd) { <span class="badge badge-light">?</span> }
                            </td>
                            <td>
                                <form method="post" action="/settings/drive-toggle-mode/@d.Id" style="display:inline;">
                                    <button type="submit" class="btn btn-sm @(d.DriveMode switch
                                    {
                                        "autodetect" => "btn-success",
                                        "manual" => "btn-warning",
                                        _ => "btn-secondary"
                                    })">@d.DriveMode</button>
                                </form>
                            </td>
                            <td class="text-nowrap">
                                <form method="post" action="/settings/start-rip" style="display:inline;">
                                    <input type="hidden" name="devPath" value="@d.Mount" />
                                    <button type="submit" class="btn btn-sm btn-success" title="Start rip">Rip</button>
                                </form>
                                <form method="post" action="/settings/eject" style="display:inline;">
                                    <input type="hidden" name="devPath" value="@d.Mount" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Eject disc">Eject</button>
                                </form>
                                <form method="post" action="/settings/drive-remove/@d.Id" style="display:inline;"
                                      data-confirm="Remove drive @d.Mount from the database?">
                                    <button type="submit" class="btn btn-sm btn-outline-dark" title="Remove drive">Remove</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <p>No drives found. <a href="/settings/scan">Scan for drives</a></p>
        }
        <h3 class="mt-3">Hardware Encoders</h3>
        @{
            var encoderList = ViewBag.HardwareEncoders as System.Collections.IList;
            var hasEncoders = encoderList is { Count: > 0 }
                && encoderList[0] is Dictionary<string, object> first
                && (!first.TryGetValue("available", out var a) || a is not false);
        }
        @if (!hasEncoders)
        {
            <p class="text-muted">No hardware encoders detected.</p>
        }
        else
        {
            foreach (Dictionary<string, object> enc in encoderList!)
            {
                <div class="card mb-2">
                    <div class="card-body py-2">
                        <strong>@enc["vendor"] @enc["type"]</strong>
                        @if (enc.TryGetValue("index", out var idx) && enc.TryGetValue("gpu", out var gpu))
                        {
                            <span class="text-muted">#@idx — @gpu</span>
                        }
                        else if (enc.TryGetValue("gpu", out var gpu2))
                        {
                            <span class="text-muted"> — @gpu2</span>
                        }
                        <table class="table table-sm mb-0 mt-1">
                            @if (enc.TryGetValue("driver", out var drv))
                            {
                                <tr><td class="w-25">Driver</td><td>@drv</td></tr>
                            }
                            @if (enc.TryGetValue("compute_cap", out var cc))
                            {
                                <tr><td>Compute Capability</td><td>@cc</td></tr>
                            }
                            @if (enc.TryGetValue("encoder_util", out var util))
                            {
                                <tr><td>Encoder Utilization</td><td>@util</td></tr>
                            }
                            @if (enc.TryGetValue("sessions", out var sess))
                            {
                                <tr><td>Active Sessions</td><td>@sess</td></tr>
                            }
                            @if (enc.TryGetValue("avg_fps", out var fps))
                            {
                                <tr><td>Average FPS</td><td>@fps</td></tr>
                            }
                            @if (enc.TryGetValue("avg_latency", out var lat))
                            {
                                <tr><td>Average Latency</td><td>@lat</td></tr>
                            }
                            @if (enc.TryGetValue("codecs", out var codecsObj) && codecsObj is List<string> codecs)
                            {
                                <tr><td>Codecs</td><td>@string.Join(", ", codecs)</td></tr>
                            }
                            @if (enc.TryGetValue("note", out var note))
                            {
                                <tr><td class="text-warning">Note</td><td class="text-warning">@note</td></tr>
                            }
                        </table>
                    </div>
                </div>
            }
        }

        <h3 class="mt-3">Statistics</h3>
        <table class="table table-sm">
            <tr><td>Total Rips:</td><td>@(stats?["total_rips"] ?? 0)</td></tr>
            <tr><td>Failed:</td><td>@(stats?["failed_rips"] ?? 0)</td></tr>
            <tr><td>Movies:</td><td>@(stats?["movies"] ?? 0)</td></tr>
            <tr><td>Series:</td><td>@(stats?["series"] ?? 0)</td></tr>
        </table>
    </div>

    <!-- Ripper Settings -->
    <div class="tab-pane fade" id="tab3" role="tabpanel">
        @{
            var tips = new Dictionary<string, string>
            {
                ["RipMethod"] = "Which program to use: mkv (MakeMKV), backup, or abcde",
                ["MkvArgs"] = "Extra arguments passed to makemkvcon (e.g. --decrypt)",
                ["MinLength"] = "Shortest track length in seconds to include",
                ["MaxLength"] = "Longest track length in seconds (99999 = no limit)",
                ["MainFeature"] = "Rip only the main feature (longest track)",
                ["SkipTranscode"] = "Skip video transcoding; keep raw MakeMKV output",
                ["UseFfmpeg"] = "Use FFmpeg instead of HandBrake for transcoding",
                ["AutoEject"] = "Automatically eject disc after processing",
                ["HbPresetDvd"] = "HandBrake preset name for DVD encodes",
                ["HbPresetBd"] = "HandBrake preset name for Blu-ray encodes",
                ["DestExt"] = "Output file extension (mp4, mkv, etc.)",
            };
            static string tip(string key, Dictionary<string, string> tips) =>
                $"<span class=\"text-info ml-1\" data-toggle=\"tooltip\" title=\"{tips[key]}\" style=\"cursor:help\">&#9432;</span>";
        }
        <h2>Ripper Settings</h2>
        <form method="post" action="/settings/save-ripper">
            <table class="table table-sm">
                <tr><td class="w-25"><label>Rip Method:</label>@Html.Raw(tip("RipMethod", tips))</td><td><input type="text" name="RipMethod" value="@armSettings?.RipMethod" class="form-control" /></td></tr>
                <tr><td><label>MKV Args:</label>@Html.Raw(tip("MkvArgs", tips))</td><td><input type="text" name="MkvArgs" value="@armSettings?.MkvArgs" class="form-control" /></td></tr>
                <tr><td><label>Min Length:</label>@Html.Raw(tip("MinLength", tips))</td><td><input type="number" name="MinLength" value="@armSettings?.MinLength" class="form-control" /></td></tr>
                <tr><td><label>Max Length:</label>@Html.Raw(tip("MaxLength", tips))</td><td><input type="number" name="MaxLength" value="@armSettings?.MaxLength" class="form-control" /></td></tr>
                <tr><td><label>Main Feature:</label>@Html.Raw(tip("MainFeature", tips))</td><td><input type="checkbox" name="MainFeature" value="true" checked="@armSettings?.MainFeature" /></td></tr>
                <tr><td><label>Skip Transcode:</label>@Html.Raw(tip("SkipTranscode", tips))</td><td><input type="checkbox" name="SkipTranscode" value="true" checked="@armSettings?.SkipTranscode" /></td></tr>
                <tr><td><label>Use FFmpeg:</label>@Html.Raw(tip("UseFfmpeg", tips))</td><td><input type="checkbox" name="UseFfmpeg" value="true" checked="@armSettings?.UseFfmpeg" /></td></tr>
                <tr><td><label>Auto Eject:</label>@Html.Raw(tip("AutoEject", tips))</td><td><input type="checkbox" name="AutoEject" value="true" checked="@armSettings?.AutoEject" /></td></tr>
                <tr><td><label>HB Preset DVD:</label>@Html.Raw(tip("HbPresetDvd", tips))</td><td><input type="text" name="HbPresetDvd" value="@armSettings?.HbPresetDvd" class="form-control" /></td></tr>
                <tr><td><label>HB Preset BD:</label>@Html.Raw(tip("HbPresetBd", tips))</td><td><input type="text" name="HbPresetBd" value="@armSettings?.HbPresetBd" class="form-control" /></td></tr>
                <tr><td><label>Dest Ext:</label>@Html.Raw(tip("DestExt", tips))</td><td><input type="text" name="DestExt" value="@armSettings?.DestExt" class="form-control" /></td></tr>
            </table>
            <button type="submit" class="btn btn-primary">Save Ripper Settings</button>
        </form>
    </div>

    <!-- UI Settings -->
    <div class="tab-pane fade" id="tab4" role="tabpanel">
        <h2>UI Settings</h2>
        <form method="post" action="/settings/save-ui">
            @Html.AntiForgeryToken()
            <table class="table table-sm">
                <tr>
                    <td><label>Theme:</label></td>
                    <td>
                        <select name="theme" class="form-control">
                            <option value="light" selected="@(uiSettings?.Theme == "light" || uiSettings?.Theme is null)">Light</option>
                            <option value="dark" selected="@(uiSettings?.Theme == "dark")">Dark</option>
                        </select>
                    </td>
                </tr>
                <tr>
                    <td><label>Refresh Rate (seconds):</label></td>
                    <td><input type="number" name="refreshRate" value="@(uiSettings?.RefreshRate ?? 10)" class="form-control" min="2" max="300" /></td>
                </tr>
                <tr>
                    <td><label>Icon Style:</label></td>
                    <td>
                        <select name="iconStyle" class="form-control">
                            <option value="default" selected="@(uiSettings?.IconStyle == "default" || uiSettings?.IconStyle is null)">Default</option>
                            <option value="simple" selected="@(uiSettings?.IconStyle == "simple")">Simple</option>
                            <option value="detailed" selected="@(uiSettings?.IconStyle == "detailed")">Detailed</option>
                        </select>
                    </td>
                </tr>
            </table>
            <button type="submit" class="btn btn-primary">Save UI Settings</button>
        </form>
    </div>

    <!-- abcde Config -->
    <div class="tab-pane fade" id="tab5" role="tabpanel">
        <h2>abcde Config</h2>
        <p>Configuration for audio CD ripping via abcde. Saved to <code>/etc/arm/config/abcde.conf</code>.</p>
        <form method="post" action="/settings/save-abcde">
            @Html.AntiForgeryToken()
            <table class="table table-sm">
                <tr>
                    <td><label>Output Format:</label></td>
                    <td>
                        <select name="outputFormat" class="form-control">
                            <option value="ogg" selected="@(abcdeConfig.GetValueOrDefault("OUTPUTTYPE") == "ogg")">OGG</option>
                            <option value="mp3" selected="@(abcdeConfig.GetValueOrDefault("OUTPUTTYPE") == "mp3")">MP3</option>
                            <option value="flac" selected="@(abcdeConfig.GetValueOrDefault("OUTPUTTYPE") == "flac")">FLAC</option>
                            <option value="aac" selected="@(abcdeConfig.GetValueOrDefault("OUTPUTTYPE") == "aac")">AAC</option>
                            <option value="wav" selected="@(abcdeConfig.GetValueOrDefault("OUTPUTTYPE") == "wav")">WAV</option>
                        </select>
                    </td>
                </tr>
                <tr>
                    <td><label>Output Directory:</label></td>
                    <td><input type="text" name="outputDir" value="@(abcdeConfig.GetValueOrDefault("OUTPUTDIR", "/home/arm/media/raw"))" class="form-control" /></td>
                </tr>
            </table>
            <button type="submit" class="btn btn-primary">Save abcde Config</button>
        </form>
        <div class="mt-3">
            <h4>Current Config</h4>
            <pre class="bg-light p-2"><code>@foreach (var kv in abcdeConfig)
{
    <text>@kv.Key=@kv.Value
</text>
}</code></pre>
        </div>
    </div>

    <!-- Apprise Config -->
    <div class="tab-pane fade" id="tab6" role="tabpanel">
        <h2>Apprise Notification Config</h2>
        <p>Notification channels configured via ArmSettings:</p>
        <table class="table table-sm">
            <tr><td>Pushbullet Key:</td><td>@(armSettings?.PbKey is not null ? "****" : "Not set")</td></tr>
            <tr><td>IFTTT Key:</td><td>@(armSettings?.IftttKey is not null ? "****" : "Not set")</td></tr>
            <tr><td>Bash Script:</td><td>@(armSettings?.BashScript ?? "Not set")</td></tr>
            <tr><td>JSON URL:</td><td>@(armSettings?.JsonUrl ?? "Not set")</td></tr>
        </table>
    </div>

    <!-- Help -->
    <div class="tab-pane fade" id="tab7" role="tabpanel">
        <h2>Help</h2>
        <p>ARM .NET Port — <a href="https://github.com/automatic-ripping-machine/automatic-ripping-machine">Automatic Ripping Machine</a></p>
        <p>View modes:</p>
        <ul>
            <li><strong>tail:</strong> Real-time log output, auto-scrolls</li>
            <li><strong>arm:</strong> Only ARM-prefixed log entries</li>
            <li><strong>full:</strong> Complete log including tool output</li>
            <li><strong>download:</strong> Download raw log file</li>
        </ul>
        <p>API endpoints:</p>
        <ul>
            <li><code>GET /api/health</code> — Health check</li>
            <li><code>GET /api/jobs</code> — Recent jobs</li>
            <li><code>GET /api/stats</code> — Job statistics</li>
            <li><code>POST /api/abandon/{id}</code> — Abandon a job</li>
            <li><code>POST /api/change-params</code> — Change job params</li>
            <li><code>GET /api/log?jobId={id}</code> — Get job log</li>
        </ul>
    </div>
</div>

</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('[data-toggle="tooltip"]').tooltip();
            var lastTab = sessionStorage.getItem('armSettingsTab');
            if (lastTab) {
                $('#settingsTabs a[href="' + lastTab + '"]').tab('show');
            }
            $('#settingsTabs a[data-toggle="tab"]').on('shown.bs.tab', function () {
                sessionStorage.setItem('armSettingsTab', $(this).attr('href'));
            });

            document.getElementById('settingsPage').addEventListener('submit', function (e) {
                var form = e.target;
                var confirmMsg = form.getAttribute('data-confirm');
                if (confirmMsg && !confirm(confirmMsg)) {
                    e.preventDefault();
                    return;
                }
                if (form.tagName !== 'FORM') return;
                e.preventDefault();
                fetch(form.action, {
                    method: form.method,
                    body: new FormData(form),
                    redirect: 'follow'
                })
                    .then(function (r) { return r.text(); })
                    .then(function (html) { replaceSettingsContent(html); })
                    .catch(function () {});
            });

            document.getElementById('settingsPage').addEventListener('click', function (e) {
                var link = e.target.closest('a');
                if (!link) return;
                if (link.getAttribute('data-toggle')) return;
                var href = link.getAttribute('href');
                if (!href || !href.startsWith('/settings/')) return;
                e.preventDefault();
                fetch(href, { redirect: 'follow' })
                    .then(function (r) { return r.text(); })
                    .then(function (html) { replaceSettingsContent(html); })
                    .catch(function () {});
            });

            function replaceSettingsContent(html) {
                var parser = new DOMParser();
                var doc = parser.parseFromString(html, 'text/html');
                var newContent = doc.getElementById('settingsPage');
                if (!newContent) return;
                document.getElementById('settingsPage').innerHTML = newContent.innerHTML;
                var lastTab = sessionStorage.getItem('armSettingsTab');
                if (lastTab) {
                    $('#settingsTabs a[href="' + lastTab + '"]').tab('show');
                }
                $('[data-toggle="tooltip"]').tooltip();
            }
        });
    </script>
}

