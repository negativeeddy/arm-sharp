    <!-- Apprise -->
    <div class="tab-pane fade @(ViewBag.ActiveTab == "tab6" ? "show active" : "")" id="tab6" role="tabpanel">
        <h2>Apprise / Push Notifications</h2>
        <form method="post" action="/settings/save-notifications">
            <div class="card mb-3">
                <div class="card-header"><h5 class="mb-0">Notification Services</h5></div>
                <div class="card-body">
                    <table class="table table-sm mb-0">
                        <tr><td class="w-25"><label for="PbKey">Pushbullet Key:</label></td>
                            <td><input type="text" class="form-control" id="PbKey" name="PbKey" value="@(armSettings?.PbKey ?? "")" /></td></tr>
                        <tr><td><label for="IftttKey">IFTTT Key:</label></td>
                            <td><input type="text" class="form-control" id="IftttKey" name="IftttKey" value="@(armSettings?.IftttKey ?? "")" /></td></tr>
                        <tr><td><label for="PoUserKey">Pushover User Key:</label></td>
                            <td><input type="text" class="form-control" id="PoUserKey" name="PoUserKey" value="@(armSettings?.PoUserKey ?? "")" /></td></tr>
                        <tr><td><label for="BashScript">Bash Script:</label></td>
                            <td><input type="text" class="form-control" id="BashScript" name="BashScript" value="@(armSettings?.BashScript ?? "")" /></td></tr>
                        <tr><td><label for="JsonUrl">JSON URL:</label></td>
                            <td><input type="text" class="form-control" id="JsonUrl" name="JsonUrl" value="@(armSettings?.JsonUrl ?? "")" /></td></tr>
                        <tr><td><label for="Apprise">Apprise Config:</label></td>
                            <td><input type="text" class="form-control" id="Apprise" name="Apprise" value="@(armSettings?.Apprise ?? "")" /></td></tr>
                    </table>
                </div>
            </div>

            <button type="submit" class="btn btn-primary">Save Notification Settings</button>
            <button type="submit" class="btn btn-outline-warning ml-2" form="resetForm">↻ Reset to file defaults</button>
        </form>
    </div>

    <script>
        function escHtml(str) {
            var div = document.createElement("div");
            div.appendChild(document.createTextNode(str));
            return div.innerHTML;
        }

        function toggleFieldVisibility(id) {
            var input = document.getElementById(id);
            input.type = input.type === "password" ? "text" : "password";
        }

        function sendPendingMovies() {
            var btn = document.getElementById("sendMoviesBtn");
            var progress = document.getElementById("sendMoviesProgress");
            var bar = document.getElementById("sendMoviesProgressBar");
            var status = document.getElementById("sendMoviesStatus");
            var results = document.getElementById("sendMoviesResults");

            btn.disabled = true;
            progress.style.display = "block";
            bar.style.width = "50%";
            status.textContent = "Sending...";

            fetch("/api/submit-crc/pending", { method: "POST" })
                .then(function (r) { return r.json(); })
                .then(function (data) {
                    bar.style.width = "100%";
                    bar.classList.remove("progress-bar-animated", "progress-bar-striped");
                    if (data.success && data.failed === 0) {
                        bar.classList.add("bg-success");
                    } else if (data.failed > 0) {
                        bar.classList.add("bg-warning");
                    } else {
                        bar.classList.add("bg-danger");
                    }
                    if (data.success) {
                        var added = 0, alreadyExists = 0, skipped = 0, failed = 0;
                        data.results.forEach(function (r) {
                            if (r.status === "added") added++;
                            else if (r.status === "already_exists") alreadyExists++;
                            else if (r.status === "skipped") skipped++;
                            else failed++;
                        });
                        var parts = [];
                        if (added > 0) parts.push(added + " added");
                        if (alreadyExists > 0) parts.push(alreadyExists + " already in DB");
                        if (skipped > 0) parts.push(skipped + " skipped");
                        if (failed > 0) parts.push(failed + " failed");
                        status.textContent = parts.join(", ") || "No movies to send.";

                        var html = "";
                        data.results.forEach(function (r) {
                            var icon, color;
                            if (r.status === "added") {
                                icon = "&#9989;"; color = "text-success";
                            } else if (r.status === "already_exists") {
                                icon = "&#128204;"; color = "text-info";
                            } else if (r.status === "skipped") {
                                icon = "&#9193;"; color = "text-secondary";
                            } else {
                                icon = "&#10060;"; color = "text-danger";
                            }
                            var tipTitle = r.status === "added" ? "Successfully added to database"
                                : r.status === "already_exists" ? "Already in the database"
                                : r.status === "skipped" ? "Already submitted locally"
                                : r.message || "Submission failed";
                            html += "<div class='d-inline-block mr-2 mb-1' title=''>" +
                                "<span class='" + color + "' data-toggle='tooltip' title='" + escHtml(tipTitle) + "'>" + icon + "</span>" +
                                " Job #" + r.jobId + "</div>";
                        });
                        results.innerHTML = html;
                        $('[data-toggle="tooltip"]').tooltip();

                        // Update the button text and disable if nothing left
                        btn.textContent = "🚀 Send " + failed + " Pending Movies";
                        if (failed === 0) btn.disabled = true;
                    } else {
                        status.textContent = "Failed to send: " + (data.error || "Unknown error");
                    }
                })
                .catch(function (err) {
                    bar.style.width = "0%";
                    bar.classList.remove("progress-bar-animated", "progress-bar-striped");
                    bar.classList.add("bg-danger");
                    status.textContent = "Error: " + err.message;
                })
                .finally(function () {
                    btn.disabled = false;
                });
        }

        function sendPendingOvid() {
            var btn = document.getElementById("sendOvidBtn");
            var progress = document.getElementById("sendOvidProgress");
            var bar = document.getElementById("sendOvidProgressBar");
            var status = document.getElementById("sendOvidStatus");
            var results = document.getElementById("sendOvidResults");

            btn.disabled = true;
            progress.style.display = "block";
            bar.style.width = "50%";
            status.textContent = "Sending...";

            fetch("/api/submit-ovid/pending", { method: "POST" })
                .then(function (r) { return r.json(); })
                .then(function (data) {
                    bar.style.width = "100%";
                    bar.classList.remove("progress-bar-animated", "progress-bar-striped");
                    if (data.success && data.failed === 0) {
                        bar.classList.add("bg-success");
                    } else if (data.failed > 0) {
                        bar.classList.add("bg-warning");
                    } else {
                        bar.classList.add("bg-danger");
                    }
                    if (data.success) {
                        var registered = 0, alreadyExists = 0, skipped = 0, failed = 0;
                        data.results.forEach(function (r) {
                            if (r.status === "registered") registered++;
                            else if (r.status === "already_exists") alreadyExists++;
                            else if (r.status === "skipped") skipped++;
                            else failed++;
                        });
                        var parts = [];
                        if (registered > 0) parts.push(registered + " registered");
                        if (alreadyExists > 0) parts.push(alreadyExists + " already in OVID");
                        if (skipped > 0) parts.push(skipped + " skipped");
                        if (failed > 0) parts.push(failed + " failed");
                        status.textContent = parts.join(", ") || "No fingerprints to send.";

                        var html = "";
                        data.results.forEach(function (r) {
                            var icon, color;
                            if (r.status === "registered") {
                                icon = "&#9989;"; color = "text-success";
                            } else if (r.status === "already_exists") {
                                icon = "&#128204;"; color = "text-info";
                            } else if (r.status === "skipped") {
                                icon = "&#9193;"; color = "text-secondary";
                            } else {
                                icon = "&#10060;"; color = "text-danger";
                            }
                            var tipTitle = r.status === "registered" ? "Successfully registered with OVID"
                                : r.status === "already_exists" ? "Already in the OVID database"
                                : r.status === "skipped" ? "Already submitted locally"
                                : r.message || "Submission failed";
                            html += "<div class='d-inline-block mr-2 mb-1' title=''>" +
                                "<span class='" + color + "' data-toggle='tooltip' title='" + escHtml(tipTitle) + "'>" + icon + "</span>" +
                                " Job #" + r.jobId + "</div>";
                        });
                        results.innerHTML = html;
                        $('[data-toggle="tooltip"]').tooltip();

                        btn.textContent = "Send " + failed + " Pending Fingerprints";
                        if (failed === 0) btn.disabled = true;
                    } else {
                        status.textContent = "Failed to send: " + (data.error || "Unknown error");
                    }
                })
                .catch(function (err) {
                    bar.style.width = "0%";
                    bar.classList.remove("progress-bar-animated", "progress-bar-striped");
                    bar.classList.add("bg-danger");
                    status.textContent = "Error: " + err.message;
                })
                .finally(function () {
                    btn.disabled = false;
                });
        }
    </script>

    <!-- Help -->
    <div class="tab-pane fade @(ViewBag.ActiveTab == "tab7" ? "show active" : "")" id="tab7" role="tabpanel">
