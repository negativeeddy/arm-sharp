@model IEnumerable<ArmRipper.Core.Models.Job>
@{
    ViewData["Title"] = "History - ARM";
}

<h1>Job History</h1>

<table class="table">
    <thead>
        <tr>
            <th>ID</th>
            <th>Title</th>
            <th>Disc Type</th>
            <th>Status</th>
            <th>Started</th>
            <th>Duration</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var job in Model)
        {
            <tr>
                <td>@job.Id</td>
                <td>@job.Title</td>
                <td>@job.DiscType</td>
                <td>@job.Status</td>
                <td>@job.StartTime.ToString("g")</td>
                <td>@job.JobLength</td>
                <td><a href="/jobs/jobdetail?jobId=@job.Id">View</a></td>
            </tr>
        }
    </tbody>
</table>
