@model IEnumerable<ArmRipper.Core.Models.Job>
@using ArmRipper.Core.Models
@{
    ViewData["Title"] = "History - ARM";
    var curPage = ViewBag.CurrentPage as int? ?? 1;
    var totalPages = ViewBag.TotalPages as int? ?? 1;
    var totalJobs = ViewBag.TotalJobs as int? ?? 0;
    var statusFilter = ViewBag.StatusFilter as string;
    var discTypeFilter = ViewBag.DiscTypeFilter as string;
    var searchFilter = ViewBag.SearchFilter as string;
    var niceTitleFilter = ViewBag.NiceTitleFilter as string;
}

<h1>Job History</h1>

<!-- Filter Form -->
<form method="get" action="/history" class="row g-3 mb-4 p-3 border rounded bg-light">
    <div class="col-md-2">
        <label for="search" class="form-label">Search Title</label>
        <input type="text" id="search" name="search" class="form-control" placeholder="Search by title..." value="@searchFilter" />
    </div>
    <div class="col-md-2">
        <label for="status" class="form-label">Status</label>
        <select id="status" name="status" class="form-select">
            <option value="">All</option>
            @foreach (var s in Enum.GetValues<JobState>())
            {
                var selected = string.Equals(statusFilter, s.ToString(), StringComparison.OrdinalIgnoreCase) ? "selected" : null;
                <option value="@s" selected="@selected">@s</option>
            }
        </select>
    </div>
    <div class="col-md-2">
        <label for="discType" class="form-label">Disc Type</label>
        <select id="discType" name="discType" class="form-select">
            <option value="">All</option>
            @foreach (var dt in Enum.GetValues<DiscType>())
            {
                var selected = string.Equals(discTypeFilter, dt.ToString(), StringComparison.OrdinalIgnoreCase) ? "selected" : null;
                <option value="@dt" selected="@selected">@dt</option>
            }
        </select>
    </div>
    <div class="col-md-2">
        <label for="niceTitle" class="form-label">Nice Title</label>
        <select id="niceTitle" name="niceTitle" class="form-select">
            <option value="">All</option>
            @{
                var ntTrue = string.Equals(niceTitleFilter, "true", StringComparison.OrdinalIgnoreCase) ? "selected" : null;
                var ntFalse = string.Equals(niceTitleFilter, "false", StringComparison.OrdinalIgnoreCase) ? "selected" : null;
            }
            <option value="true" selected="@ntTrue">✅ Yes</option>
            <option value="false" selected="@ntFalse">⚠️ No</option>
        </select>
    </div>
    <div class="col-md-2 d-flex align-items-end">
        <button type="submit" class="btn btn-primary me-2">Filter</button>
        <a href="/history" class="btn btn-outline-secondary">Clear</a>
    </div>
</form>

<p>Showing page <strong>@curPage</strong> of <strong>@totalPages</strong> (@totalJobs total jobs)</p>

@if (!Model.Any())
{
    <div class="alert alert-info">No jobs found.</div>
}
else
{
    <table class="table table-striped table-hover table-sm tablesorter">
        <thead>
            <tr>
                <th>ID</th>
                <th>Title</th>
                <th>Nice Title</th>
                <th>Disc Type</th>
                <th>Status</th>
                <th>Started</th>
                <th>Duration</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var job in Model)
            {
                <tr>
                    <td>@job.Id</td>
                    <td>@(job.TitleManual ?? job.Title ?? "Untitled")</td>
                    <td>
                        @if (job.HasNiceTitle)
                        {
                            <span class="text-success" title="Authoritative title confirmed">✅</span>
                        }
                        else if (!string.IsNullOrEmpty(job.Title) && !string.IsNullOrEmpty(job.Year))
                        {
                            <span class="text-warning" title="Title from fallback, needs review">⚠️</span>
                        }
                        else
                        {
                            <span class="text-danger" title="No title identified">❌</span>
                        }
                    </td>
                    <td>@job.DiscType</td>
                    <td>
                        @if (!string.IsNullOrEmpty(job.Warnings))
                        {
                            <span class="badge bg-warning text-dark" title="@job.Warnings">Warning</span>
                        }
                        else
                        {
                            @job.Status
                        }
                    </td>
                    <td>@job.StartTime.ToLocalTime().ToString("g")</td>
                    <td>@(job.JobLength ?? "—")</td>
                    <td><a href="/jobs/jobdetail?jobId=@job.Id" class="btn btn-sm btn-outline-primary">View</a></td>
                </tr>
            }
        </tbody>
    </table>
}

<nav aria-label="Page navigation">
    <ul class="pagination pagination-sm justify-content-center">
        <li class="page-item @(curPage <= 1 ? "disabled" : "")">
            <a class="page-link" href="/history?page=@(curPage - 1)@(string.IsNullOrEmpty(statusFilter) ? "" : "&status=" + statusFilter)@(string.IsNullOrEmpty(discTypeFilter) ? "" : "&discType=" + discTypeFilter)@(string.IsNullOrEmpty(searchFilter) ? "" : "&search=" + Uri.EscapeDataString(searchFilter))@(string.IsNullOrEmpty(niceTitleFilter) ? "" : "&niceTitle=" + niceTitleFilter)">&laquo; Prev</a>
        </li>
        @for (var p = 1; p <= totalPages; p++)
        {
            <li class="page-item @(p == curPage ? "active" : "")">
                <a class="page-link" href="/history?page=@p@(string.IsNullOrEmpty(statusFilter) ? "" : "&status=" + statusFilter)@(string.IsNullOrEmpty(discTypeFilter) ? "" : "&discType=" + discTypeFilter)@(string.IsNullOrEmpty(searchFilter) ? "" : "&search=" + Uri.EscapeDataString(searchFilter))@(string.IsNullOrEmpty(niceTitleFilter) ? "" : "&niceTitle=" + niceTitleFilter)">@p</a>
            </li>
        }
        <li class="page-item @(curPage >= totalPages ? "disabled" : "")">
            <a class="page-link" href="/history?page=@(curPage + 1)@(string.IsNullOrEmpty(statusFilter) ? "" : "&status=" + statusFilter)@(string.IsNullOrEmpty(discTypeFilter) ? "" : "&discType=" + discTypeFilter)@(string.IsNullOrEmpty(searchFilter) ? "" : "&search=" + Uri.EscapeDataString(searchFilter))@(string.IsNullOrEmpty(niceTitleFilter) ? "" : "&niceTitle=" + niceTitleFilter)">Next &raquo;</a>
        </li>
    </ul>
</nav>

@section Scripts {
<script>
    $(function () {
        $('.tablesorter').tablesorter({
            sortList: [[0,1]],
            headers: { 0: { sorter: 'digit' } }
        });
    });
</script>
}
