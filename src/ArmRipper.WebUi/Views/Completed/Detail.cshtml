@model CompletedFileInfo
@{
    ViewData["Title"] = Model.FileName;
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/completed">Output</a></li>
        <li class="breadcrumb-item active">@Model.FileName</li>
    </ol>
</nav>

<div class="card mb-4">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">@Model.FileName</h5>
        <a href="/completed?refresh=true" class="btn btn-outline-secondary btn-sm">← Back</a>
    </div>
    <div class="card-body">
        <div class="row">
            <div class="col-md-6">
                <table class="table table-sm table-borderless mb-0">
                    <tr><th class="w-25">Location</th><td>@Model.RelativeDirectory</td></tr>
                    <tr><th>Size</th><td>@Model.SizeFormatted</td></tr>
                    <tr><th>Duration</th><td>@Model.DurationFormatted</td></tr>
                    <tr><th>Overall Bitrate</th><td>@Model.BitrateKbps.ToString("N0") kbps</td></tr>
                    <tr><th>Source</th><td>@Model.Source</td></tr>
                    @if (Model.JobId.HasValue)
                    {
                        <tr>
                            <th>Job</th>
                            <td>
                                <a href="/jobs/jobdetail?jobId=@Model.JobId.Value">#@Model.JobId.Value</a>
                                @if (!string.IsNullOrEmpty(Model.JobTitle))
                                {
                                    <span class="text-muted ml-2">@Model.JobTitle</span>
                                }
                            </td>
                        </tr>
                    }
                </table>
            </div>
            <div class="col-md-6 text-right">
                <code class="text-muted" style="font-size:0.75rem;">@Model.FilePath</code>
            </div>
        </div>
    </div>
</div>

@if (Model.Video != null)
{
    <div class="card mb-4">
        <div class="card-header"><h5 class="mb-0">🎬 Video Stream</h5></div>
        <div class="card-body">
            <table class="table table-sm">
                <tr><th style="width:180px;">Codec</th><td>@Model.Video.CodecName</td></tr>
                <tr><th>Profile</th><td>@Model.Video.Profile</td></tr>
                <tr><th>Resolution</th><td>@Model.Video.Width × @Model.Video.Height</td></tr>
                <tr><th>Pixel Format</th><td>@Model.Video.PixelFormat</td></tr>
                <tr><th>Frame Rate</th><td>@Model.Video.FrameRate fps</td></tr>
                <tr><th>Color Space</th><td>@Model.Video.ColorSpace</td></tr>
                <tr><th>Color Transfer</th><td>@Model.Video.ColorTransfer</td></tr>
                <tr><th>HDR</th><td>@(Model.Video.IsHdr ? "✅ Yes" : "—")</td></tr>
                <tr><th>B-frames</th><td>@(Model.Video.BFrames.HasValue ? Model.Video.BFrames.Value.ToString() : "—")</td></tr>
            </table>
        </div>
    </div>
}

<div class="card mb-4">
    <div class="card-header"><h5 class="mb-0">🔊 Audio Streams</h5></div>
    <div class="card-body p-0">
        @if (Model.AudioStreams.Any())
        {
            <div class="table-responsive">
                <table class="table table-sm mb-0">
                    <thead class="thead-light">
                        <tr>
                            <th>#</th>
                            <th>Codec</th>
                            <th>Channels</th>
                            <th>Layout</th>
                            <th>Sample Rate</th>
                            <th>Bitrate</th>
                            <th>Language</th>
                            <th>Title</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (var i = 0; i < Model.AudioStreams.Count; i++)
                        {
                            var a = Model.AudioStreams[i];
                            <tr>
                                <td>@(i + 1)</td>
                                <td title="@a.CodecLongName">@a.CodecName</td>
                                <td>@a.Channels</td>
                                <td><code>@a.ChannelLayout</code></td>
                                <td>@(a.SampleRate > 0 ? $"{a.SampleRate / 1000.0:F1} kHz" : "—")</td>
                                <td>@a.BitrateFormatted</td>
                                <td>@(string.IsNullOrEmpty(a.Language) ? "—" : a.Language)</td>
                                <td>@(string.IsNullOrEmpty(a.Title) ? "—" : a.Title)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="p-3 text-muted">No audio streams</div>
        }
    </div>
</div>

<div class="card mb-4">
    <div class="card-header"><h5 class="mb-0">💬 Subtitle Streams</h5></div>
    <div class="card-body p-0">
        @if (Model.SubtitleStreams.Any())
        {
            <div class="table-responsive">
                <table class="table table-sm mb-0">
                    <thead class="thead-light">
                        <tr>
                            <th>#</th>
                            <th>Codec</th>
                            <th>Language</th>
                            <th>Forced</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (var i = 0; i < Model.SubtitleStreams.Count; i++)
                        {
                            var s = Model.SubtitleStreams[i];
                            <tr>
                                <td>@(i + 1)</td>
                                <td>@s.CodecName</td>
                                <td>@(string.IsNullOrEmpty(s.Language) ? "—" : s.Language)</td>
                                <td>@(s.Forced ? "✅" : "—")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="p-3 text-muted">No subtitle streams</div>
        }
    </div>
</div>

<div class="mt-3">
    <a href="/completed?refresh=true" class="btn btn-outline-primary">🔄 Refresh All</a>
</div>

@section Scripts {
    <script>
        $(function () {
            $("table").tablesorter();
        });
    </script>
}
