@model CompletedFileInfo
@{
    ViewData["Title"] = $"Playing - {Model.FileName}";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/css/bootstrap.min.css" integrity="sha384-xOolHFLEh07PJGoPkLv1IbcEPTNtaed2xpHsD9ESMhqIYd0nLMwNLD69Npy4HI+N" crossorigin="anonymous">
    <style>
        body {
            background-color: #1a1a1a;
            color: #fff;
            margin: 0;
            padding: 0;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
        }
        .player-container {
            width: 100%;
            height: 100vh;
            display: flex;
            flex-direction: column;
            background-color: #000;
        }
        .video-wrapper {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            background-color: #000;
            position: relative;
        }
        video {
            width: 100%;
            height: 100%;
            max-width: 100%;
            max-height: 100%;
        }
        .controls-bar {
            background-color: #222;
            padding: 1rem;
            border-top: 1px solid #444;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .file-info {
            flex: 1;
            min-width: 0;
        }
        .file-name {
            font-size: 1rem;
            margin: 0;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            margin-bottom: 0.25rem;
        }
        .file-meta {
            font-size: 0.85rem;
            color: #aaa;
            margin: 0;
        }
        .controls-buttons {
            display: flex;
            gap: 0.5rem;
            align-items: center;
        }
        .btn-group-player {
            display: flex;
            gap: 0.5rem;
        }
        .btn-player {
            padding: 0.4rem 0.8rem;
            font-size: 0.9rem;
            white-space: nowrap;
        }
        .stream-info {
            font-size: 0.8rem;
            color: #aaa;
            display: flex;
            gap: 1rem;
            flex-wrap: wrap;
            justify-content: flex-end;
        }
        .stream-info-item {
            display: flex;
            align-items: center;
            gap: 0.25rem;
        }
        .badge-stream {
            display: inline-block;
            background-color: #28a745;
            color: white;
            padding: 0.25rem 0.5rem;
            border-radius: 0.25rem;
            font-size: 0.75rem;
            margin-left: 0.5rem;
        }
    </style>
</head>
<body>
    <div class="player-container">
        <div class="video-wrapper">
            <video controls controlsList="nodownload">
                <source src="/completed/stream?filePath=@Uri.EscapeDataString(Model.FilePath)" type="video/mp4">
                Your browser does not support the video tag.
            </video>
        </div>
        <div class="controls-bar">
            <div class="file-info">
                <p class="file-name">▶️ @Model.FileName</p>
                <p class="file-meta">
                    @if (Model.Video != null)
                    {
                        <span>@Model.Video.Width×@Model.Video.Height</span>
                        <span class="mx-2">•</span>
                        <span>@Model.DurationFormatted</span>
                        <span class="mx-2">•</span>
                        <span>@Model.SizeFormatted</span>
                    }
                    else
                    {
                        <span>@Model.DurationFormatted • @Model.SizeFormatted</span>
                    }
                </p>
            </div>
            <div class="controls-buttons">
                <div class="stream-info">
                    @if (Model.Video != null)
                    {
                        <div class="stream-info-item">
                            <strong>Video:</strong>
                            <span title="@Model.Video.CodecLongName">@Model.Video.CodecName</span>
                            @if (Model.Video.IsHdr)
                            {
                                <span class="badge-stream">HDR</span>
                            }
                        </div>
                    }
                    @if (Model.AudioStreams.Count > 0)
                    {
                        var first = Model.AudioStreams[0];
                        <div class="stream-info-item">
                            <strong>Audio:</strong>
                            <span title="@first.CodecLongName">@first.CodecName</span>
                            @if (!string.IsNullOrEmpty(first.Language))
                            {
                                <span>(@first.Language)</span>
                            }
                        </div>
                    }
                </div>
                <div class="btn-group-player">
                    <a href="/completed?@(ViewBag.BackPage != null ? $"page={ViewBag.BackPage}" : "")" class="btn btn-sm btn-secondary btn-player">← Back</a>
                </div>
            </div>
        </div>
    </div>

    <script>
        // Auto-focus video element for keyboard controls
        document.querySelector('video').focus();
    </script>
</body>
</html>
