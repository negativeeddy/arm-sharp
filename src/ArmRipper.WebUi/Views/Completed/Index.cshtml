@model List<CompletedFileInfo>
@{
    ViewData["Title"] = "Output Files";
    string TopLevelDir(string? relativePath)
    {
        if (string.IsNullOrEmpty(relativePath)) return "Other";
        var parts = relativePath.Split('/', '\\');
        return parts.Length > 0 && !string.IsNullOrEmpty(parts[0])
            ? char.ToUpper(parts[0][0]) + parts[0][1..]
            : "Other";
    }
    var sourceGroups = Model.GroupBy(f => f.Source)
        .OrderBy(g => g.Key == "Output" ? 0 : g.Key == "Transcode" ? 1 : 2)
        .ToList();
    var totalFiles = Model.Count;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">Output Files</h1>
    <div>
        <span class="text-muted mr-2">@totalFiles file@(totalFiles != 1 ? "s" : "")</span>
        <a href="/completed?refresh=true" class="btn btn-outline-secondary btn-sm">🔄 Refresh</a>
    </div>
</div>

@if (TempData["SuccessMessage"] is string successMsg)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @successMsg
        <button type="button" class="close" data-dismiss="alert">&times;</button>
    </div>
}
@if (TempData["ErrorMessage"] is string errorMsg)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @errorMsg
        <button type="button" class="close" data-dismiss="alert">&times;</button>
    </div>
}

@if (!Model.Any())
{
    <div class="alert alert-info">No video files found in any output directory.</div>
}
else
{
    foreach (var sourceGroup in sourceGroups)
    {
        var sourceIcon = sourceGroup.Key switch
        {
            "Output" => "✅",
            "Raw" => "📦",
            "Transcode" => "⚙️",
            _ => "📁"
        };
        var sourceDesc = sourceGroup.Key switch
        {
            "Output" => "Completed, ready-to-play files",
            "Raw" => "Unprocessed MakeMKV rips",
            "Transcode" => "In-progress or partially transcoded files",
            _ => ""
        };
        var subGroups = sourceGroup.GroupBy(f => TopLevelDir(f.RelativeDirectory))
            .OrderByDescending(g => g.Sum(f => f.SizeBytes))
            .ToList();

        <div class="mb-4">
            <h4 class="mb-2">@sourceIcon @sourceGroup.Key <small class="text-muted">@sourceDesc</small></h4>

            @foreach (var group in subGroups)
            {
                var groupSize = group.Sum(f => f.SizeBytes);
                var groupSizeStr = groupSize switch
                {
                    >= 1_000_000_000 => $"{groupSize / 1_000_000_000.0:F2} GB",
                    >= 1_000_000 => $"{groupSize / 1_000_000.0:F1} MB",
                    _ => $"{groupSize / 1_000.0:F0} KB"
                };

                <div class="card mb-3">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">
                            @group.Key
                            <small class="text-muted ml-2">@group.Count() file@(group.Count() != 1 ? "s" : "")</small>
                        </h5>
                        <span class="text-muted">@groupSizeStr</span>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover table-sortable mb-0 group-table">
                                <thead class="thead-light">
                                    <tr>
                                        <th>File</th>
                                        <th>Date</th>
                                        <th>Directory</th>
                                        <th>Size</th>
                                        <th>Duration</th>
                                        <th>Video</th>
                                        <th>Resolution</th>
                                        <th>Audio</th>
                                        <th>HDR</th>
                                        <th class="sorter-false"></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var file in group)
                                    {
                                        <tr>
                                            <td>
                                                <a href="/completed/probe?filePath=@Uri.EscapeDataString(file.FilePath)" class="font-weight-bold">
                                                    @file.FileName
                                                </a>
                                            </td>
                                            <td data-order="@file.LastModified.ToString("O")"><small class="text-muted">@file.LastModifiedFormatted</small></td>
                                            <td><small class="text-muted">@file.RelativeDirectory</small></td>
                                            <td data-order="@file.SizeBytes">@file.SizeFormatted</td>
                                            <td data-order="@file.DurationSeconds">@file.DurationFormatted</td>
                                            <td>
                                                @if (file.Video != null)
                                                {
                                                    <span title="@file.Video.CodecLongName">@file.Video.CodecName</span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">—</span>
                                                }
                                            </td>
                                            <td>
                                                @if (file.Video != null)
                                                {
                                                    <span>@file.Video.Width×@file.Video.Height</span>
                                                    @if (!string.IsNullOrEmpty(file.Video.PixelFormat))
                                                    {
                                                        <br /><small class="text-muted">@file.Video.PixelFormat</small>
                                                    }
                                                }
                                                else
                                                {
                                                    <span class="text-muted">—</span>
                                                }
                                            </td>
                                            <td>
                                                @if (file.AudioStreams.Count > 0)
                                                {
                                                    var first = file.AudioStreams[0];
                                                    <span title="@first.CodecLongName">@first.CodecName</span>
                                                    <span class="text-muted">· @first.Channels ch (@first.BitrateFormatted)</span>
                                                    @if (file.AudioStreams.Count > 1)
                                                    {
                                                        <br /><small class="text-muted">+@(file.AudioStreams.Count - 1) more</small>
                                                    }
                                                }
                                                else
                                                {
                                                    <span class="text-muted">—</span>
                                                }
                                            </td>
                                            <td>
                                                @if (file.Video?.IsHdr == true)
                                                {
                                                    <span class="badge badge-success">HDR</span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">—</span>
                                                }
                                            </td>
                                            <td class="text-right">
                                                @if (file.Source == "Raw")
                                                {
                                                    <form method="post" action="/completed/transcode" style="display:inline" class="mr-1">
                                                        <input type="hidden" name="filePath" value="@file.FilePath" />
                                                        @if (file.OriginalJobId.HasValue)
                                                        {
                                                            <input type="hidden" name="originalJobId" value="@file.OriginalJobId.Value" />
                                                        }
                                                        <button type="submit" class="btn btn-outline-success btn-sm" title="Start transcoding this raw file">🎬 Transcode</button>
                                                    </form>
                                                }
                                                <form method="post" action="/completed/delete" onsubmit="return confirm('Delete @file.FileName? This cannot be undone.');" style="display:inline">
                                                    <input type="hidden" name="filePath" value="@file.FilePath" />
                                                    <button type="submit" class="btn btn-outline-danger btn-sm" title="Delete file">🗑</button>
                                                </form>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
}

@section Scripts {
    <script>
        $(function () {
            $(".group-table").tablesorter({
                sortList: [[1, 1]] // sort by date descending (newest first) within each group
            });
        });
    </script>
}
