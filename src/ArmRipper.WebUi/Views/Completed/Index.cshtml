@model List<CompletedFileInfo>
@{
    ViewData["Title"] = "Output Files";
    var totalFiles = Model.Count;

    // Single flat list ordered by Source priority, then by directory, then by date desc.
    var sourceOrder = new Dictionary<string, int>(StringComparer.OrdinalIgnoreCase) { ["Output"] = 0, ["Transcode"] = 1, ["Raw"] = 2 };
    var ordered = Model
        .OrderBy(f => sourceOrder.TryGetValue(f.Source, out var o) ? o : 3)
        .ThenBy(f => f.RelativeDirectory)
        .ThenByDescending(f => f.LastModified)
        .ToList();
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">Output Files</h1>
    <div>
        <span class="text-muted mr-2">@totalFiles file@(totalFiles != 1 ? "s" : "")</span>
        <a href="/completed?refresh=true" class="btn btn-outline-secondary btn-sm">🔄 Refresh</a>
    </div>
</div>

@if (TempData["SuccessMessage"] is string successMsg)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @successMsg
        <button type="button" class="close" data-dismiss="alert">&times;</button>
    </div>
}
@if (TempData["ErrorMessage"] is string errorMsg)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @errorMsg
        <button type="button" class="close" data-dismiss="alert">&times;</button>
    </div>
}

@if (!Model.Any())
{
    <div class="alert alert-info">No video files found in any output directory.</div>
}
else
{
    var sourceIcons = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase)
    {
        ["Output"] = "✅",
        ["Raw"] = "📦",
        ["Transcode"] = "⚙️"
    };

    <div class="table-responsive">
        <table class="table table-hover table-sm mb-0 output-unified" style="table-layout:fixed; min-width:1100px;">
            <colgroup>
                <col style="width:18%;">
                <col style="width:7%;">
                <col style="width:10%;">
                <col style="width:6%;">
                <col style="width:7%;">
                <col style="width:7%;">
                <col style="width:7%;">
                <col style="width:11%;">
                <col style="width:4%;">
                <col style="width:10%;">
                <col style="width:13%;">
            </colgroup>
            <thead class="thead-light">
                <tr>
                    <th>File</th>
                    <th>Date</th>
                    <th>Directory</th>
                    <th>Size</th>
                    <th>Duration</th>
                    <th>Video</th>
                    <th>Resolution</th>
                    <th>Audio</th>
                    <th>HDR</th>
                    <th>Job</th>
                    <th class="text-right" style="padding-right: 2rem;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @{
                    string? lastSource = null;
                    string? lastDir = null;
                    long dirTotalSize = 0;
                }
                @foreach (var file in ordered)
                {
                    // Emit source divider row when source changes
                    if (file.Source != lastSource)
                    {
                        lastDir = null; // reset directory tracker
                        dirTotalSize = 0;
                        var icon = sourceIcons.TryGetValue(file.Source, out var ic) ? ic : "📁";
                        var desc = file.Source switch
                        {
                            "Output" => "Completed, ready-to-play files",
                            "Raw" => "Unprocessed MakeMKV rips",
                            "Transcode" => "In-progress or partially transcoded files",
                            _ => ""
                        };
                        <tr class="table-divider-source">
                            <td colspan="11">
                                <strong>@icon @file.Source</strong>
                                <small class="text-muted ml-2">@desc</small>
                            </td>
                        </tr>
                    }

                    // Emit directory divider row when directory changes within a source
                    if (file.RelativeDirectory != lastDir)
                    {
                        if (lastDir != null && dirTotalSize > 0)
                        {
                            // Close previous directory's total size
                            var sizeStr = dirTotalSize switch
                            {
                                >= 1_000_000_000 => $"{dirTotalSize / 1_000_000_000.0:F2} GB",
                                >= 1_000_000 => $"{dirTotalSize / 1_000_000.0:F1} MB",
                                _ => $"{dirTotalSize / 1_000.0:F0} KB"
                            };
                        }
                        dirTotalSize = 0;
                        var displayDir = string.IsNullOrEmpty(file.RelativeDirectory) ? "—" : file.RelativeDirectory;
                        <tr class="table-divider-dir">
                            <td colspan="11">
                                <span class="text-muted mr-2">📂</span>@displayDir
                            </td>
                        </tr>
                    }

                    dirTotalSize += file.SizeBytes;

                    lastSource = file.Source;
                    lastDir = file.RelativeDirectory;

                    // ── File row ──
                    <tr>
                        <td class="text-truncate" title="@file.FileName">
                            <a href="/completed/probe?filePath=@Uri.EscapeDataString(file.FilePath)" class="font-weight-bold">@file.FileName</a>
                        </td>
                        <td data-order="@file.LastModified.ToString("O")"><small class="text-muted">@file.LastModifiedFormatted</small></td>
                        <td class="text-truncate" title="@file.RelativeDirectory"><small class="text-muted">@file.RelativeDirectory</small></td>
                        <td data-order="@file.SizeBytes">@file.SizeFormatted</td>
                        <td data-order="@file.DurationSeconds">@file.DurationFormatted</td>
                        <td>
                            @if (file.Video != null)
                            {
                                <span title="@file.Video.CodecLongName">@file.Video.CodecName</span>
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </td>
                        <td>
                            @if (file.Video != null)
                            {
                                <span>@file.Video.Width×@file.Video.Height</span>
                                @if (!string.IsNullOrEmpty(file.Video.PixelFormat))
                                {
                                    <br /><small class="text-muted">@file.Video.PixelFormat</small>
                                }
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </td>
                        <td>
                            @if (file.AudioStreams.Count > 0)
                            {
                                var first = file.AudioStreams[0];
                                <span title="@first.CodecLongName">@first.CodecName</span>
                                <span class="text-muted">· @first.Channels ch (@first.BitrateFormatted)</span>
                                @if (file.AudioStreams.Count > 1)
                                {
                                    <br /><small class="text-muted">+@(file.AudioStreams.Count - 1) more</small>
                                }
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </td>
                        <td>
                            @if (file.Video?.IsHdr == true)
                            {
                                <span class="badge badge-success">HDR</span>
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </td>
                        <td>
                            @if (file.JobId.HasValue)
                            {
                                <a href="/jobs/jobdetail?jobId=@file.JobId.Value" class="btn btn-sm btn-outline-info" title="View job #@file.JobId.Value">#@file.JobId.Value</a>
                                if (!string.IsNullOrEmpty(file.JobTitle))
                                {
                                    <br /><small class="text-muted text-truncate d-inline-block" style="max-width:90px;" title="@file.JobTitle">@file.JobTitle</small>
                                }
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </td>
                        <td class="text-right text-nowrap" style="padding-right: 0.5rem;">
                            <button type="button" class="btn btn-outline-secondary btn-sm rename-btn mr-1"
                                    title="Rename file"
                                    style="padding:0.1rem 0.4rem; font-size:0.75rem;"
                                    data-filepath="@Uri.EscapeDataString(file.FilePath)"
                                    data-filename="@file.FileName">✏️</button>
                            @if (file.Source == "Raw")
                            {
                                <form method="post" action="/completed/transcode" style="display:inline" class="mr-1">
                                    <input type="hidden" name="filePath" value="@file.FilePath" />
                                    @{
                                        var transcodeJobId = file.OriginalJobId ?? file.JobId;
                                    }
                                    @if (transcodeJobId.HasValue)
                                    {
                                        <input type="hidden" name="originalJobId" value="@transcodeJobId.Value" />
                                    }
                                    <button type="submit" class="btn btn-outline-success btn-sm" title="Start transcoding this raw file" style="padding:0.1rem 0.4rem; font-size:0.75rem;">🎬</button>
                                </form>
                            }
                            <form method="post" action="/completed/delete" onsubmit="return confirm('Delete @file.FileName? This cannot be undone.');" style="display:inline">
                                <input type="hidden" name="filePath" value="@file.FilePath" />
                                <button type="submit" class="btn btn-outline-danger btn-sm" title="Delete file" style="padding:0.1rem 0.4rem; font-size:0.75rem;">🗑</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@section Scripts {
    <style>
        .table-divider-source td {
            background: #e9ecef !important;
            font-size: 0.9rem;
            padding: 0.5rem 0.75rem;
            border-bottom: 2px solid #adb5bd;
            font-weight: 600;
        }
        .table-divider-dir td {
            background: #f8f9fa !important;
            font-size: 0.8rem;
            padding: 0.3rem 0.75rem;
            color: #6c757d;
            border-bottom: 1px solid #dee2e6;
        }
        /* Dark mode overrides injected by arm.initDarkMode() */
        body.dark-mode .table-divider-source td {
            background: #2d3238 !important;
            border-bottom-color: #495057;
        }
        body.dark-mode .table-divider-dir td {
            background: #343a40 !important;
            border-bottom-color: #495057;
        }
    </style>

    <!-- Rename Modal -->
    <div class="modal fade" id="renameModal" tabindex="-1" role="dialog" aria-labelledby="renameModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered" role="document">
            <div class="modal-content">
                <form method="post" action="/completed/rename" id="renameForm">
                    <input type="hidden" name="filePath" id="renameFilePath" />
                    <div class="modal-header">
                        <h5 class="modal-title" id="renameModalLabel">Rename File</h5>
                        <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                            <span aria-hidden="true">&times;</span>
                        </button>
                    </div>
                    <div class="modal-body">
                        <div class="form-group mb-0">
                            <label for="renameInput" class="text-muted small">Current name:</label>
                            <code class="d-block mb-2" id="renameCurrentName"></code>
                            <label for="renameInput">New name</label>
                            <input type="text" class="form-control" id="renameInput" name="newName"
                                   autofocus required maxlength="255"
                                   placeholder="Enter new filename (keep extension)" />
                            <small class="form-text text-muted">The file will stay in the same directory.</small>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary">Rename</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script>
        $(function () {
            // Rename modal plumbing
            var $modal = $('#renameModal');
            var $filePath = $('#renameFilePath');
            var $currentName = $('#renameCurrentName');
            var $input = $('#renameInput');

            $(document).on('click', '.rename-btn', function () {
                var $btn = $(this);
                var fp = decodeURIComponent($btn.data('filepath'));
                var fn = $btn.data('filename');
                $filePath.val(fp);
                $currentName.text(fn);
                // Pre-fill input with current name (selected for easy replacement)
                $input.val(fn).select();
                $modal.modal('show');
            });

            // Auto-focus input when modal opens
            $modal.on('shown.bs.modal', function () {
                $input.trigger('focus').select();
            });
        });
    </script>
}
