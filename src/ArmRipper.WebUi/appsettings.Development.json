{
  "ConnectionStrings": {
    "ArmDb": "Data Source=./data/arm.db"
  },
  "Arm": {
    "RawPath": "./data/raw",
    "TranscodePath": "./data/transcode",
    "CompletedPath": "./data/completed",
    "LogPath": "./data/logs"
  },
  "Tmdb": {
    "ApiKey": ""
  },
  "Tvdb": {
    "ApiKey": "",
    "ApiBaseUrl": "https://api4.thetvdb.com/v4"
  },
  "Omdb": {
    "ApiKey": ""
  },
  "EpisodeIdentification": {
    "ProviderOrder": ["DiscDb", "FileBot", "Tmdb", "Tvdb", "Omdb", "PositionalFallback"],
    "ShortCircuitOnDefinitive": true,
    "RuntimeToleranceSeconds": 180,
    "MultiPartDurationToleranceSeconds": 300,
    "ExtraMaxDurationSeconds": 600
  },
  "Naming": {
    "Template": "{Series} - S{Season:D2}E{Episode:D2} - {Title}",
    "MultiPartTemplate": "{Series} - S{Season:D2}E{Episode:D2}{MultiPartSep}{Episode2:D2} - {Title}",
    "ExtraTemplate": "{Series} - S00 - {Title}",
    "SanitizeFileName": true
  },
  "Linting": {
    "FailOnError": true,
    "FailOnWarning": false,
    "SuppressedRules": [],
    "ExpectedEpisodeDurationSeconds": 0,
    "MultiPartDurationToleranceRatio": 0.25
  },
  "FileBot": {
    "MapFilePath": "./filebot-map.json",
    "FileBotDb": "TheTVDB"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
