{
  "ConnectionStrings": {
    "ArmDb": "Data Source=/etc/arm/config/arm.db"
  },
  "Arm": {
    "RawPath": "/home/arm/media/raw",
    "TranscodePath": "/home/arm/media/transcode",
    "CompletedPath": "/home/arm/media",
    "LogPath": "/home/arm/logs",
    "WebServerPort": 8080,
    "DelRawFiles": false
  },
  "DvdCompare": {
    "RuntimeToleranceSeconds": 60,
    "ReleaseIndex": 0
  },
  "FileBot": {
    "MapFilePath": "./filebot-map.json",
    "FileBotDb": "TheTVDB",
    "NonStrict": true
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "CliProcessRunner": "Debug",
      "ArmRipper.Core.Rip.DiscDb": "Debug",
      "ArmRipper.Core.Rip.TrackMapperService": "Debug",
      "ArmRipperService": "Debug",
      "IdentifyService": "Debug"
    }
  }
}
