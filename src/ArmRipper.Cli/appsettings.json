{
  "ConnectionStrings": {
    "ArmDb": "Data Source=/etc/arm/config/arm.db"
  },
  "Arm": {
    "RawPath": "/home/arm/media/raw",
    "TranscodePath": "/home/arm/media/transcode",
    "CompletedPath": "/home/arm/media/completed",
    "LogPath": "/home/arm/logs",
    "InstallPath": "/opt/arm",
    "DbFile": "/etc/arm/config/arm.db",
    "GetVideoTitle": true,
    "GetAudioTitle": "musicbrainz",
    "RipMethod": "mkv",
    "MainFeature": true,
    "Prevent99": true,
    "AutoEject": true,
    "SkipTranscode": false,
    "UseFfmpeg": false,
    "MinLength": 300,
    "MaxLength": 99999,
    "AllowDuplicates": true,
    "DelRawFiles": false,
    "NotifyRip": true,
    "NotifyTranscode": true,
    "OmdbApiKey": "5972cf35",
    "TmdbApiKey": "",
    "TvdbApiKey": "",
    "MetadataProvider": "omdb",
    "HbPresetDvd": "",
    "HbPresetBd": "Very Fast 1080p30",
    "HbArgsDvd": "-e nvenc_h264 --encoder-preset slower --quality 18 --enable-hw-decoding nvdec --encopts spatial-aq=1:aq-strength=10:bf=4:cabac=1:g=50:keyint-min=23 --all-audio --all-subtitles --subtitle-burned=none --aencoder aac --audio-fallback aac --mixdown none",
    "HbArgsBd": "-e nvenc_h265 --encoder-preset slow --quality 22 --enable-hw-decoding nvdec --encopts spatial-aq=1:aq-strength=10:g=50:keyint-min=23 --all-audio --all-subtitles --subtitle-burned=none --aencoder aac --audio-fallback aac --mixdown none",
    "DestExt": "mkv",
    "ExtrasSub": "extras",
    "FfmpegPostFileArgs": "-fflags +genpts -c:v copy -c:a ac3 -b:a 640k -c:s copy -map 0",
    "WebServerPort": 8080
  },
  "Tmdb": {
    "ApiKey": ""
  },
  "Tvdb": {
    "ApiKey": "",
    "ApiBaseUrl": "https://api4.thetvdb.com/v4"
  },
  "Omdb": {
    "ApiKey": ""
  },
  "EpisodeIdentification": {
    "ProviderOrder": ["DiscDb", "DvdCompare", "FileBot", "Tmdb", "Tvdb", "Omdb", "PositionalFallback"],
    "ShortCircuitOnDefinitive": true,
    "RuntimeToleranceSeconds": 180,
    "MultiPartDurationToleranceSeconds": 300,
    "ExtraMaxDurationSeconds": 600
  },
  "Naming": {
    "Template": "{Series} - S{Season:D2}E{Episode:D2} - {Title}",
    "MultiPartTemplate": "{Series} - S{Season:D2}E{Episode:D2}{MultiPartSep}{Episode2:D2} - {Title}",
    "ExtraTemplate": "{Series} - S00 - {Title}",
    "SanitizeFileName": true
  },
  "Linting": {
    "FailOnError": true,
    "FailOnWarning": false,
    "SuppressedRules": [],
    "ExpectedEpisodeDurationSeconds": 0,
    "MultiPartDurationToleranceRatio": 0.25
  },
  "DvdCompare": {
    "ComparisonUrl": "",
    "RuntimeToleranceSeconds": 1,
    "ReleaseIndex": 0
  },
  "FileBot": {
    "MapFilePath": "./filebot-map.json",
    "FileBotDb": "TheTVDB",
    "NonStrict": true
  }
}
