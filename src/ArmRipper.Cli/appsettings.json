{
  "ConnectionStrings": {
    "ArmDb": "Data Source=/etc/arm/config/arm.db"
  },
  "Arm": {
    "RawPath": "/home/arm/media/raw",
    "TranscodePath": "/home/arm/media/transcode",
    "CompletedPath": "/home/arm/media/completed",
    "LogPath": "/home/arm/logs",
    "InstallPath": "/opt/arm",
    "DbFile": "/etc/arm/config/arm.db",
    "GetVideoTitle": true,
    "GetAudioTitle": true,
    "RipMethod": "mkv",
    "MainFeature": true,
    "Prevent99": true,
    "AutoEject": true,
    "SkipTranscode": false,
    "UseFfmpeg": false,
    "MinLength": 600,
    "MaxLength": 99999,
    "AllowDuplicates": true,
    "DelRawFiles": true,
    "NotifyRip": true,
    "NotifyTranscode": true,
    "OmdbApiKey": "5972cf35",
    "MetadataProvider": "omdb",
    "HbPresetDvd": "HQ 480p30",
    "HbPresetBd": "Very Fast 1080p30",
    "HbArgsDvd": "-e nvenc_h264 --encoder-preset slower --quality 18 --enable-hw-decoding nvdec --encopts spatial-aq=1:aq-strength=10:bf=4:cabac=1:g=50:keyint-min=23 --all-audio --all-subtitles --subtitle-burned=none --aencoder ac3 --ab 640",
    "HbArgsBd": "-e nvenc_h265 --encoder-preset slow --quality 22 --enable-hw-decoding nvdec --encopts spatial-aq=1:aq-strength=10:g=50:keyint-min=23 --audio-lang-list eng --first-audio --all-subtitles --subtitle-burned=none --aencoder ac3 --ab 640 --mixdown 5point1",
    "DestExt": "mkv",
    "ExtrasSub": "extras",
    "FfmpegPostFileArgs": "-fflags +genpts -c:v copy -c:a ac3 -b:a 640k -c:s copy -map 0",
    "WebServerPort": 8080
  }
}
